# Environment Variables — Universal ERP System
# Copy this file to .env.local and fill in the values

# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────
DATABASE_URL="postgresql://unerp:unerp_password@localhost:5432/unerp_dev?schema=public"

# ──────────────────────────────────────────────
# Redis
# ──────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ──────────────────────────────────────────────
# Authentication
# ──────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
# REQUIRED — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=""
# REQUIRED for PII field encryption — generate with the same command
PII_ENCRYPTION_KEY=""

# ──────────────────────────────────────────────
# CRM Mailbox Integration (Google/Microsoft OAuth)
# Optional — required only to enable CRM > Settings > Email Integration.
# ──────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
MICROSOFT_OAUTH_CLIENT_ID=""
MICROSOFT_OAUTH_CLIENT_SECRET=""

# ──────────────────────────────────────────────
# API
# ──────────────────────────────────────────────
API_URL="http://localhost:4000"
API_PORT=4000

# ──────────────────────────────────────────────
# Web
# ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ──────────────────────────────────────────────
# File Storage (S3-compatible)
# ──────────────────────────────────────────────
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="unerp-uploads"

# ──────────────────────────────────────────────
# Email (Development — use Mailtrap or similar)
# ──────────────────────────────────────────────
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="noreply@unerp.dev"

# ──────────────────────────────────────────────
# Observability
# ──────────────────────────────────────────────
LOG_LEVEL="info"
# Sentry DSN — leave blank to disable error tracking
SENTRY_DSN=""

# ──────────────────────────────────────────────
# AI (self-hosted Ollama — https://ollama.com)
# ──────────────────────────────────────────────
# UniERP's AI copilot runs against a self-hosted Ollama server instead of a
# paid LLM API, to eliminate per-token cost. Install Ollama, run `ollama serve`,
# and pull the model before starting the API: `ollama pull llama3.2:3b`
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.2:3b"
