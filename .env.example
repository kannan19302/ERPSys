# Environment Variables — Universal ERP System
# GENERATED from apps/api/src/common/config/env.schema.ts (Track G.6).
# Do not edit by hand: change the schema, then run
#   node scripts/generate-env-example.mjs
# Copy to .env (repo root) and fill in the values.

# Runtime mode [default: "development"]
NODE_ENV=development

# PostgreSQL connection string (app runtime — unerp_api role, NOSUPERUSER NOBYPASSRLS) [REQUIRED]
DATABASE_URL=

# PostgreSQL connection string for migrations (owner/superuser role — not used at runtime) [REQUIRED]
DATABASE_OWNER_URL=

# Redis connection string (BullMQ queues, caching) [default: "redis://localhost:6379"]
REDIS_URL=redis://localhost:6379

# Port the NestJS API listens on [default: 4000]
API_PORT=4000

# Public web app origin (links in emails, redirects) [default: "http://localhost:3000"]
APP_URL=http://localhost:3000

# Session/JWT signing secret — generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))" [REQUIRED]
NEXTAUTH_SECRET=

# Auth callback base URL [default: "http://localhost:3000"]
NEXTAUTH_URL=http://localhost:3000

# Field-level PII encryption key (hex) — same generator as NEXTAUTH_SECRET [REQUIRED]
PII_ENCRYPTION_KEY=

# MFA TOTP secret encryption key; falls back to PII_ENCRYPTION_KEY when unset [optional]
MFA_ENCRYPTION_KEY=

# Extension-gateway service JWT secret (out-of-process industry apps) [default: "change-me"]
EXT_SERVICE_JWT_SECRET=change-me

# Web Push VAPID public key — generate: node -e "console.log(require('web-push').generateVAPIDKeys())" [optional]
VAPID_PUBLIC_KEY=

# Web Push VAPID private key; MFA push-approval is disabled when unset [optional]
VAPID_PRIVATE_KEY=

# Contact URI (mailto: or https:) sent with VAPID push requests [default: "mailto:admin@unerp.dev"]
VAPID_SUBJECT=mailto:admin@unerp.dev

# S3-compatible endpoint [default: "http://localhost:9000"]
S3_ENDPOINT=http://localhost:9000

# S3 access key [default: "minioadmin"]
S3_ACCESS_KEY=minioadmin

# S3 secret key [default: "minioadmin"]
S3_SECRET_KEY=minioadmin

# S3 bucket for uploads [default: "unerp-uploads"]
S3_BUCKET=unerp-uploads

# SMTP host (blank disables outbound email) [optional]
SMTP_HOST=

# SMTP port [default: 587]
SMTP_PORT=587

# SMTP username [optional]
SMTP_USER=

# SMTP password [optional]
SMTP_PASSWORD=

# From address for system email [default: "noreply@unerp.dev"]
SMTP_FROM=noreply@unerp.dev

# CRM mailbox: Google OAuth client id [optional]
GOOGLE_OAUTH_CLIENT_ID=

# CRM mailbox: Google OAuth client secret [optional]
GOOGLE_OAUTH_CLIENT_SECRET=

# CRM mailbox: Microsoft OAuth client id [optional]
MICROSOFT_OAUTH_CLIENT_ID=

# CRM mailbox: Microsoft OAuth client secret [optional]
MICROSOFT_OAUTH_CLIENT_SECRET=

# Stripe secret key (billing/e-commerce; blank disables) [optional]
STRIPE_SECRET_KEY=

# Stripe webhook signing secret [optional]
STRIPE_WEBHOOK_SECRET=

# Pino log level [default: "info"]
LOG_LEVEL=info

# Sentry DSN (blank disables error tracking) [optional]
SENTRY_DSN=

# OpenTelemetry OTLP exporter endpoint [optional]
OTEL_EXPORTER_OTLP_ENDPOINT=

# Ollama server URL [default: "http://localhost:11434"]
OLLAMA_BASE_URL=http://localhost:11434

# Ollama model tag [default: "llama3.2:3b"]
OLLAMA_MODEL=llama3.2:3b

# Blockchain layer flag — keep unset/false until Track E re-platforms it [optional]
BLOCKCHAIN_ENABLED=

# Use the local Fabric test network [optional]
FABRIC_USE_TEST_NETWORK=

# API origin used by the web app rewrite proxy [default: "http://localhost:4000"]
API_URL=http://localhost:4000

# Browser-visible API base URL [default: "http://localhost:4000/api/v1"]
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# Browser-visible app origin [default: "http://localhost:3000"]
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Reported platform core version (extension apiVersion window) [optional]
CORE_VERSION=

# Filesystem root for per-tenant installed app bundles [optional]
APP_TENANT_ROOT=

# Filesystem root for marketplace app bundles [optional]
APP_BUNDLE_ROOT=

# Override URL for the field-service extension app [optional]
FIELD_SERVICE_SERVICE_URL=
