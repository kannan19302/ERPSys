# Environment Variables — Universal ERP System
# Copy this file to .env.local and fill in the values

# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────
DATABASE_URL="postgresql://unerp:unerp_password@localhost:5432/unerp_dev?schema=public"

# ──────────────────────────────────────────────
# Redis
# ──────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ──────────────────────────────────────────────
# Authentication
# ──────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
# REQUIRED — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=""
# REQUIRED for PII field encryption — generate with the same command
PII_ENCRYPTION_KEY=""

# ──────────────────────────────────────────────
# API
# ──────────────────────────────────────────────
API_URL="http://localhost:4000"
API_PORT=4000

# ──────────────────────────────────────────────
# Web
# ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ──────────────────────────────────────────────
# File Storage (S3-compatible)
# ──────────────────────────────────────────────
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="unerp-uploads"

# ──────────────────────────────────────────────
# Email (Development — use Mailtrap or similar)
# ──────────────────────────────────────────────
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="noreply@unerp.dev"

# ──────────────────────────────────────────────
# Observability
# ──────────────────────────────────────────────
LOG_LEVEL="info"
# Sentry DSN — leave blank to disable error tracking
SENTRY_DSN=""

# ──────────────────────────────────────────────
# AI (Anthropic Claude)
# ──────────────────────────────────────────────
# Leave blank to disable AI features; copilot/summarization/generation will return graceful fallbacks
ANTHROPIC_API_KEY=""
AI_MODEL="claude-sonnet-4-6"
