# Environment Variables — Universal ERP System
# Copy this file to .env.local and fill in the values

# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────
DATABASE_URL="postgresql://unerp:unerp_password@localhost:5432/unerp_dev?schema=public"

# ──────────────────────────────────────────────
# Redis
# ──────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ──────────────────────────────────────────────
# Authentication
# ──────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-change-in-production"

# ──────────────────────────────────────────────
# API
# ──────────────────────────────────────────────
API_URL="http://localhost:4000"
API_PORT=4000

# ──────────────────────────────────────────────
# Web
# ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ──────────────────────────────────────────────
# File Storage (S3-compatible)
# ──────────────────────────────────────────────
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="unerp-uploads"

# ──────────────────────────────────────────────
# Email (Development — use Mailtrap or similar)
# ──────────────────────────────────────────────
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="noreply@unerp.dev"

# ──────────────────────────────────────────────
# Logging
# ──────────────────────────────────────────────
LOG_LEVEL="debug"
