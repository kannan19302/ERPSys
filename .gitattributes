# Auto-detect text files and normalize line endings
* text=auto

# Shell scripts must always have Unix-style line endings (LF)
# This is critical for Docker containers running Linux
*.sh text eol=lf
scripts/docker-entrypoint.sh text eol=lf

# Windows scripts keep CRLF
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
