{
  "slug": "lab-dashboard",
  "title": "Lab Dashboard",
  "type": "custom",
  "layout": [
    {
      "id": "w15",
      "type": "header",
      "title": "Laboratory",
      "gridSpan": 12,
      "config": {
        "subtitle": "Orders and results"
      }
    },
    {
      "id": "w16",
      "type": "kpi",
      "title": "Results",
      "gridSpan": 12,
      "config": {
        "items": [
          {
            "metric": "count:lab-order",
            "label": "Orders",
            "color": "#3b82f6"
          },
          {
            "metric": "critical_labs",
            "label": "Critical",
            "color": "#ef4444"
          },
          {
            "metric": "abnormal_labs",
            "label": "Abnormal",
            "color": "#f59e0b"
          }
        ]
      }
    },
    {
      "id": "w17",
      "type": "alert",
      "gridSpan": 12,
      "config": {
        "text": "Critical results require provider notification within 60 minutes.",
        "type": "danger"
      }
    },
    {
      "id": "w18",
      "type": "table",
      "title": "Results",
      "gridSpan": 12,
      "config": {
        "dataModelSlug": "lab-result",
        "maxRows": 6
      }
    }
  ],
  "module": "lab-diagnostics"
}