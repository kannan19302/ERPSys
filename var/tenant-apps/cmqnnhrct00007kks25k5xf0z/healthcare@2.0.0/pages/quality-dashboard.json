{
  "slug": "quality-dashboard",
  "title": "Quality & Analytics",
  "type": "custom",
  "layout": [
    {
      "id": "w32",
      "type": "header",
      "title": "Quality & Population Health",
      "gridSpan": 12,
      "config": {
        "subtitle": "HEDIS / MIPS-style measures computed from records"
      }
    },
    {
      "id": "w33",
      "type": "kpi",
      "title": "Volumes",
      "gridSpan": 12,
      "config": {
        "items": [
          {
            "metric": "count:patient",
            "label": "Patients",
            "color": "#3b82f6"
          },
          {
            "metric": "count:encounter",
            "label": "Encounters",
            "color": "#14b8a6"
          },
          {
            "metric": "count:claim",
            "label": "Claims",
            "color": "#8b5cf6"
          },
          {
            "metric": "abnormal_labs",
            "label": "Abnormal Labs",
            "color": "#f59e0b"
          }
        ]
      }
    },
    {
      "id": "w34",
      "type": "alert",
      "gridSpan": 12,
      "config": {
        "text": "Open the Quality Measures API (/api/v1/healthcare/quality/measures) for computed care-gap rates.",
        "type": "info"
      }
    }
