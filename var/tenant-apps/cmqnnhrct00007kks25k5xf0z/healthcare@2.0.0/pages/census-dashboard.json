{
  "slug": "census-dashboard",
  "title": "Bed Census",
  "type": "custom",
  "layout": [
    {
      "id": "w19",
      "type": "header",
      "title": "Inpatient Census",
      "gridSpan": 12,
      "config": {
        "subtitle": "Occupancy and admissions"
      }
    },
    {
      "id": "w20",
      "type": "kpi",
      "title": "Census",
      "gridSpan": 12,
      "config": {
        "items": [
          {
            "metric": "active_inpatients",
            "label": "Occupied Beds",
            "color": "#8b5cf6"
          },
          {
            "metric": "bed_occupancy_pct",
            "label": "Occupancy %",
            "color": "#f59e0b"
          },
          {
            "metric": "count:admission",
            "label": "Admissions",
            "color": "#3b82f6"
          }
        ]
      }
    },
    {
      "id": "w21",
      "type": "table",
      "title": "Bed Board",
      "gridSpan": 12,
      "config": {
        "dataModelSlug": "bed",
        "maxRows": 6
      }
    }
  ],
  "module": "inpatient-adt"
}