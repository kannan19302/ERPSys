{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "docker-dev",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "-f", "docker-compose.dev.yml", "up", "-d"],
      "port": 3000,
      "autoPort": false
    },
    {
      "name": "api",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@unerp/api", "dev"],
      "port": 3001
    },
    {
      "name": "web",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@unerp/web", "dev"],
      "port": 3000
    }
  ]
}
