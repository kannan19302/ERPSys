# ============================================================
# UniERP Dev Container — lightweight, no build steps.
# The monorepo is bind-mounted at runtime for live-reload.
# Build: docker build -f Dockerfile.dev -t unerp-dev .
# ============================================================
FROM node:22-alpine

# Install tini for proper signal handling (graceful shutdown of dev servers)
RUN apk add --no-cache tini bash

# Enable corepack (ships with Node 22) and activate pnpm
RUN corepack enable && corepack prepare pnpm@9.15.4 --activate

WORKDIR /app

# Copy the entrypoint script
COPY scripts/docker-entrypoint.sh /usr/local/bin/docker-entrypoint.sh
RUN chmod +x /usr/local/bin/docker-entrypoint.sh

# Use tini as init to reap zombie processes from dev watchers
ENTRYPOINT ["/sbin/tini", "--"]

# Default command: run the entrypoint
CMD ["/usr/local/bin/docker-entrypoint.sh"]
