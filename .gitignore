# Dependencies
node_modules/
.pnpm-store/

# Lockfiles (pnpm monorepo only)
package-lock.json
yarn.lock

# Build outputs
dist/
.next/
out/
*.tsbuildinfo
apps/api/src/**/*.js
apps/api/src/**/*.js.map

# Stray compiled output that sometimes lands in src/ instead of dist/ —
# excludes hand-written ambient declarations (css.d.ts, matchers.d.ts).
packages/*/src/**/*.js
packages/*/src/**/*.js.map
packages/*/src/**/*.d.ts.map
apps/*/src/**/*.d.ts
apps/*/src/**/*.d.ts.map
!packages/*/src/**/css.d.ts
!packages/*/src/**/matchers.d.ts

# Environment / Secrets (safety-hardened)
.env
.env.*
!.env.example

# IDE
.vscode/*
!.vscode/launch.json
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# Testing
coverage/
test-results/
playwright-report/

# Turbo
.turbo/

# Prisma
packages/database/prisma/*.db
packages/database/prisma/*.db-journal

# Logs & Caches
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache
.stylelintcache

# Docker
docker/data/
var/

# service-kit ships its compiled contract for git-subdir installs by app repos
!packages/service-kit/dist
!packages/service-kit/dist/**
dump.rdb

# Storybook
storybook-static/

# Generated AI-agent artifacts (regenerate locally; never commit)
.ai/FEATURE_LEDGER.md
.ai/ISSUE_INVENTORY.jsonl
.ai/locks/*.lock

# Local agent/tool settings & scratch
.claude/settings.local.json
.claude/worktrees/
.agents/
tsc_errors.txt
*.tmp
