model Setting {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  key       String
  value     Json
  category  String   @default("general")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, key])
  @@index([tenantId, category])
  @@map("settings")
}

// ════════════════════════════════════════════════
// PROCUREMENT MODULE (Phase 2)
// ════════════════════════════════════════════════

model PurchaseOrder {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  orgId           String    @map("org_id")
  vendorId        String    @map("vendor_id")
  poNumber        String    @map("po_number")
  status          String    @default("DRAFT") // DRAFT, SUBMITTED, APPROVED, PARTIALLY_RECEIVED, RECEIVED, CANCELLED
  orderDate       DateTime  @default(now()) @map("order_date")
  expectedDate    DateTime? @map("expected_date")
  subtotal        Decimal   @default(0) @db.Decimal(15, 2)
  taxAmount       Decimal   @default(0) @map("tax_amount") @db.Decimal(15, 2)
  discountAmount  Decimal   @default(0) @map("discount_amount") @db.Decimal(15, 2)
  totalAmount     Decimal   @default(0) @map("total_amount") @db.Decimal(15, 2)
  paidAmount      Decimal   @default(0) @map("paid_amount") @db.Decimal(15, 2)
  currency        String    @default("USD")
  exchangeRate    Decimal   @default(1) @map("exchange_rate") @db.Decimal(15, 6)
  shippingAddress Json?     @map("shipping_address")
  notes           String?
  internalNotes   String?   @map("internal_notes")
  approvedBy      String?   @map("approved_by")
  approvedAt      DateTime? @map("approved_at")
  createdBy       String?   @map("created_by")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")
  contractId      String?   @map("contract_id")

  rfqId               String? @map("rfq_id")
  supplierQuotationId String? @map("supplier_quotation_id")
  requisitionId       String? @map("requisition_id")
  blanketAgreementId  String? @map("blanket_agreement_id")

  vendor            Vendor                    @relation(fields: [vendorId], references: [id])
  contract          Contract?                 @relation(fields: [contractId], references: [id])
  rfq               RFQ?                      @relation(fields: [rfqId], references: [id])
  supplierQuotation SupplierQuotation?        @relation(fields: [supplierQuotationId], references: [id])
  requisition       PurchaseRequisition?      @relation(fields: [requisitionId], references: [id], onDelete: SetNull)
  blanketAgreement  BlanketPurchaseAgreement? @relation(fields: [blanketAgreementId], references: [id], onDelete: SetNull)
  lineItems         PurchaseOrderItem[]
  receipts          PurchaseReceipt[]
  debitNotes        DebitNote[]
  paymentSchedules  PaymentSchedule[]
  returns           PurchaseReturn[]

  @@unique([tenantId, orgId, poNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, vendorId])
  @@index([contractId])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String  @id @default(cuid())
  tenantId        String  @map("tenant_id")
  purchaseOrderId String  @map("purchase_order_id")
  productId       String? @map("product_id")
  description     String
  quantity        Decimal @db.Decimal(15, 3)
  receivedQty     Decimal @default(0) @map("received_qty") @db.Decimal(15, 3)
  unitPrice       Decimal @map("unit_price") @db.Decimal(15, 2)
  taxRate         Decimal @default(0) @map("tax_rate") @db.Decimal(5, 2)
  taxAmount       Decimal @default(0) @map("tax_amount") @db.Decimal(15, 2)
  totalAmount     Decimal @map("total_amount") @db.Decimal(15, 2)
  sortOrder       Int     @default(0) @map("sort_order")

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product?      @relation(fields: [productId], references: [id])

  @@index([tenantId])
  @@index([purchaseOrderId])
  @@map("purchase_order_items")
}

model PurchaseReceipt {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  purchaseOrderId String   @map("purchase_order_id")
  receiptNumber   String   @map("receipt_number")
  receivedDate    DateTime @default(now()) @map("received_date")
  warehouseId     String?  @map("warehouse_id")
  notes           String?
  createdBy       String?  @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at")

  purchaseOrder PurchaseOrder         @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  lineItems     PurchaseReceiptItem[]

  @@unique([tenantId, receiptNumber])
  @@index([tenantId])
  @@index([purchaseOrderId])
  @@map("purchase_receipts")
}

model PurchaseReceiptItem {
  id                String  @id @default(cuid())
  tenantId          String  @map("tenant_id")
  purchaseReceiptId String  @map("purchase_receipt_id")
  productId         String? @map("product_id")
  description       String
  receivedQty       Decimal @map("received_qty") @db.Decimal(15, 3)
  acceptedQty       Decimal @map("accepted_qty") @db.Decimal(15, 3)
  rejectedQty       Decimal @default(0) @map("rejected_qty") @db.Decimal(15, 3)

  purchaseReceipt PurchaseReceipt @relation(fields: [purchaseReceiptId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([purchaseReceiptId])
  @@map("purchase_receipt_items")
}

model RFQ {
  id            String    @id @default(cuid())
  tenantId      String    @map("tenant_id")
  orgId         String    @map("org_id")
  rfqNumber     String    @map("rfq_number")
  status        String    @default("DRAFT") // DRAFT, SENT, COMPLETED, CANCELLED
  expectedDate  DateTime? @map("expected_date")
  notes         String?
  isAuction     Boolean   @default(false) @map("is_auction")
  auctionEndsAt DateTime? @map("auction_ends_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  organization       Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  lineItems          RFQItem[]
  supplierQuotations SupplierQuotation[]
  purchaseOrders     PurchaseOrder[]
  auctionBids        RFQAuctionBid[]

  @@unique([tenantId, orgId, rfqNumber])
  @@index([tenantId])
  @@map("rfqs")
}

model RFQItem {
  id          String  @id @default(cuid())
  tenantId    String  @map("tenant_id")
  rfqId       String  @map("rfq_id")
  productId   String? @map("product_id")
  description String
  quantity    Decimal @db.Decimal(15, 3)

  rfq     RFQ      @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@index([tenantId])
  @@index([rfqId])
  @@map("rfq_items")
}

model SupplierQuotation {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  orgId           String   @map("org_id")
  rfqId           String?  @map("rfq_id")
  vendorId        String   @map("vendor_id")
  quotationNumber String   @map("quotation_number")
  status          String   @default("DRAFT") // DRAFT, SUBMITTED, APPROVED, REJECTED, EXPIRED, CONVERTED
  validUntil      DateTime @map("valid_until")
  subtotal        Decimal  @default(0) @db.Decimal(15, 2)
  taxAmount       Decimal  @default(0) @map("tax_amount") @db.Decimal(15, 2)
  totalAmount     Decimal  @default(0) @map("total_amount") @db.Decimal(15, 2)
  currency        String   @default("USD")
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  organization   Organization            @relation(fields: [orgId], references: [id], onDelete: Cascade)
  rfq            RFQ?                    @relation(fields: [rfqId], references: [id])
  vendor         Vendor                  @relation(fields: [vendorId], references: [id])
  lineItems      SupplierQuotationItem[]
  purchaseOrders PurchaseOrder[]

  @@unique([tenantId, orgId, quotationNumber])
  @@index([tenantId])
  @@index([rfqId])
  @@index([vendorId])
  @@map("supplier_quotations")
}

model SupplierQuotationItem {
  id                  String  @id @default(cuid())
  tenantId            String  @map("tenant_id")
  supplierQuotationId String  @map("supplier_quotation_id")
  productId           String? @map("product_id")
  description         String
  quantity            Decimal @db.Decimal(15, 3)
  unitPrice           Decimal @map("unit_price") @db.Decimal(15, 2)
  taxRate             Decimal @default(0) @map("tax_rate") @db.Decimal(5, 2)
  taxAmount           Decimal @default(0) @map("tax_amount") @db.Decimal(15, 2)
  totalAmount         Decimal @map("total_amount") @db.Decimal(15, 2)

  supplierQuotation SupplierQuotation @relation(fields: [supplierQuotationId], references: [id], onDelete: Cascade)
  product           Product?          @relation(fields: [productId], references: [id])

  @@index([tenantId])
  @@index([supplierQuotationId])
  @@map("supplier_quotation_items")
}

// ════════════════════════════════════════════════
// SALES MODULE (Phase 2)
// ════════════════════════════════════════════════

model Quotation {
  id                 String    @id @default(cuid())
  tenantId           String    @map("tenant_id")
  orgId              String    @map("org_id")
  customerId         String    @map("customer_id")
  quotationNumber    String    @map("quotation_number")
  status             String    @default("DRAFT") // DRAFT, SENT, ACCEPTED, REJECTED, EXPIRED, CONVERTED
  issueDate          DateTime  @default(now()) @map("issue_date")
  validUntil         DateTime  @map("valid_until")
  subtotal           Decimal   @default(0) @db.Decimal(15, 2)
  taxAmount          Decimal   @default(0) @map("tax_amount") @db.Decimal(15, 2)
  discountAmount     Decimal   @default(0) @map("discount_amount") @db.Decimal(15, 2)
  totalAmount        Decimal   @default(0) @map("total_amount") @db.Decimal(15, 2)
  currency           String    @default("USD")
  notes              String?
  termsConditions    String?   @map("terms_conditions")
  convertedToOrderId String?   @map("converted_to_order_id")
  templateId         String?   @map("template_id")
  version            Int       @default(1)
  opportunityId      String?   @map("opportunity_id")
  contactId          String?   @map("contact_id")
  createdBy          String?   @map("created_by")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")

  customer   Customer             @relation(fields: [customerId], references: [id])
  lineItems  QuotationItem[]
  sections   QuotationSection[]
  versions   QuotationVersion[]
  signatures QuotationSignature[]

  @@unique([tenantId, orgId, quotationNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, customerId])
  @@map("quotations")
}

model QuotationItem {
  id          String  @id @default(cuid())
  tenantId    String  @map("tenant_id")
  quotationId String  @map("quotation_id")
  productId   String? @map("product_id")
  description String
  quantity    Decimal @db.Decimal(15, 3)
  unitPrice   Decimal @map("unit_price") @db.Decimal(15, 2)
  taxRate     Decimal @default(0) @map("tax_rate") @db.Decimal(5, 2)
  taxAmount   Decimal @default(0) @map("tax_amount") @db.Decimal(15, 2)
  totalAmount Decimal @map("total_amount") @db.Decimal(15, 2)
  sortOrder   Int     @default(0) @map("sort_order")
  sectionId   String? @map("section_id")

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([quotationId])
  @@map("quotation_items")
}

model SalesOrder {
  id                      String    @id @default(cuid())
  tenantId                String    @map("tenant_id")
  orgId                   String    @map("org_id")
  customerId              String    @map("customer_id")
  orderNumber             String    @map("order_number")
  status                  String    @default("DRAFT") // DRAFT, CONFIRMED, PROCESSING, PARTIALLY_DELIVERED, DELIVERED, CANCELLED
  orderDate               DateTime  @default(now()) @map("order_date")
  deliveryDate            DateTime? @map("delivery_date")
  subtotal                Decimal   @default(0) @db.Decimal(15, 2)
  taxAmount               Decimal   @default(0) @map("tax_amount") @db.Decimal(15, 2)
  discountAmount          Decimal   @default(0) @map("discount_amount") @db.Decimal(15, 2)
  totalAmount             Decimal   @default(0) @map("total_amount") @db.Decimal(15, 2)
  currency                String    @default("USD")
  salesChannel            String    @default("B2B") @map("sales_channel")
  paymentMethod           String?   @map("payment_method")
  paymentStatus           String    @default("UNPAID") @map("payment_status")
  shippingAddress         Json?     @map("shipping_address")
  notes                   String?
  internalNotes           String?   @map("internal_notes")
  quotationId             String?   @map("quotation_id")
  invoiceId               String?   @map("invoice_id")
  contractId              String?   @map("contract_id")
  shippingHandlingCharges Decimal   @default(0) @map("shipping_handling_charges") @db.Decimal(15, 2)
  priceAdjustment         Decimal   @default(0) @map("price_adjustment") @db.Decimal(15, 2)
  createdBy               String?   @map("created_by")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")
  deletedAt               DateTime? @map("deleted_at")

  customer           Customer                 @relation(fields: [customerId], references: [id])
  contract           Contract?                @relation(fields: [contractId], references: [id])
  lineItems          SalesOrderItem[]
  deliveryNotes      DeliveryNote[]
  returns            SalesReturn[]
  storefrontPayments StorefrontOrderPayment[]

  @@unique([tenantId, orgId, orderNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, customerId])
  @@index([contractId])
  @@map("sales_orders")
}

model SalesOrderItem {
  id           String  @id @default(cuid())
  tenantId     String  @map("tenant_id")
  salesOrderId String  @map("sales_order_id")
  productId    String? @map("product_id")
  description  String
  quantity     Decimal @db.Decimal(15, 3)
  deliveredQty Decimal @default(0) @map("delivered_qty") @db.Decimal(15, 3)
  unitPrice    Decimal @map("unit_price") @db.Decimal(15, 2)
  taxRate      Decimal @default(0) @map("tax_rate") @db.Decimal(5, 2)
  taxAmount    Decimal @default(0) @map("tax_amount") @db.Decimal(15, 2)
  totalAmount  Decimal @map("total_amount") @db.Decimal(15, 2)
  sortOrder    Int     @default(0) @map("sort_order")

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  product    Product?   @relation(fields: [productId], references: [id])

  @@index([tenantId])
  @@index([salesOrderId])
  @@map("sales_order_items")
}

model DeliveryNote {
  id             String    @id @default(cuid())
  tenantId       String    @map("tenant_id")
  salesOrderId   String    @map("sales_order_id")
  deliveryNumber String    @map("delivery_number")
  status         String    @default("PENDING") // PENDING, IN_TRANSIT, DELIVERED, RETURNED
  deliveredDate  DateTime? @map("delivered_date")
  warehouseId    String?   @map("warehouse_id")
  carrierName    String?   @map("carrier_name")
  trackingNumber String?   @map("tracking_number")
  notes          String?
  createdBy      String?   @map("created_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  salesOrder SalesOrder         @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  lineItems  DeliveryNoteItem[]

  @@unique([tenantId, deliveryNumber])
  @@index([tenantId])
  @@index([salesOrderId])
  @@map("delivery_notes")
}

model DeliveryNoteItem {
  id             String  @id @default(cuid())
  tenantId       String  @map("tenant_id")
  deliveryNoteId String  @map("delivery_note_id")
  productId      String? @map("product_id")
  description    String
  deliveredQty   Decimal @map("delivered_qty") @db.Decimal(15, 3)

  deliveryNote DeliveryNote @relation(fields: [deliveryNoteId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([deliveryNoteId])
  @@map("delivery_note_items")
}

// ════════════════════════════════════════════════
// SUPPLY CHAIN MODULE (Phase 2)
// ════════════════════════════════════════════════

model Shipment {
  id                String    @id @default(cuid())
  tenantId          String    @map("tenant_id")
  orgId             String    @map("org_id")
  shipmentNumber    String    @map("shipment_number")
  type              String    @default("OUTBOUND") // INBOUND, OUTBOUND, TRANSFER
  status            String    @default("PENDING") // PENDING, PICKED_UP, IN_TRANSIT, DELIVERED, RETURNED, CANCELLED
  carrierName       String?   @map("carrier_name")
  trackingNumber    String?   @map("tracking_number")
  trackingUrl       String?   @map("tracking_url")
  originAddress     Json?     @map("origin_address")
  destAddress       Json?     @map("dest_address")
  weight            Decimal?  @db.Decimal(10, 2)
  weightUnit        String    @default("KG") @map("weight_unit")
  shippingCost      Decimal?  @map("shipping_cost") @db.Decimal(15, 2)
  currency          String    @default("USD")
  estimatedDelivery DateTime? @map("estimated_delivery")
  actualDelivery    DateTime? @map("actual_delivery")
  shippedAt         DateTime? @map("shipped_at")
  notes             String?
  createdBy         String?   @map("created_by")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@unique([tenantId, shipmentNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("shipments")
}

// ════════════════════════════════════════════════
// PROJECT MANAGEMENT MODULE (Phase 3)
// ════════════════════════════════════════════════

model Project {
  id               String    @id @default(cuid())
  tenantId         String    @map("tenant_id")
  orgId            String    @map("org_id")
  name             String
  code             String
  description      String?
  status           String    @default("PLANNED") // PLANNED, ACTIVE, ON_HOLD, COMPLETED, CANCELLED
  startDate        DateTime? @map("start_date")
  endDate          DateTime? @map("end_date")
  budget           Decimal?  @db.Decimal(15, 2)
  estimatedCost    Decimal?  @map("estimated_cost") @db.Decimal(15, 2)
  contractValue    Decimal?  @map("contract_value") @db.Decimal(15, 2)
  baselineSchedule String?   @map("baseline_schedule") @db.Text
  criticalPath     String?   @map("critical_path") @db.Text
  overallHealth    String?   @map("overall_health")
  portfolioId      String?   @map("portfolio_id")
  customerId       String?   @map("customer_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  portfolio      ProjectPortfolio?  @relation(fields: [portfolioId], references: [id], onDelete: SetNull)
  customer       Customer?          @relation(fields: [customerId], references: [id], onDelete: SetNull)
  tasks          Task[]
  milestones     Milestone[]
  journalEntries JournalEntry[]
  budgets        Budget[]
  risks          ProjectRisk[]
  changeRequests ChangeRequest[]
  costEntries    ProjectCostEntry[]
  invoices       Invoice[]

  @@unique([tenantId, orgId, code])
  @@index([tenantId])
  @@map("projects")
}

model ProjectPortfolio {
  id                 String   @id @default(cuid())
  tenantId           String   @map("tenant_id")
  orgId              String   @map("org_id")
  name               String
  description        String?
  riskScore          Decimal? @map("risk_score") @db.Decimal(5, 2)
  strategicAlignment String?  @map("strategic_alignment") // HIGH, MEDIUM, LOW
  budget             Decimal? @db.Decimal(15, 2)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  projects Project[]

  @@index([tenantId])
  @@map("project_portfolios")
}

model ProjectRisk {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  projectId      String   @map("project_id")
  title          String
  description    String?
  probability    String // LOW, MEDIUM, HIGH
  impact         String // LOW, MEDIUM, HIGH
  mitigationPlan String?  @map("mitigation_plan")
  status         String   @default("OPEN") // OPEN, MITIGATED, CLOSED
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([projectId])
  @@map("project_risks")
}

model ChangeRequest {
  id                    String    @id @default(cuid())
  tenantId              String    @map("tenant_id")
  projectId             String    @map("project_id")
  title                 String
  description           String?
  requestedAmount       Decimal   @map("requested_amount") @db.Decimal(15, 2)
  requestedScheduleDays Int       @map("requested_schedule_days")
  status                String    @default("PENDING") // PENDING, APPROVED, REJECTED
  approvedBy            String?   @map("approved_by")
  approvedAt            DateTime? @map("approved_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([projectId])
  @@map("change_requests")
}

model Task {
  id           String    @id @default(cuid())
  tenantId     String    @map("tenant_id")
  projectId    String    @map("project_id")
  name         String
  description  String?
  status       String    @default("BACKLOG") // BACKLOG, TODO, IN_PROGRESS, IN_REVIEW, DONE
  priority     String    @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  dueDate      DateTime? @map("due_date")
  assignedToId String?   @map("assigned_to_id")
  slaHours     Int?      @map("sla_hours")
  escalatedAt  DateTime? @map("escalated_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  timesheets Timesheet[]

  @@index([tenantId])
  @@index([projectId])
  @@map("tasks")
}

model Timesheet {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  taskId     String   @map("task_id")
  employeeId String   @map("employee_id")
  date       DateTime
  hours      Decimal  @db.Decimal(4, 2)
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([taskId])
  @@map("timesheets")
}

model Milestone {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  projectId   String   @map("project_id")
  name        String
  dueDate     DateTime @map("due_date")
  isCompleted Boolean  @default(false) @map("is_completed")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("milestones")
}

model ProjectCostEntry {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  projectId   String   @map("project_id")
  type        String // LABOR, MATERIAL, OVERHEAD
  amount      Decimal  @db.Decimal(15, 2)
  date        DateTime
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([projectId])
  @@map("project_cost_entries")
}

// ════════════════════════════════════════════════
// MANUFACTURING MODULE (Phase 3)
// ════════════════════════════════════════════════

model BOM {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  productId     String   @map("product_id")
  name          String
  code          String
  isActive      Boolean  @default(true) @map("is_active")
  materialCost  Decimal  @default(0) @map("material_cost") @db.Decimal(15, 3)
  overheadCost  Decimal  @default(0) @map("overhead_cost") @db.Decimal(15, 3)
  standardCost  Decimal  @default(0) @map("standard_cost") @db.Decimal(15, 3)
  routingJson   Json     @default("[]") // Operations list
  version       String   @default("1.0")
  status        String   @default("APPROVED") // APPROVED, UNDER_REVIEW, ARCHIVED
  previousBomId String?  @map("previous_bom_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  items                BOMItem[]
  workOrders           WorkOrder[]
  mrpPlannedItems      MRPPlannedItem[]
  subcontractingOrders SubcontractingOrder[]
  ecos                 EngineeringChangeOrder[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("boms")
}

model BOMItem {
  id        String  @id @default(cuid())
  tenantId  String  @map("tenant_id")
  bomId     String  @map("bom_id")
  productId String  @map("product_id")
  quantity  Decimal @db.Decimal(15, 3)
  type      String  @default("COMPONENT") // COMPONENT, CO_PRODUCT, BY_PRODUCT

  bom BOM @relation(fields: [bomId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([bomId])
  @@map("bom_items")
}

model WorkOrder {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  bomId           String    @map("bom_id")
  workOrderNumber String    @map("work_order_number")
  status          String    @default("DRAFT") // DRAFT, PLANNED, IN_PROGRESS, COMPLETED, CANCELLED
  quantity        Decimal   @db.Decimal(15, 3)
  startDate       DateTime? @map("start_date")
  endDate         DateTime? @map("end_date")
  oeeScore        Decimal?  @map("oee_score") @db.Decimal(5, 2)
  scrapQuantity   Decimal?  @map("scrap_quantity") @db.Decimal(15, 3)
  lotNumber       String?   @map("lot_number")
  workstationId   String?   @map("workstation_id")
  standardCost    Decimal?  @map("standard_cost") @db.Decimal(15, 3)
  actualCost      Decimal?  @map("actual_cost") @db.Decimal(15, 3)
  costVariance    Decimal?  @map("cost_variance") @db.Decimal(15, 3)
  overheadCost    Decimal?  @map("overhead_cost") @db.Decimal(15, 3)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  bom                   BOM                             @relation(fields: [bomId], references: [id])
  workstation           Workstation?                    @relation(fields: [workstationId], references: [id])
  ncrRecords            NonConformanceReport[]
  operations            WorkOrderOperation[]
  componentConsumptions WorkOrderComponentConsumption[]

  @@unique([tenantId, workOrderNumber])
  @@index([tenantId])
  @@map("work_orders")
}

// ════════════════════════════════════════════════
// BUSINESS INTELLIGENCE (Phase 4)
// ════════════════════════════════════════════════

model Dashboard {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  orgId       String   @map("org_id")
  name        String
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  layout      Json     @default("[]")
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("dashboards")
}

model Report {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  orgId       String   @map("org_id")
  name        String
  description String?
  query       Json     @default("{}")
  type        String   @default("BUILDER") // BUILDER, SQL
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("reports")
}

model KPI {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  orgId       String   @map("org_id")
  name        String
  code        String
  value       String
  unit        String?
  trend       Json     @default("[]")
  lastUpdated DateTime @default(now()) @map("last_updated")
  createdAt   DateTime @default(now()) @map("created_at")
