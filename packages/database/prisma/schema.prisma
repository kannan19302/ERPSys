// ════════════════════════════════════════════════
// WEB STUDIO — CMS COLLECTIONS (dynamic content modeling)
// Powers e-commerce catalogs, portfolios, team directories, testimonials, etc.
// ════════════════════════════════════════════════

model WebCollection {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  siteId      String?  @map("site_id") // owning site (multi-site); null = legacy/default
  name        String // e.g. "Products", "Projects", "Team"
  slug        String // URL-safe, used in public API + dynamic routes
  singular    String? // e.g. "Product" (for UI labels)
  description String?
  icon        String? // emoji or lucide name
  color       String?
  kind        String   @default("GENERIC") // GENERIC | PRODUCT | POST | PORTFOLIO | TEAM | TESTIMONIAL
  fields      Json     @default("[]") // [{ name, label, type, required, options, ... }]
  settings    Json     @default("{}") // titleField, slugField, imageField, sort, etc.
  status      String   @default("ACTIVE") // ACTIVE | ARCHIVED
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  items WebCollectionItem[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("web_collections")
}

model WebCollectionItem {
  id           String    @id @default(cuid())
  tenantId     String    @map("tenant_id")
  collectionId String    @map("collection_id")
  slug         String // item-level slug for /:collection/:slug routes
  data         Json      @default("{}") // the actual field values
  status       String    @default("DRAFT") // DRAFT | PUBLISHED | ARCHIVED
  featured     Boolean   @default(false)
  sortOrder    Int       @default(0) @map("sort_order")
  publishedAt  DateTime? @map("published_at")
  createdBy    String?   @map("created_by")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  collection WebCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@unique([collectionId, slug])
  @@index([tenantId, collectionId])
  @@index([tenantId, status])
  @@map("web_collection_items")
}

// Form submissions captured from public-facing website forms (contact, lead, newsletter).
model WebFormSubmission {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  siteId    String?  @map("site_id") // owning site (multi-site)
  formName  String   @map("form_name") // logical form identifier, e.g. "contact", "newsletter"
  pageSlug  String?  @map("page_slug") // which page it came from
  data      Json     @default("{}") // submitted field values
  status    String   @default("NEW") // NEW | READ | SPAM | ARCHIVED
  meta      Json     @default("{}") // ip, userAgent, referrer
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId, formName])
  @@index([tenantId, status])
  @@map("web_form_submissions")
}

// Orders captured from the public-facing storefront (e-commerce).
model WebOrder {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  siteId      String?  @map("site_id") // owning site (multi-site)
  orderNumber String   @map("order_number")
  status      String   @default("PENDING") // PENDING | PAID | FULFILLED | CANCELLED
  customer    Json     @default("{}") // { name, email, phone, address }
  items       Json     @default("[]") // [{ productSlug, name, price, qty, image }]
  subtotal    Float    @default(0)
  total       Float    @default(0)
  currency    String   @default("USD")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, orderNumber])
  @@index([tenantId, status])
  @@map("web_orders")
}

// ════════════════════════════════════════════════
// WEB STUDIO — MULTI-SITE WEBSITE BUILDER
// A tenant can build one or more sites, each served at its own custom
// domain(s) from "/". Pages/blog/docs/collections/forms/store/chatbot are
// scoped to a site.
// ════════════════════════════════════════════════

model WebSite {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  name      String
  slug      String // unique per tenant; the migrated legacy site is "default"
  status    String   @default("ACTIVE") // ACTIVE | ARCHIVED
  theme     Json     @default("{}") // colors, fonts, css tokens
  settings  Json     @default("{}") // nav, footer, favicon, analytics, etc.
  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  domains  WebDomain[]
  pages    WebSitePage[]
  chatbots WebChatbot[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("web_sites")
}

// Custom domain / subdomain mapping → site. The middleware resolves the
// request Host against this table to serve the right site at "/".
model WebDomain {
  id        String   @id @default(cuid())
  siteId    String   @map("site_id")
  host      String   @unique // e.g. "acme.com" or "acme.unerp.app"
  verified  Boolean  @default(false)
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")

  site WebSite @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId])
  @@map("web_domains")
}

model WebSitePage {
  id        String   @id @default(cuid())
  siteId    String   @map("site_id")
  tenantId  String   @map("tenant_id")
  path      String // "/" for home, "/about", "/blog/hello-world"
  title     String
  type      String   @default("PAGE") // PAGE | BLOG | DOCS | LANDING
  blocks    Json     @default("[]") // block tree rendered by PublicPageRenderer
  seo       Json     @default("{}") // { metaTitle, metaDesc, ogImage, keywords }
  status    String   @default("DRAFT") // DRAFT | PUBLISHED
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  site WebSite @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, path])
  @@index([siteId, status])
  @@index([tenantId])
  @@map("web_site_pages")
}

// Site AI chatbot — grounded in the site's collections/pages, answered via Claude.
model WebChatbot {
  id        String   @id @default(cuid())
  siteId    String   @map("site_id")
  tenantId  String   @map("tenant_id")
  name      String   @default("Assistant")
  enabled   Boolean  @default(true)
  config    Json     @default("{}") // { greeting, model, accent, persona }
  knowledge Json     @default("{}") // { collections: string[], usePages: boolean, custom: string }
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  site WebSite @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId])
  @@map("web_chatbots")
}

// ════════════════════════════════════════════════
// BUILDER STUDIO MODULE
// ════════════════════════════════════════════════

model SchemaRegistry {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  module      String // e.g., "crm", "hr", "custom"
  name        String // e.g., "Vehicle Maintenance"
  slug        String // e.g., "vehicle_maintenance"
  description String?
  isCustom    Boolean  @default(true) @map("is_custom")
  fields      Json     @default("[]") // Definition of fields/columns
  settings    Json     @default("{}") // RBAC, naming series, etc.
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  pageRegistries PageRegistry[]
  customRecords  CustomRecord[]

  @@unique([tenantId, slug])
  @@index([tenantId, module])
  @@map("schema_registries")
}

model PageRegistry {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  schemaId  String?  @map("schema_id")
  module    String // e.g., "crm"
  slug      String // Unique URL path segment
  title     String
  type      String   @default("FORM") // FORM, LIST, DASHBOARD, REPORT
  layout    Json     @default("[]") // The JSON DOM (fields, grids, sections)
  history   Json[]   @default([]) // Array of previous layouts for rollback
  status    String   @default("DRAFT") // DRAFT, PUBLISHED
  isCustom  Boolean  @default(true) @map("is_custom")
  submodule String? // named submodule group within a core app (App Studio extension)
  navIcon   String?  @map("nav_icon") // optional lucide icon name for the sidebar entry
  sortOrder Int      @default(0) @map("sort_order") // ordering within its submodule section
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  schemaRegistry SchemaRegistry? @relation(fields: [schemaId], references: [id])

  @@unique([tenantId, module, slug])
  @@index([tenantId])
  @@map("page_registries")
}

model CustomRecord {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  schemaId  String   @map("schema_id")
  data      Json     @default("{}") // The actual submitted user data
  status    String   @default("ACTIVE")
  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  schemaRegistry SchemaRegistry @relation(fields: [schemaId], references: [id], onDelete: Cascade)

  @@index([tenantId, schemaId])
  @@index([tenantId, createdAt])
  @@map("custom_records")
}

// Per-tenant, non-destructive customization of an existing app's sidebar nav.
// Absence of a row ⇒ stock navigation (reset = delete the row). `config` holds:
//   { order: string[], hidden: string[], renames: Record<string,string>,
//     submodules: { slug, name, icon?, order? }[] }
// Submodule pages themselves live in PageRegistry (tagged via `submodule`).
model AppNavOverlay {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  moduleId  String   @map("module_id") // core app slug, e.g. "finance"
  config    Json     @default("{}")
  updatedBy String?  @map("updated_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, moduleId])
  @@index([tenantId])
  @@map("app_nav_overlays")
}

