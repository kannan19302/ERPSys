// ════════════════════════════════════════════════
// CRM — CONTRACT / RENEWAL MANAGEMENT
// ════════════════════════════════════════════════

model Contract {
  id                      String    @id @default(cuid())
  tenantId                String    @map("tenant_id")
  orgId                   String    @map("org_id")
  contractNumber          String    @map("contract_number")
  title                   String
  customerId              String?   @map("customer_id")
  vendorId                String?   @map("vendor_id")
  type                    String    @default("SALES") // SALES, PURCHASE, SERVICE, NDA, OTHER
  value                   Decimal   @db.Decimal(15, 2)
  currency                String    @default("USD")
  startDate               DateTime  @map("start_date")
  endDate                 DateTime  @map("end_date")
  renewalDate             DateTime  @map("renewal_date")
  autoRenew               Boolean   @default(false) @map("auto_renew")
  renewalTermMonths       Int?      @map("renewal_term_months")
  status                  String    @default("DRAFT") // DRAFT, ACTIVE, EXPIRING_SOON, EXPIRED, TERMINATED, RENEWED
  contractType            String    @default("ONE_TIME") @map("contract_type")
  terms                   String?
  ownerId                 String?   @map("owner_id")
  renewedFromId           String?   @map("renewed_from_id")
  revisedFromId           String?   @map("revised_from_id")
  approvalStatus          String    @default("DRAFT") @map("approval_status")
  approverId              String?   @map("approver_id")
  signatureStatus         String    @default("UNSIGNED") @map("signature_status")
  signerName              String?   @map("signer_name")
  signerEmail             String?   @map("signer_email")
  signedAt                DateTime? @map("signed_at")
  shippingHandlingCharges Decimal   @default(0) @map("shipping_handling_charges") @db.Decimal(15, 2)
  priceAdjustment         Decimal   @default(0) @map("price_adjustment") @db.Decimal(15, 2)
  taxRate                 Decimal   @default(0) @map("tax_rate") @db.Decimal(5, 2)
  billingAddress          String?   @map("billing_address")
  shippingAddress         String?   @map("shipping_address")
  deliveryNotes           String?   @map("delivery_notes")
  shippingCarrier         String?   @map("shipping_carrier")
  trackingNumber          String?   @map("tracking_number")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")
  deletedAt               DateTime? @map("deleted_at")

  organization      Organization               @relation(fields: [orgId], references: [id], onDelete: Cascade)
  customer          Customer?                  @relation(fields: [customerId], references: [id])
  vendor            Vendor?                    @relation(fields: [vendorId], references: [id])
  renewedFrom       Contract?                  @relation("ContractRenewal", fields: [renewedFromId], references: [id])
  renewals          Contract[]                 @relation("ContractRenewal")
  revisedFrom       Contract?                  @relation("ContractRevision", fields: [revisedFromId], references: [id])
  revisions         Contract[]                 @relation("ContractRevision")
  lineItems         ContractLineItem[]
  billingMilestones ContractBillingMilestone[]
  salesOrders       SalesOrder[]
  purchaseOrders    PurchaseOrder[]

  @@unique([tenantId, contractNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([customerId])
  @@index([vendorId])
  @@index([renewalDate])
  @@index([ownerId])
  @@map("crm_contracts")
}

