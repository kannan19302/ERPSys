  @@unique([tenantId, passNumber])
  @@index([tenantId])
  @@map("gate_passes")
}

model YardMove {
  id              String         @id @default(cuid())
  tenantId        String         @map("tenant_id")
  appointmentId   String?        @map("appointment_id")
  warehouseId     String         @map("warehouse_id")
  trailerNumber   String         @map("trailer_number")
