  tenantId        String   @map("tenant_id")
  cardId          String   @map("card_id")
  transactionDate DateTime @map("transaction_date")
  merchant        String
  amount          Decimal  @db.Decimal(15, 2)
  status          String   @default("UNMATCHED") // UNMATCHED, MATCHED, IGNORED
