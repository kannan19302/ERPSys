  @@unique([tenantId, metric])
  @@index([tenantId])
  @@map("usage_records")
}

model InstalledApp {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  appId       String   @map("app_id")
  appSlug     String?  @map("app_slug")
  appName     String?  @map("app_name")
  installedAt DateTime @default(now()) @map("installed_at")
  installedBy String?  @map("installed_by")
  status      String   @default("ACTIVE") // ACTIVE | DISABLED | PENDING
  config      Json     @default("{}")

  // ─── Builder-app & marketplace-bundle installs (null for static catalog apps) ───
  source           String  @default("CATALOG") // CATALOG | BUILDER | MARKETPLACE
  sourceModuleId   String? @map("source_module_id")
  releaseId        String? @map("release_id")
  bundleId         String? @map("bundle_id") // AppBundle.id for MARKETPLACE installs
  installPath      String? @map("install_path") // absolute path of extracted bundle dir (deleted on uninstall)
  installedVersion String? @map("installed_version")
  provisioned      Json    @default("{}") // {pageRegistryIds:[], schemaRegistryIds:[], automationRuleIds:[]} for teardown on uninstall
  serviceConfig    Json?   @map("service_config") // manifest `service` section for declarative+service apps (ext-gateway routing)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, appId])
  @@index([tenantId])
  @@map("installed_apps")
}

