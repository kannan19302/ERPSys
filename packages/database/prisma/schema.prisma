  tenantId      String    @map("tenant_id")
  taskNumber    String    @map("task_number")
  taskType      String    @map("task_type")      // PICK | PUTAWAY | REPLENISH | BIN_TRANSFER | RECEIVE | PACK | CYCLE_COUNT
