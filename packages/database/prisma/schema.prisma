  batchNumber     String?   @map("batch_number")
  lotNo           String?   @map("lot_no")
  quantity        Decimal   @default(0) @db.Decimal(15, 3)
  usedQty         Decimal   @default(0) @map("used_qty") @db.Decimal(15, 3)
  manufactureDate DateTime? @map("manufacture_date")
  expiryDate      DateTime? @map("expiry_date")
  supplierBatchNo String?   @map("supplier_batch_no")
