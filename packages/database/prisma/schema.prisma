  createdAt       DateTime @default(now()) @map("created_at")

  consolidation ConsolidationRun @relation(fields: [consolidationId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("consolidation_eliminations")
}

model FinanceAuditLog {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
