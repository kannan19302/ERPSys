// ════════════════════════════════════════════════
// PROJECT MANAGEMENT MODULE (Phase 3)
// ════════════════════════════════════════════════

model Project {
  id               String    @id @default(cuid())
  tenantId         String    @map("tenant_id")
  orgId            String    @map("org_id")
  name             String
  code             String
  description      String?
  status           String    @default("PLANNED") // PLANNED, ACTIVE, ON_HOLD, COMPLETED, CANCELLED
  startDate        DateTime? @map("start_date")
  endDate          DateTime? @map("end_date")
  budget           Decimal?  @db.Decimal(15, 2)
  baselineSchedule String?   @map("baseline_schedule") @db.Text
  criticalPath     String?   @map("critical_path") @db.Text
  overallHealth    String?   @map("overall_health")
  portfolioId      String?   @map("portfolio_id")
  customerId       String?   @map("customer_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  portfolio      ProjectPortfolio? @relation(fields: [portfolioId], references: [id], onDelete: SetNull)
  customer       Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  tasks          Task[]
  milestones     Milestone[]
  journalEntries JournalEntry[]
  budgets        Budget[]
  risks          ProjectRisk[]
  changeRequests ChangeRequest[]

  @@unique([tenantId, orgId, code])
  @@index([tenantId])
  @@map("projects")
}

model ProjectPortfolio {
  id                 String   @id @default(cuid())
  tenantId           String   @map("tenant_id")
  orgId              String   @map("org_id")
  name               String
  description        String?
  riskScore          Decimal? @map("risk_score") @db.Decimal(5, 2)
  strategicAlignment String?  @map("strategic_alignment") // HIGH, MEDIUM, LOW
  budget             Decimal? @db.Decimal(15, 2)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  projects Project[]

  @@index([tenantId])
  @@map("project_portfolios")
}

model ProjectRisk {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  projectId      String   @map("project_id")
  title          String
  description    String?
  probability    String // LOW, MEDIUM, HIGH
  impact         String // LOW, MEDIUM, HIGH
  mitigationPlan String?  @map("mitigation_plan")
  status         String   @default("OPEN") // OPEN, MITIGATED, CLOSED
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([projectId])
  @@map("project_risks")
}

model ChangeRequest {
  id                    String    @id @default(cuid())
  tenantId              String    @map("tenant_id")
