// ─────────────────────────────────────────────────
// Prisma Schema — Universal ERP System
// ─────────────────────────────────────────────────
// This is the single source of truth for the database schema.
// All entities follow the patterns defined in .ai/DATA_MODEL.md
// ─────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ════════════════════════════════════════════════
// MULTI-TENANCY & AUTH
// ════════════════════════════════════════════════

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      String   @default("free")
  status    String   @default("ACTIVE")
  settings  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users         User[]
  organizations Organization[]
  subscription  TenantSubscription?
  installedApps InstalledApp[]

  @@map("tenants")
}

model User {
  id           String    @id @default(cuid())
  tenantId     String    @map("tenant_id")
  email        String
  passwordHash String?   @map("password_hash")
  firstName    String    @map("first_name")
  lastName     String    @map("last_name")
  avatar       String?
  status       String    @default("ACTIVE")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")
  preferences  Json      @default("{}")

  tenant Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roles  UserRole[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
  @@map("users")
}

model Role {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  name        String
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  permissions Json     @default("[]")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users UserRole[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("roles")
}

model UserRole {
  userId     String   @map("user_id")
  roleId     String   @map("role_id")
  assignedAt DateTime @default(now()) @map("assigned_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

// ════════════════════════════════════════════════
// ORGANIZATION STRUCTURE
// ════════════════════════════════════════════════

model Organization {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  name            String
  legalName       String?  @map("legal_name")
  taxId           String?  @map("tax_id")
  email           String?
  phone           String?
  website         String?
  logo            String?
  address         Json?
  currency        String   @default("USD")
  timezone        String   @default("UTC")
  fiscalYearStart Int      @default(1) @map("fiscal_year_start")
  settings        Json     @default("{}")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant               Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  departments          Department[]
  customers            Customer[]
  vendors              Vendor[]
  products             Product[]
  warehouses           Warehouse[]
  creditNotes          CreditNote[]
  debitNotes           DebitNote[]
  dunningLevels        DunningLevel[]
  dunningRuns          DunningRun[]
  paymentSchedules     PaymentSchedule[]
  paymentRuns          PaymentRun[]
  budgets              Budget[]
  forecastScenarios    ForecastScenario[]
  taxRules             TaxRule[]
  withholdingTaxes     WithholdingTax[]
  taxFilings           TaxFiling[]
  outgoingTransfers    InterCompanyTransfer[] @relation("FromOrganization")
  incomingTransfers    InterCompanyTransfer[] @relation("ToOrganization")
  investmentPortfolios InvestmentPortfolio[]
  treasuryTransactions TreasuryTransaction[]
  rfqs                 RFQ[]
  supplierQuotations   SupplierQuotation[]
  campaigns            Campaign[]
  salesReturns         SalesReturn[]
  purchaseReturns      PurchaseReturn[]

  @@index([tenantId])
  @@map("organizations")
}

model Department {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  orgId     String   @map("org_id")
  name      String
  code      String
  parentId  String?  @map("parent_id")
  managerId String?  @map("manager_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization   Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  parent         Department?    @relation("DeptHierarchy", fields: [parentId], references: [id])
  children       Department[]   @relation("DeptHierarchy")
  employees      Employee[]
  journalEntries JournalEntry[]

  @@unique([tenantId, orgId, code])
  @@index([tenantId])
  @@map("departments")
}

// ════════════════════════════════════════════════
// HR MODULE
// ════════════════════════════════════════════════

model Employee {
  id             String    @id @default(cuid())
  tenantId       String    @map("tenant_id")
  orgId          String    @map("org_id")
  userId         String?   @map("user_id")
  departmentId   String?   @map("department_id")
  employeeCode   String    @map("employee_code")
  firstName      String    @map("first_name")
  lastName       String    @map("last_name")
  email          String
  phone          String?
  designation    String?
  dateOfBirth    DateTime? @map("date_of_birth")
  dateOfJoining  DateTime  @map("date_of_joining")
  dateOfLeaving  DateTime? @map("date_of_leaving")
  employmentType String    @default("FULL_TIME") @map("employment_type")
  status         String    @default("ACTIVE")
  address        Json?
  bankDetails    Json?     @map("bank_details")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  department          Department?          @relation(fields: [departmentId], references: [id])
  practitioners       Practitioner[]
  trainingEnrollments TrainingEnrollment[]

  @@unique([tenantId, orgId, employeeCode])
  @@index([tenantId])
  @@map("employees")
}

// ════════════════════════════════════════════════
// CRM MODULE
// ════════════════════════════════════════════════

model Customer {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  orgId           String    @map("org_id")
  type            String    @default("COMPANY")
  name            String
  email           String?
  phone           String?
  taxId           String?   @map("tax_id")
  billingAddress  Json?     @map("billing_address")
  shippingAddress Json?     @map("shipping_address")
  creditLimit     Decimal?  @map("credit_limit") @db.Decimal(15, 2)
  paymentTerms    Int       @default(30) @map("payment_terms")
  status          String    @default("ACTIVE")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  invoices     Invoice[]
  quotations   Quotation[]
  salesOrders  SalesOrder[]
  creditNotes  CreditNote[]
  contacts     Contact[] // Added for inverse relation
  opportunities Opportunity[] // Added for inverse relation
  activities   Activity[] // Added for inverse relation
  salesReturns  SalesReturn[]

  @@index([tenantId])
  @@index([tenantId, orgId])
  @@map("customers")
}

model Vendor {
  id           String    @id @default(cuid())
  tenantId     String    @map("tenant_id")
  orgId        String    @map("org_id")
  type         String    @default("COMPANY")
  name         String
  email        String?
  phone        String?
  taxId        String?   @map("tax_id")
  address      Json?
  paymentTerms Int       @default(30) @map("payment_terms")
  status       String    @default("ACTIVE")
  notes        String?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  organization     Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  purchaseOrders   PurchaseOrder[]
  debitNotes       DebitNote[]
  paymentSchedules PaymentSchedule[]
  supplierQuotations SupplierQuotation[]
  purchaseReturns  PurchaseReturn[]

  @@index([tenantId])
  @@map("vendors")
}

model Contact {
  id               String   @id @default(cuid())
  tenantId         String   @map("tenant_id")
  orgId            String   @map("org_id")
  customerId       String?  @map("customer_id")
  salutation       String?
  firstName        String   @map("first_name")
  lastName         String   @map("last_name")
  email            String?
  phone            String?
  mobile           String?
  title            String?
  department       String?
  isPrimary        Boolean  @default(false) @map("is_primary")
  isActive         Boolean  @default(true) @map("is_active")
  notes            String?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  customer Customer? @relation(fields: [customerId], references: [id])
  activities Activity[] // Added for inverse relation

  @@unique([tenantId, orgId, email])
  @@index([tenantId])
  @@index([customerId])
  @@map("contacts")
}

model LeadSource {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  leads Lead[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("lead_sources")
}

model Lead {
  id            String    @id @default(cuid())
  tenantId      String    @map("tenant_id")
  orgId         String    @map("org_id")
  salutation    String?
  firstName     String    @map("first_name")
  lastName      String    @map("last_name")
  company       String?
  title         String?
  email         String?
  phone         String?
  mobile        String?
  website       String?
  sourceId      String?   @map("source_id")
  status        String    @default("NEW") // NEW, CONTACTED, QUALIFIED, DISQUALIFIED, CONVERTED
  industry      String?
  employeeCount Int?      @map("employee_count")
  annualRevenue Decimal?  @map("annual_revenue") @db.Decimal(15, 2)
  score         Int       @default(0)
  notes         String?
  assignedToId  String?   @map("assigned_to_id")
  convertedCustomerId String? @map("converted_customer_id")
  convertedOpportunityId String? @map("converted_opportunity_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  campaignId    String?   @map("campaign_id")

  source       LeadSource?   @relation(fields: [sourceId], references: [id])
  campaign     Campaign?     @relation(fields: [campaignId], references: [id])
  activities   Activity[]
  opportunities Opportunity[] @relation("LeadOpportunity")

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([campaignId])
  @@index([assignedToId])
  @@map("leads")
}

model SalesPipeline {
  id               String   @id @default(cuid())
  tenantId         String   @map("tenant_id")
  name             String
  stages           Json     @default("[]") // Array of {label, probability, order}
  isDefault        Boolean  @default(false) @map("is_default")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  opportunities Opportunity[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("sales_pipelines")
}

model Opportunity {
  id             String    @id @default(cuid())
  tenantId       String    @map("tenant_id")
  orgId          String    @map("org_id")
  name           String
  customerId     String?   @map("customer_id")
  leadId         String?   @map("lead_id")
  pipelineId     String?   @map("pipeline_id")
  stage          String    @default("PROSPECTING") // Prospecting, Qualification, Proposal, Negotiation, Closed Won, Closed Lost
  amount         Decimal?  @db.Decimal(15, 2)
  probability    Int       @default(0) // 0-100
  expectedCloseDate DateTime? @map("expected_close_date")
  actualCloseDate DateTime? @map("actual_close_date")
  competitor     String?
  lossReason     String?   @map("loss_reason")
  notes          String?
  assignedToId   String?   @map("assigned_to_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  customer Customer?       @relation(fields: [customerId], references: [id])
  lead     Lead?           @relation("LeadOpportunity", fields: [leadId], references: [id])
  pipeline SalesPipeline?  @relation(fields: [pipelineId], references: [id])
  activities Activity[]

  @@index([tenantId])
  @@index([tenantId, stage])
  @@index([tenantId, pipelineId])
  @@index([customerId])
  @@map("opportunities")
}

model Activity {
  id            String    @id @default(cuid())
  tenantId      String    @map("tenant_id")
  orgId         String    @map("org_id")
  type          String    // CALL, EMAIL, MEETING, NOTE, TASK, QUOTE_SENT, ORDER_PLACED
  subject       String
  description   String?
  leadId        String?   @map("lead_id")
  opportunityId String?   @map("opportunity_id")
  customerId    String?   @map("customer_id")
  contactId     String?   @map("contact_id")
  dueDate       DateTime? @map("due_date")
  completedAt   DateTime? @map("completed_at")
  assignedToId  String?   @map("assigned_to_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  lead        Lead?        @relation(fields: [leadId], references: [id])
  opportunity Opportunity? @relation(fields: [opportunityId], references: [id])
  customer    Customer?    @relation(fields: [customerId], references: [id])
  contact     Contact?     @relation(fields: [contactId], references: [id])

  @@index([tenantId])
  @@index([leadId])
  @@index([opportunityId])
  @@index([customerId])
  @@map("activities")
}

model EmailTemplate {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  name        String
  category    String   @default("GENERAL") // GENERAL, QUOTATION, INVOICE, FOLLOWUP
  subject     String
  body        String
  variables   Json     @default("[]") // Available variable names
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("email_templates")
}

// ════════════════════════════════════════════════
// INVENTORY MODULE
// ════════════════════════════════════════════════

model Product {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenant_id")
  orgId       String    @map("org_id")
  sku         String
  name        String
  description String?
  type        String    @default("GOODS")
  category    String?
  unit        String    @default("EACH")
  costPrice   Decimal   @map("cost_price") @db.Decimal(15, 2)
  sellPrice   Decimal   @map("sell_price") @db.Decimal(15, 2)
  taxCategory String?   @map("tax_category")
  isActive    Boolean   @default(true) @map("is_active")
  images      Json      @default("[]")
  attributes  Json      @default("{}")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  organization       Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  inventoryItems     InventoryItem[]
  invoiceLines       InvoiceLineItem[]
  purchaseOrderItems PurchaseOrderItem[]
  salesOrderItems    SalesOrderItem[]
  serialNumbers      SerialNumber[]
  batches            Batch[]
  stockLedgerEntries StockLedgerEntry[]
  stockEntryItems    StockEntryItem[]
  qualityInspections QualityInspection[]
  cycleCountItems    CycleCountItem[]
  rfqItems           RFQItem[]
  supplierQuotationItems SupplierQuotationItem[]
  salesReturnItems   SalesReturnItem[]
  purchaseReturnItems PurchaseReturnItem[]

  @@unique([tenantId, orgId, sku])
  @@index([tenantId])
  @@map("products")
}

model Warehouse {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  orgId     String   @map("org_id")
  name      String
  code      String
  address   Json?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization       Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  inventoryItems     InventoryItem[]
  stockLedgerEntries StockLedgerEntry[]

  @@unique([tenantId, orgId, code])
  @@index([tenantId])
  @@map("warehouses")
}

model InventoryItem {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  productId    String   @map("product_id")
  warehouseId  String   @map("warehouse_id")
  quantity     Decimal  @default(0) @db.Decimal(15, 3)
  reorderPoint Decimal? @map("reorder_point") @db.Decimal(15, 3)
  reorderQty   Decimal? @map("reorder_qty") @db.Decimal(15, 3)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([tenantId, productId, warehouseId])
  @@index([tenantId])
  @@map("inventory_items")
}

// ════════════════════════════════════════════════
// FINANCE MODULE
// ════════════════════════════════════════════════

model Invoice {
  id             String    @id @default(cuid())
  tenantId       String    @map("tenant_id")
  orgId          String    @map("org_id")
  customerId     String    @map("customer_id")
  invoiceNumber  String    @map("invoice_number")
  status         String    @default("DRAFT")
  issueDate      DateTime  @default(now()) @map("issue_date")
  dueDate        DateTime  @map("due_date")
  subtotal       Decimal   @default(0) @db.Decimal(15, 2)
  taxAmount      Decimal   @default(0) @map("tax_amount") @db.Decimal(15, 2)
  discountAmount Decimal   @default(0) @map("discount_amount") @db.Decimal(15, 2)
  totalAmount    Decimal   @default(0) @map("total_amount") @db.Decimal(15, 2)
  paidAmount     Decimal   @default(0) @map("paid_amount") @db.Decimal(15, 2)
  currency       String    @default("USD")
  exchangeRate   Decimal   @default(1) @map("exchange_rate") @db.Decimal(15, 6)
  notes          String?
  internalNotes  String?   @map("internal_notes")
  paidAt         DateTime? @map("paid_at")
  sentAt         DateTime? @map("sent_at")
  createdBy      String?   @map("created_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  customer    Customer          @relation(fields: [customerId], references: [id])
  lineItems   InvoiceLineItem[]
  payments    Payment[]
  creditNotes CreditNote[]

  @@unique([tenantId, orgId, invoiceNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, customerId])
  @@map("invoices")
}

model InvoiceLineItem {
  id          String  @id @default(cuid())
  tenantId    String  @map("tenant_id")
  invoiceId   String  @map("invoice_id")
  productId   String? @map("product_id")
  description String
  quantity    Decimal @db.Decimal(15, 3)
  unitPrice   Decimal @map("unit_price") @db.Decimal(15, 2)
  taxRate     Decimal @default(0) @map("tax_rate") @db.Decimal(5, 2)
  taxAmount   Decimal @default(0) @map("tax_amount") @db.Decimal(15, 2)
  totalAmount Decimal @map("total_amount") @db.Decimal(15, 2)
  sortOrder   Int     @default(0) @map("sort_order")

  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@index([tenantId])
  @@index([invoiceId])
  @@map("invoice_line_items")
}

model Payment {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  invoiceId String   @map("invoice_id")
  amount    Decimal  @db.Decimal(15, 2)
  currency  String   @default("USD")
  method    String   @default("BANK_TRANSFER")
  reference String?
  notes     String?
  paidAt    DateTime @default(now()) @map("paid_at")
  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([invoiceId])
  @@map("payments")
}

// ════════════════════════════════════════════════
// AUDIT & SYSTEM
// ════════════════════════════════════════════════

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  userId     String   @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  changes    Json?
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([tenantId, entityType, entityId])
  @@index([tenantId, userId])
  @@index([tenantId, createdAt])
  @@map("audit_logs")
}

model Setting {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  key       String
  value     Json
  category  String   @default("general")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, key])
  @@index([tenantId, category])
  @@map("settings")
}

// ════════════════════════════════════════════════
// PROCUREMENT MODULE (Phase 2)
// ════════════════════════════════════════════════

model PurchaseOrder {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  orgId           String    @map("org_id")
  vendorId        String    @map("vendor_id")
  poNumber        String    @map("po_number")
  status          String    @default("DRAFT") // DRAFT, SUBMITTED, APPROVED, PARTIALLY_RECEIVED, RECEIVED, CANCELLED
  orderDate       DateTime  @default(now()) @map("order_date")
  expectedDate    DateTime? @map("expected_date")
  subtotal        Decimal   @default(0) @db.Decimal(15, 2)
  taxAmount       Decimal   @default(0) @map("tax_amount") @db.Decimal(15, 2)
  discountAmount  Decimal   @default(0) @map("discount_amount") @db.Decimal(15, 2)
  totalAmount     Decimal   @default(0) @map("total_amount") @db.Decimal(15, 2)
  currency        String    @default("USD")
  shippingAddress Json?     @map("shipping_address")
  notes           String?
  internalNotes   String?   @map("internal_notes")
  approvedBy      String?   @map("approved_by")
  approvedAt      DateTime? @map("approved_at")
  createdBy       String?   @map("created_by")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  rfqId               String?             @map("rfq_id")
  supplierQuotationId String?             @map("supplier_quotation_id")

  vendor           Vendor              @relation(fields: [vendorId], references: [id])
  rfq              RFQ?                @relation(fields: [rfqId], references: [id])
  supplierQuotation SupplierQuotation?  @relation(fields: [supplierQuotationId], references: [id])
  lineItems        PurchaseOrderItem[]
  receipts         PurchaseReceipt[]
  debitNotes       DebitNote[]
  paymentSchedules PaymentSchedule[]

  @@unique([tenantId, orgId, poNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, vendorId])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String  @id @default(cuid())
  tenantId        String  @map("tenant_id")
  purchaseOrderId String  @map("purchase_order_id")
  productId       String? @map("product_id")
  description     String
  quantity        Decimal @db.Decimal(15, 3)
  receivedQty     Decimal @default(0) @map("received_qty") @db.Decimal(15, 3)
  unitPrice       Decimal @map("unit_price") @db.Decimal(15, 2)
  taxRate         Decimal @default(0) @map("tax_rate") @db.Decimal(5, 2)
  taxAmount       Decimal @default(0) @map("tax_amount") @db.Decimal(15, 2)
  totalAmount     Decimal @map("total_amount") @db.Decimal(15, 2)
  sortOrder       Int     @default(0) @map("sort_order")

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product?      @relation(fields: [productId], references: [id])

  @@index([tenantId])
  @@index([purchaseOrderId])
  @@map("purchase_order_items")
}

model PurchaseReceipt {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  purchaseOrderId String   @map("purchase_order_id")
  receiptNumber   String   @map("receipt_number")
  receivedDate    DateTime @default(now()) @map("received_date")
  warehouseId     String?  @map("warehouse_id")
  notes           String?
  createdBy       String?  @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at")

  purchaseOrder PurchaseOrder         @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  lineItems     PurchaseReceiptItem[]

  @@unique([tenantId, receiptNumber])
  @@index([tenantId])
  @@index([purchaseOrderId])
  @@map("purchase_receipts")
}

model PurchaseReceiptItem {
  id                String  @id @default(cuid())
  tenantId          String  @map("tenant_id")
  purchaseReceiptId String  @map("purchase_receipt_id")
  productId         String? @map("product_id")
  description       String
  receivedQty       Decimal @map("received_qty") @db.Decimal(15, 3)
  acceptedQty       Decimal @map("accepted_qty") @db.Decimal(15, 3)
  rejectedQty       Decimal @default(0) @map("rejected_qty") @db.Decimal(15, 3)

  purchaseReceipt PurchaseReceipt @relation(fields: [purchaseReceiptId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([purchaseReceiptId])
  @@map("purchase_receipt_items")
}

model RFQ {
  id           String    @id @default(cuid())
  tenantId     String    @map("tenant_id")
  orgId        String    @map("org_id")
  rfqNumber    String    @map("rfq_number")
  status       String    @default("DRAFT") // DRAFT, SENT, COMPLETED, CANCELLED
  expectedDate DateTime? @map("expected_date")
  notes        String?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  organization      Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  lineItems         RFQItem[]
  supplierQuotations SupplierQuotation[]
  purchaseOrders    PurchaseOrder[]

  @@unique([tenantId, orgId, rfqNumber])
  @@index([tenantId])
  @@map("rfqs")
}

model RFQItem {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  rfqId       String   @map("rfq_id")
  productId   String?  @map("product_id")
  description String
  quantity    Decimal  @db.Decimal(15, 3)

  rfq     RFQ      @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@index([tenantId])
  @@index([rfqId])
  @@map("rfq_items")
}

model SupplierQuotation {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  orgId           String    @map("org_id")
  rfqId           String?   @map("rfq_id")
  vendorId        String    @map("vendor_id")
  quotationNumber String    @map("quotation_number")
  status          String    @default("DRAFT") // DRAFT, SUBMITTED, APPROVED, REJECTED, EXPIRED, CONVERTED
  validUntil      DateTime  @map("valid_until")
  subtotal        Decimal   @default(0) @db.Decimal(15, 2)
  taxAmount       Decimal   @default(0) @map("tax_amount") @db.Decimal(15, 2)
  totalAmount     Decimal   @default(0) @map("total_amount") @db.Decimal(15, 2)
  currency        String    @default("USD")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  organization   Organization            @relation(fields: [orgId], references: [id], onDelete: Cascade)
  rfq            RFQ?                    @relation(fields: [rfqId], references: [id])
  vendor         Vendor                  @relation(fields: [vendorId], references: [id])
  lineItems      SupplierQuotationItem[]
  purchaseOrders PurchaseOrder[]

  @@unique([tenantId, orgId, quotationNumber])
  @@index([tenantId])
  @@index([rfqId])
  @@index([vendorId])
  @@map("supplier_quotations")
}

model SupplierQuotationItem {
  id                  String  @id @default(cuid())
  tenantId            String  @map("tenant_id")
  supplierQuotationId String  @map("supplier_quotation_id")
  productId           String? @map("product_id")
  description         String
  quantity            Decimal @db.Decimal(15, 3)
  unitPrice           Decimal @map("unit_price") @db.Decimal(15, 2)
  taxRate             Decimal @default(0) @map("tax_rate") @db.Decimal(5, 2)
  taxAmount           Decimal @default(0) @map("tax_amount") @db.Decimal(15, 2)
  totalAmount         Decimal @map("total_amount") @db.Decimal(15, 2)

  supplierQuotation SupplierQuotation @relation(fields: [supplierQuotationId], references: [id], onDelete: Cascade)
  product           Product?          @relation(fields: [productId], references: [id])

  @@index([tenantId])
  @@index([supplierQuotationId])
  @@map("supplier_quotation_items")
}

// ════════════════════════════════════════════════
// SALES MODULE (Phase 2)
// ════════════════════════════════════════════════

model Quotation {
  id                 String    @id @default(cuid())
  tenantId           String    @map("tenant_id")
  orgId              String    @map("org_id")
  customerId         String    @map("customer_id")
  quotationNumber    String    @map("quotation_number")
  status             String    @default("DRAFT") // DRAFT, SENT, ACCEPTED, REJECTED, EXPIRED, CONVERTED
  issueDate          DateTime  @default(now()) @map("issue_date")
  validUntil         DateTime  @map("valid_until")
  subtotal           Decimal   @default(0) @db.Decimal(15, 2)
  taxAmount          Decimal   @default(0) @map("tax_amount") @db.Decimal(15, 2)
  discountAmount     Decimal   @default(0) @map("discount_amount") @db.Decimal(15, 2)
  totalAmount        Decimal   @default(0) @map("total_amount") @db.Decimal(15, 2)
  currency           String    @default("USD")
  notes              String?
  termsConditions    String?   @map("terms_conditions")
  convertedToOrderId String?   @map("converted_to_order_id")
  createdBy          String?   @map("created_by")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")

  customer  Customer        @relation(fields: [customerId], references: [id])
  lineItems QuotationItem[]

  @@unique([tenantId, orgId, quotationNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, customerId])
  @@map("quotations")
}

model QuotationItem {
  id          String  @id @default(cuid())
  tenantId    String  @map("tenant_id")
  quotationId String  @map("quotation_id")
  productId   String? @map("product_id")
  description String
  quantity    Decimal @db.Decimal(15, 3)
  unitPrice   Decimal @map("unit_price") @db.Decimal(15, 2)
  taxRate     Decimal @default(0) @map("tax_rate") @db.Decimal(5, 2)
  taxAmount   Decimal @default(0) @map("tax_amount") @db.Decimal(15, 2)
  totalAmount Decimal @map("total_amount") @db.Decimal(15, 2)
  sortOrder   Int     @default(0) @map("sort_order")

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([quotationId])
  @@map("quotation_items")
}

model SalesOrder {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  orgId           String    @map("org_id")
  customerId      String    @map("customer_id")
  orderNumber     String    @map("order_number")
  status          String    @default("DRAFT") // DRAFT, CONFIRMED, PROCESSING, PARTIALLY_DELIVERED, DELIVERED, CANCELLED
  orderDate       DateTime  @default(now()) @map("order_date")
  deliveryDate    DateTime? @map("delivery_date")
  subtotal        Decimal   @default(0) @db.Decimal(15, 2)
  taxAmount       Decimal   @default(0) @map("tax_amount") @db.Decimal(15, 2)
  discountAmount  Decimal   @default(0) @map("discount_amount") @db.Decimal(15, 2)
  totalAmount     Decimal   @default(0) @map("total_amount") @db.Decimal(15, 2)
  currency        String    @default("USD")
  salesChannel    String    @default("B2B") @map("sales_channel")
  paymentMethod   String?   @map("payment_method")
  paymentStatus   String    @default("UNPAID") @map("payment_status")
  shippingAddress Json?     @map("shipping_address")
  notes           String?
  internalNotes   String?   @map("internal_notes")
  quotationId     String?   @map("quotation_id")
  invoiceId       String?   @map("invoice_id")
  createdBy       String?   @map("created_by")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  customer      Customer         @relation(fields: [customerId], references: [id])
  lineItems     SalesOrderItem[]
  deliveryNotes DeliveryNote[]

  @@unique([tenantId, orgId, orderNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, customerId])
  @@map("sales_orders")
}

model SalesOrderItem {
  id           String  @id @default(cuid())
  tenantId     String  @map("tenant_id")
  salesOrderId String  @map("sales_order_id")
  productId    String? @map("product_id")
  description  String
  quantity     Decimal @db.Decimal(15, 3)
  deliveredQty Decimal @default(0) @map("delivered_qty") @db.Decimal(15, 3)
  unitPrice    Decimal @map("unit_price") @db.Decimal(15, 2)
  taxRate      Decimal @default(0) @map("tax_rate") @db.Decimal(5, 2)
  taxAmount    Decimal @default(0) @map("tax_amount") @db.Decimal(15, 2)
  totalAmount  Decimal @map("total_amount") @db.Decimal(15, 2)
  sortOrder    Int     @default(0) @map("sort_order")

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  product    Product?   @relation(fields: [productId], references: [id])

  @@index([tenantId])
  @@index([salesOrderId])
  @@map("sales_order_items")
}

model DeliveryNote {
  id             String    @id @default(cuid())
  tenantId       String    @map("tenant_id")
  salesOrderId   String    @map("sales_order_id")
  deliveryNumber String    @map("delivery_number")
  status         String    @default("PENDING") // PENDING, IN_TRANSIT, DELIVERED, RETURNED
  deliveredDate  DateTime? @map("delivered_date")
  warehouseId    String?   @map("warehouse_id")
  carrierName    String?   @map("carrier_name")
  trackingNumber String?   @map("tracking_number")
  notes          String?
  createdBy      String?   @map("created_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  salesOrder SalesOrder         @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  lineItems  DeliveryNoteItem[]

  @@unique([tenantId, deliveryNumber])
  @@index([tenantId])
  @@index([salesOrderId])
  @@map("delivery_notes")
}

model DeliveryNoteItem {
  id             String  @id @default(cuid())
  tenantId       String  @map("tenant_id")
  deliveryNoteId String  @map("delivery_note_id")
  productId      String? @map("product_id")
  description    String
  deliveredQty   Decimal @map("delivered_qty") @db.Decimal(15, 3)

  deliveryNote DeliveryNote @relation(fields: [deliveryNoteId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([deliveryNoteId])
  @@map("delivery_note_items")
}

// ════════════════════════════════════════════════
// SUPPLY CHAIN MODULE (Phase 2)
// ════════════════════════════════════════════════

model Shipment {
  id                String    @id @default(cuid())
  tenantId          String    @map("tenant_id")
  orgId             String    @map("org_id")
  shipmentNumber    String    @map("shipment_number")
  type              String    @default("OUTBOUND") // INBOUND, OUTBOUND, TRANSFER
  status            String    @default("PENDING") // PENDING, PICKED_UP, IN_TRANSIT, DELIVERED, RETURNED, CANCELLED
  carrierName       String?   @map("carrier_name")
  trackingNumber    String?   @map("tracking_number")
  trackingUrl       String?   @map("tracking_url")
  originAddress     Json?     @map("origin_address")
  destAddress       Json?     @map("dest_address")
  weight            Decimal?  @db.Decimal(10, 2)
  weightUnit        String    @default("KG") @map("weight_unit")
  shippingCost      Decimal?  @map("shipping_cost") @db.Decimal(15, 2)
  currency          String    @default("USD")
  estimatedDelivery DateTime? @map("estimated_delivery")
  actualDelivery    DateTime? @map("actual_delivery")
  shippedAt         DateTime? @map("shipped_at")
  notes             String?
  createdBy         String?   @map("created_by")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@unique([tenantId, shipmentNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("shipments")
}

// ════════════════════════════════════════════════
// PROJECT MANAGEMENT MODULE (Phase 3)
// ════════════════════════════════════════════════

model Project {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenant_id")
  orgId       String    @map("org_id")
  name        String
  code        String
  description String?
  status      String    @default("PLANNED") // PLANNED, ACTIVE, ON_HOLD, COMPLETED, CANCELLED
  startDate   DateTime? @map("start_date")
  endDate     DateTime? @map("end_date")
  budget      Decimal?  @db.Decimal(15, 2)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  tasks          Task[]
  milestones     Milestone[]
  journalEntries JournalEntry[]
  budgets        Budget[]

  @@unique([tenantId, orgId, code])
  @@index([tenantId])
  @@map("projects")
}

model Task {
  id           String    @id @default(cuid())
  tenantId     String    @map("tenant_id")
  projectId    String    @map("project_id")
  name         String
  description  String?
  status       String    @default("BACKLOG") // BACKLOG, TODO, IN_PROGRESS, IN_REVIEW, DONE
  priority     String    @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  dueDate      DateTime? @map("due_date")
  assignedToId String?   @map("assigned_to_id")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  timesheets Timesheet[]

  @@index([tenantId])
  @@index([projectId])
  @@map("tasks")
}

model Timesheet {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  taskId     String   @map("task_id")
  employeeId String   @map("employee_id")
  date       DateTime
  hours      Decimal  @db.Decimal(4, 2)
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([taskId])
  @@map("timesheets")
}

model Milestone {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  projectId   String   @map("project_id")
  name        String
  dueDate     DateTime @map("due_date")
  isCompleted Boolean  @default(false) @map("is_completed")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([projectId])
  @@map("milestones")
}

// ════════════════════════════════════════════════
// MANUFACTURING MODULE (Phase 3)
// ════════════════════════════════════════════════

model BOM {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  productId String   @map("product_id")
  name      String
  code      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items      BOMItem[]
  workOrders WorkOrder[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("boms")
}

model BOMItem {
  id        String  @id @default(cuid())
  tenantId  String  @map("tenant_id")
  bomId     String  @map("bom_id")
  productId String  @map("product_id")
  quantity  Decimal @db.Decimal(15, 3)

  bom BOM @relation(fields: [bomId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([bomId])
  @@map("bom_items")
}

model WorkOrder {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  bomId           String    @map("bom_id")
  workOrderNumber String    @map("work_order_number")
  status          String    @default("DRAFT") // DRAFT, PLANNED, IN_PROGRESS, COMPLETED, CANCELLED
  quantity        Decimal   @db.Decimal(15, 3)
  startDate       DateTime? @map("start_date")
  endDate         DateTime? @map("end_date")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  bom BOM @relation(fields: [bomId], references: [id])

  @@unique([tenantId, workOrderNumber])
  @@index([tenantId])
  @@map("work_orders")
}

// ════════════════════════════════════════════════
// BUSINESS INTELLIGENCE (Phase 4)
// ════════════════════════════════════════════════

model Dashboard {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  orgId       String   @map("org_id")
  name        String
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  layout      Json     @default("[]")
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("dashboards")
}

model Report {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  orgId       String   @map("org_id")
  name        String
  description String?
  query       Json     @default("{}")
  type        String   @default("BUILDER") // BUILDER, SQL
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("reports")
}

model KPI {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  orgId       String   @map("org_id")
  name        String
  code        String
  value       String
  unit        String?
  trend       Json     @default("[]")
  lastUpdated DateTime @default(now()) @map("last_updated")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, orgId, code])
  @@index([tenantId])
  @@map("kpis")
}

// ════════════════════════════════════════════════
// DOCUMENT MANAGEMENT (Phase 4)
// ════════════════════════════════════════════════

model Folder {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  orgId     String   @map("org_id")
  name      String
  parentId  String?  @map("parent_id")
  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  parent    Folder?    @relation("FolderHierarchy", fields: [parentId], references: [id])
  children  Folder[]   @relation("FolderHierarchy")
  documents Document[]

  @@index([tenantId])
  @@map("folders")
}

model Document {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  orgId           String    @map("org_id")
  name            String
  folderId        String?   @map("folder_id")
  templateId      String?   @map("template_id")
  signatureStatus String    @default("NONE") @map("signature_status") // NONE, PENDING, SIGNED
  createdBy       String?   @map("created_by")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  folder     Folder?           @relation(fields: [folderId], references: [id])
  versions   DocumentVersion[]
  signatures Signature[]

  @@index([tenantId])
  @@map("documents")
}

model DocumentVersion {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  documentId    String   @map("document_id")
  versionNumber Int      @map("version_number")
  fileUrl       String   @map("file_url")
  fileSize      Int      @map("file_size")
  createdBy     String?  @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("document_versions")
}

model DocumentTemplate {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  orgId     String   @map("org_id")
  name      String
  content   String   @db.Text
  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("document_templates")
}

model Signature {
  id            String    @id @default(cuid())
  tenantId      String    @map("tenant_id")
  documentId    String    @map("document_id")
  signerEmail   String    @map("signer_email")
  status        String    @default("PENDING") // PENDING, SIGNED
  signedAt      DateTime? @map("signed_at")
  ipAddress     String?   @map("ip_address")
  signatureData String?   @map("signature_data") @db.Text

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("signatures")
}

// ════════════════════════════════════════════════
// COMMUNICATION (Phase 4)
// ════════════════════════════════════════════════

model Channel {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  orgId       String   @map("org_id")
  name        String
