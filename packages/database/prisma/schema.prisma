}

model LoadPlan {
  id              String          @id @default(cuid())
  tenantId        String          @map("tenant_id")
  planNumber      String          @map("plan_number")
  containerTypeId String          @map("container_type_id")
  shipmentRef     String?         @map("shipment_ref")
  originWarehouse String          @map("origin_warehouse")
  destAddress     String          @map("dest_address")
  plannedLoadDate DateTime?       @map("planned_load_date")
  status          LoadPlanStatus  @default(DRAFT)
  totalWeightKg   Decimal         @default(0) @map("total_weight_kg") @db.Decimal(12, 2)
  totalVolumeM3   Decimal         @default(0) @map("total_volume_m3") @db.Decimal(10, 3)
  utilizationPct  Decimal         @default(0) @map("utilization_pct") @db.Decimal(5, 2)
  optimizationNotes String?       @map("optimization_notes")
  createdBy       String          @map("created_by")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  containerType   ContainerType   @relation(fields: [containerTypeId], references: [id])
  pallets         LoadPlanPallet[]
  items           LoadPlanItem[]

  @@unique([tenantId, planNumber])
  @@index([tenantId])
  @@index([status])
  @@map("load_plans")
}

model LoadPlanPallet {
  id              String     @id @default(cuid())
  tenantId        String     @map("tenant_id")
  loadPlanId      String     @map("load_plan_id")
  palletTypeId    String     @map("pallet_type_id")
  palletSequence  Int        @map("pallet_sequence")
  positionX       Int?       @map("position_x")
  positionY       Int?       @map("position_y")
  positionZ       Int?       @map("position_z")
  grossWeightKg   Decimal    @default(0) @map("gross_weight_kg") @db.Decimal(10, 2)
  netWeightKg     Decimal    @default(0) @map("net_weight_kg") @db.Decimal(10, 2)
