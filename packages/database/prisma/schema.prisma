  @@index([tenantId])
  @@index([loadPlanId])
  @@map("load_plan_pallets")
}

model LoadPlanItem {
  id              String     @id @default(cuid())
  tenantId        String     @map("tenant_id")
  loadPlanId      String     @map("load_plan_id")
  productId       String     @map("product_id")
  quantity        Decimal    @db.Decimal(15, 4)
  uom             String     @default("UNIT")
  grossWeightKg   Decimal?   @map("gross_weight_kg") @db.Decimal(10, 2)
  volumeM3        Decimal?   @map("volume_m3") @db.Decimal(10, 4)
  palletSequence  Int?       @map("pallet_sequence")
  notes           String?

  loadPlan        LoadPlan   @relation(fields: [loadPlanId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([loadPlanId])
  @@map("load_plan_items")
}

model PackingPlan {
  id              String           @id @default(cuid())
  tenantId        String           @map("tenant_id")
