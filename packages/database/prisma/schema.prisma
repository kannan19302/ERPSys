  description                String
  merchant                   String?
  amount                     Decimal  @db.Decimal(15, 2)
  taxAmount                  Decimal  @default(0) @map("tax_amount") @db.Decimal(15, 2)
  receiptUrl                 String?  @map("receipt_url")
  expenseDate                DateTime @map("expense_date")
  billable                   Boolean  @default(false)
  isMileage                  Boolean  @default(false) @map("is_mileage")
  mileageDistance            Decimal? @map("mileage_distance") @db.Decimal(10, 2)
  mileageRateApplied         Decimal? @map("mileage_rate_applied") @db.Decimal(10, 4)
  isPerDiem                  Boolean  @default(false) @map("is_per_diem")
  perDiemDays                Decimal? @map("per_diem_days") @db.Decimal(6, 2)
  perDiemRateApplied         Decimal? @map("per_diem_rate_applied") @db.Decimal(10, 2)
  ocrRaw                     Json?    @map("ocr_raw")
  ocrConfidence              Float?   @map("ocr_confidence")
  policyViolation            Boolean  @default(false) @map("policy_violation")
  policyViolationReason      String?  @map("policy_violation_reason")
