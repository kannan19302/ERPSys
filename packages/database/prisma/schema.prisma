  totalEquity      Decimal  @default(0) @map("total_equity") @db.Decimal(15, 2)
  totalRevenue     Decimal  @default(0) @map("total_revenue") @db.Decimal(15, 2)
  totalExpenses    Decimal  @default(0) @map("total_expenses") @db.Decimal(15, 2)
