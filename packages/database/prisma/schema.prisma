  @@index([warehouseId])
  @@map("dock_doors")
}

model YardAppointment {
  id              String            @id @default(cuid())
  tenantId        String            @map("tenant_id")
  appointmentNumber String          @map("appointment_number")
  dockDoorId      String?           @map("dock_door_id")
  warehouseId     String            @map("warehouse_id")
