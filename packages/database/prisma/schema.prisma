// Period-end foreign-currency revaluation of open monetary balances (AR, AP, FX bank accounts).
// Produces unrealized FX gain/loss and posts an adjusting journal.
model CurrencyRevaluation {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  orgId         String   @map("org_id")
  runNumber     String   @map("run_number")
  asOfDate      DateTime @map("as_of_date")
  baseCurrency  String   @default("USD") @map("base_currency")
  status        String   @default("POSTED") // POSTED, REVERSED
  totalGain     Decimal  @default(0) @map("total_gain") @db.Decimal(15, 2)
  totalLoss     Decimal  @default(0) @map("total_loss") @db.Decimal(15, 2)
  netAdjustment Decimal  @default(0) @map("net_adjustment") @db.Decimal(15, 2)
  journalId     String?  @map("journal_id")
  lines         Json // [{ source, ref, currency, foreignAmount, bookRate, currentRate, bookValue, currentValue, delta }]
  createdBy     String?  @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, orgId, runNumber])
  @@index([tenantId])
  @@index([tenantId, asOfDate])
  @@map("currency_revaluations")
}

