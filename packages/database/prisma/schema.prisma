  warehouseId    String?   @map("warehouse_id")
  carrierName    String?   @map("carrier_name")
  trackingNumber String?   @map("tracking_number")
  notes          String?
  createdBy      String?   @map("created_by")
  createdAt      DateTime  @default(now()) @map("created_at")
