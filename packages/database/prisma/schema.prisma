  tenantId  String   @map("tenant_id")
  name      String
  type      String
  config    Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("third_party_connectors")
}

model CustomWidget {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  name      String
  tag       String   @unique
  source    String
  manifest  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("custom_widgets")
}

model GitConfig {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenant_id")
  repoUrl     String    @map("repo_url")
  branch      String    @default("main")
  accessToken String?   @map("access_token")
  status      String    @default("DISCONNECTED")
  lastSync    DateTime? @map("last_sync")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@unique([tenantId])
  @@map("builder_git_configs")
}

model NativeBuild {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  version     String
  platform    String
  status      String
  downloadUrl String?  @map("download_url")
  logSummary  String?  @map("log_summary")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("builder_native_builds")
}

// ════════════════════════════════════════════════
// CRM — CUSTOMER SERVICE CASES & SLA
// ════════════════════════════════════════════════

model Case {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  orgId           String    @map("org_id")
  caseNumber      String    @map("case_number")
  subject         String
  description     String?
  customerId      String?   @map("customer_id")
  contactId       String?   @map("contact_id")
  priority        String    @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  status          String    @default("OPEN") // OPEN, IN_PROGRESS, WAITING_ON_CUSTOMER, RESOLVED, CLOSED
  channel         String    @default("EMAIL") // EMAIL, PHONE, CHAT, WEB, API
  slaDeadline     DateTime? @map("sla_deadline")
  firstResponseAt DateTime? @map("first_response_at")
  resolvedAt      DateTime? @map("resolved_at")
  slaFirstResponseAt DateTime? @map("sla_first_response_at")
  slaResolveBy       DateTime? @map("sla_resolve_by")
  slaBreached        Boolean   @default(false) @map("sla_breached")
  assignedToId    String?   @map("assigned_to_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  organization Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  customer     Customer?     @relation(fields: [customerId], references: [id])
  contact      Contact?      @relation(fields: [contactId], references: [id])
  comments     CaseComment[]

  @@unique([tenantId, caseNumber])
  @@index([tenantId])
  @@index([customerId])
  @@index([status])
  @@map("crm_cases")
}

model CaseComment {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  caseId     String   @map("case_id")
  authorId   String?  @map("author_id")
  body       String
  isInternal Boolean  @default(false) @map("is_internal")
  createdAt  DateTime @default(now()) @map("created_at")

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([caseId])
  @@map("crm_case_comments")
}

// ════════════════════════════════════════════════
// PROCUREMENT — SUPPLIER PORTAL & E-AUCTION
// ════════════════════════════════════════════════

model VendorPortalUser {
  id           String    @id @default(cuid())
  tenantId     String    @map("tenant_id")
  vendorId     String    @map("vendor_id")
  email        String
  passwordHash String    @map("password_hash")
  status       String    @default("INVITED") // INVITED, ACTIVE, DISABLED
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([vendorId])
  @@map("vendor_portal_users")
}

model RFQAuctionBid {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  rfqId       String   @map("rfq_id")
  vendorId    String   @map("vendor_id")
  bidAmount   Decimal  @map("bid_amount") @db.Decimal(15, 2)
  notes       String?
  status      String   @default("SUBMITTED") // SUBMITTED, WINNING, REJECTED, WITHDRAWN
  submittedAt DateTime @default(now()) @map("submitted_at")

  rfq    RFQ    @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([rfqId])
  @@map("rfq_auction_bids")
}

// ════════════════════════════════════════════════
// POS — OMNICHANNEL INVENTORY SYNC
// ════════════════════════════════════════════════

model SalesChannel {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  orgId     String   @map("org_id")
  name      String
  type      String   @default("POS") // POS, ONLINE, MARKETPLACE
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization  Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  channelStocks ChannelInventory[]

  @@unique([tenantId, orgId, name])
  @@index([tenantId])
  @@map("sales_channels")
}

model ChannelInventory {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  channelId    String   @map("channel_id")
  productId    String   @map("product_id")
  allocatedQty Decimal  @default(0) @map("allocated_qty") @db.Decimal(15, 3)
  reservedQty  Decimal  @default(0) @map("reserved_qty") @db.Decimal(15, 3)
  updatedAt    DateTime @updatedAt @map("updated_at")

  channel SalesChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  product Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([tenantId, channelId, productId])
  @@index([tenantId])
  @@map("channel_inventory")
}

// ════════════════════════════════════════════════
// FINANCE — MULTI-BOOK ACCOUNTING (PARALLEL LEDGERS)
// ════════════════════════════════════════════════

model AccountingBook {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  orgId     String   @map("org_id")
  name      String
  standard  String   @default("LOCAL_GAAP") // LOCAL_GAAP, IFRS, TAX, MANAGEMENT
  isPrimary Boolean  @default(false) @map("is_primary")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  journals     Journal[]

  @@unique([tenantId, orgId, name])
  @@index([tenantId])
  @@map("accounting_books")
}

// ════════════════════════════════════════════════
// E-COMMERCE STOREFRONT MODULE (module #33)
// See .ai/ECOMMERCE_MODULE_REQUIREMENTS.md — public catalog/cart/checkout layer
// built on top of existing Product / SalesOrder / Invoice. No parallel product
// or order model: ProductListing is a thin publish/price-override layer over
// Product, and checkout writes a real SalesOrder (salesChannel = "ONLINE").
// ════════════════════════════════════════════════

model StorefrontConfig {
  id         String   @id @default(cuid())
  tenantId   String   @unique @map("tenant_id")
  storeName  String   @map("store_name")
  storeSlug  String   @unique @map("store_slug") // public URL routing: /store/[storeSlug]
  isEnabled  Boolean  @default(false) @map("is_enabled")
  currency   String   @default("USD")
  contactEmail String? @map("contact_email")
  logoUrl    String?  @map("logo_url")
  primaryColor String? @map("primary_color")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("storefront_configs")
}

model StorefrontCategory {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  name        String
  slug        String
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  listings ProductListing[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("storefront_categories")
}

model ProductListing {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  productId       String    @map("product_id")
  categoryId      String?   @map("category_id")
  isPublished     Boolean   @default(false) @map("is_published")
  displayName     String?   @map("display_name") // optional override of Product.name
  description     String?   // optional override of Product.description
  priceOverride   Decimal?  @map("price_override") @db.Decimal(15, 2) // null = use Product.sellPrice
  sortOrder       Int       @default(0) @map("sort_order")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  product  Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  category StorefrontCategory? @relation(fields: [categoryId], references: [id])
  cartItems CartItem[]

  @@unique([tenantId, productId])
  @@index([tenantId, isPublished])
  @@index([tenantId, categoryId])
  @@map("product_listings")
}

model Cart {
  id           String    @id @default(cuid())
  tenantId     String    @map("tenant_id")
  sessionToken String    @unique @map("session_token") // opaque random token, no customer auth
  status       String    @default("ACTIVE") @map("status") // ACTIVE, CONVERTED, ABANDONED
  currency     String    @default("USD")
  expiresAt    DateTime  @map("expires_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  items CartItem[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("carts")
}

model CartItem {
  id                  String   @id @default(cuid())
  tenantId            String   @map("tenant_id")
  cartId              String   @map("cart_id")
  productListingId    String   @map("product_listing_id")
  quantity            Int
  unitPriceSnapshot   Decimal  @map("unit_price_snapshot") @db.Decimal(15, 2) // captured at add-time
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  cart           Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productListing ProductListing @relation(fields: [productListingId], references: [id])

  @@index([tenantId])
  @@index([cartId])
  @@map("cart_items")
}

model StorefrontOrderPayment {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  salesOrderId    String   @map("sales_order_id")
  provider        String   @default("mock_gateway") // "mock_gateway" for MVP; real gateways are a drop-in swap
  providerIntentId String  @map("provider_intent_id")
  status          String   @default("PENDING") // PENDING, SUCCEEDED, FAILED, REFUNDED
  amount          Decimal  @db.Decimal(15, 2)
  currency        String   @default("USD")
  rawResponse     Json?    @map("raw_response") // whatever the gateway adapter returns, for reconciliation
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, salesOrderId])
  @@map("storefront_order_payments")
}

// ==========================================
// FIXED ASSETS MODULE
// ==========================================

model FixedAssetCategory {
  id                    String       @id @default(cuid())
  tenantId              String       @map("tenant_id")
  name                  String
  description           String?
  depreciationMethod    String       @default("STRAIGHT_LINE") // STRAIGHT_LINE, DOUBLE_DECLINING
  expectedLifeMonths    Int          @map("expected_life_months")
  depreciationRate      Decimal?     @map("depreciation_rate") @db.Decimal(5, 2)
  assetAccountId        String?      @map("asset_account_id")
  depreciationAccountId String?      @map("depreciation_account_id")
  expenseAccountId      String?      @map("expense_account_id")
  createdAt             DateTime     @default(now()) @map("created_at")
  updatedAt             DateTime     @updatedAt @map("updated_at")

  assets                FixedAsset[]
  tenant                Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("fixed_asset_categories")
}

model AssetTransferLog {
  id               String     @id @default(cuid())
  tenantId         String     @map("tenant_id")
  assetId          String     @map("asset_id")
  transferDate     DateTime   @map("transfer_date")
  fromLocationId   String?    @map("from_location_id")
  toLocationId     String?    @map("to_location_id")
  fromCustodianId  String?    @map("from_custodian_id")
  toCustodianId    String?    @map("to_custodian_id")
  reason           String?
  performedBy      String     @map("performed_by")
  createdAt        DateTime   @default(now()) @map("created_at")

  asset            FixedAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  tenant           Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([assetId])
  @@map("asset_transfer_logs")
}

model AssetMaintenanceLog {
  id                  String     @id @default(cuid())
  tenantId            String     @map("tenant_id")
  assetId             String     @map("asset_id")
  maintenanceDate     DateTime   @map("maintenance_date")
  type                String     @default("PREVENTIVE")
  description         String
  cost                Decimal    @db.Decimal(15, 2)
  performedBy         String     @map("performed_by")
  nextMaintenanceDate DateTime?  @map("next_maintenance_date")
  createdAt           DateTime   @default(now()) @map("created_at")

  asset            FixedAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  tenant           Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([assetId])
  @@map("asset_maintenance_logs")
}

// ════════════════════════════════════════════════
// CRM ADVANCED — LEAD SCORING, DUPLICATE DETECTION,
// CONFIGURABLE PIPELINES, SEGMENTATION, SLA POLICIES
// ════════════════════════════════════════════════

model LeadScoringRule {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  name      String
  field     String
  operator  String
  value     String
  points    Int
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId, active])
  @@map("crm_lead_scoring_rules")
}

model DuplicateRule {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  name        String
  entity      String // LEAD|CONTACT|ACCOUNT
  matchFields Json     @map("match_fields")
  threshold   Int
  action      String // BLOCK|WARN|MERGE
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([tenantId, entity, active])
  @@map("crm_duplicate_rules")
}

model PipelineStage {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  pipelineId  String   @map("pipeline_id")
  name        String
  order       Int
  probability Int
  isWon       Boolean  @default(false) @map("is_won")
  isLost      Boolean  @default(false) @map("is_lost")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  pipeline SalesPipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@index([tenantId, pipelineId])
  @@map("crm_pipeline_stages")
}

model Segment {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  name      String
  entity    String // CONTACT|LEAD|ACCOUNT
  criteria  Json
  isDynamic Boolean  @default(true) @map("is_dynamic")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members SegmentMember[]

  @@index([tenantId, entity])
  @@map("crm_segments")
}

model SegmentMember {
  id        String   @id @default(cuid())
  segmentId String   @map("segment_id")
  entityId  String   @map("entity_id")
  addedAt   DateTime @default(now()) @map("added_at")

  segment Segment @relation(fields: [segmentId], references: [id], onDelete: Cascade)

  @@unique([segmentId, entityId])
  @@index([segmentId])
  @@map("crm_segment_members")
}

model SlaPolicy {
  id                String   @id @default(cuid())
  tenantId          String   @map("tenant_id")
  name              String
  entity            String // CASE
  priority          String
  firstResponseMins Int      @map("first_response_mins")
  resolutionMins    Int      @map("resolution_mins")
  businessHoursId   String?  @map("business_hours_id")
  active            Boolean  @default(true)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([tenantId, entity, active])
  @@map("crm_sla_policies")
}

model SlaBreach {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  entity     String
  entityId   String   @map("entity_id")
  policyId   String   @map("policy_id")
  breachType String   @map("breach_type") // FIRST_RESPONSE|RESOLUTION
  breachedAt DateTime @map("breached_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([tenantId, entity, entityId])
  @@index([tenantId, policyId])
  @@map("crm_sla_breaches")
}

