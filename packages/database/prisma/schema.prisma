  status        String    @default("QUEUED")      // QUEUED | ASSIGNED | IN_PROGRESS | COMPLETE | CANCELLED | FAILED
  warehouseId   String    @map("warehouse_id")
  zoneId        String?   @map("zone_id")
  sourceLocation String?  @map("source_location")
  destLocation  String?   @map("dest_location")
  productId     String?   @map("product_id")
  qty           Decimal?  @db.Decimal(15, 4)
  uom           String?
