// ── Inventory Cycle 22: Stock Valuation Methods ──────────────────────────────

enum ValuationMethod {
  FIFO
  LIFO
  WEIGHTED_AVG
  STANDARD_COST
  ACTUAL_COST
}

enum ValuationStatus {
  ACTIVE
  SUPERSEDED
  REVALUED
}

model StockValuationPolicy {
  id              String          @id @default(cuid())
  tenantId        String          @map("tenant_id")
  productId       String?         @map("product_id")
  warehouseId     String?         @map("warehouse_id")
  method          ValuationMethod
  standardCost    Decimal?        @map("standard_cost") @db.Decimal(18, 6)
  currency        String          @default("USD")
  effectiveFrom   DateTime        @default(now()) @map("effective_from")
  effectiveTo     DateTime?       @map("effective_to")
  isActive        Boolean         @default(true) @map("is_active")
  notes           String?
  createdBy       String?         @map("created_by")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  @@unique([tenantId, productId, warehouseId])
  @@index([tenantId])
  @@index([tenantId, productId])
  @@map("stock_valuation_policies")
}

model StockValuationLedger {
  id              String          @id @default(cuid())
  tenantId        String          @map("tenant_id")
  productId       String          @map("product_id")
  warehouseId     String?         @map("warehouse_id")
  method          ValuationMethod
  transactionType String          @map("transaction_type") // RECEIPT|ISSUE|ADJUSTMENT|REVALUATION
  transactionRef  String          @map("transaction_ref")
  qty             Decimal         @db.Decimal(18, 4)
  unitCost        Decimal         @map("unit_cost") @db.Decimal(18, 6)
  totalCost       Decimal         @map("total_cost") @db.Decimal(18, 4)
  runningQty      Decimal         @map("running_qty") @db.Decimal(18, 4)
  runningValue    Decimal         @map("running_value") @db.Decimal(18, 4)
  runningAvgCost  Decimal?        @map("running_avg_cost") @db.Decimal(18, 6)
  status          ValuationStatus @default(ACTIVE)
  postedAt        DateTime        @default(now()) @map("posted_at")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([tenantId, productId])
  @@index([tenantId, productId, warehouseId])
  @@index([transactionRef])
  @@map("stock_valuation_ledger")
}

model CostAdjustment {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
