enum DockDoorType {
  INBOUND
  OUTBOUND
  DUAL
}

enum DockDoorStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
  CLOSED
}

enum AppointmentStatus {
  SCHEDULED
  CHECKED_IN
  LOADING
  COMPLETE
  NO_SHOW
  CANCELLED
}

enum YardMoveStatus {
  PENDING
  IN_PROGRESS
  COMPLETE
  CANCELLED
}

model DockDoor {
