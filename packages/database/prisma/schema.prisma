  @@unique([tenantId, orgId, code])
  @@index([tenantId])
  @@map("kpis")
}

// ════════════════════════════════════════════════
// DOCUMENT MANAGEMENT (Phase 4)
// ════════════════════════════════════════════════

model Folder {
  id        String    @id @default(cuid())
  tenantId  String    @map("tenant_id")
  orgId     String    @map("org_id")
  name      String
  parentId  String?   @map("parent_id")
  createdBy String?   @map("created_by")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  starred   Boolean   @default(false) @map("starred")
  legalHold Boolean   @default(false) @map("legal_hold")

  parent    Folder?       @relation("FolderHierarchy", fields: [parentId], references: [id])
  children  Folder[]      @relation("FolderHierarchy")
  documents Document[]
  shares    FolderShare[]

  @@index([tenantId])
  @@map("folders")
}

model Document {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  orgId           String    @map("org_id")
  name            String
  folderId        String?   @map("folder_id")
  templateId      String?   @map("template_id")
  signatureStatus String    @default("NONE") @map("signature_status") // NONE, PENDING, SIGNED
  createdBy       String?   @map("created_by")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")
  starred         Boolean   @default(false) @map("starred")
  legalHold       Boolean   @default(false) @map("legal_hold")

  folder     Folder?           @relation(fields: [folderId], references: [id])
  versions   DocumentVersion[]
  signatures Signature[]
  shares     DocumentShare[]

  @@index([tenantId])
  @@map("documents")
}

model DocumentVersion {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  documentId    String   @map("document_id")
  versionNumber Int      @map("version_number")
  fileUrl       String   @map("file_url")
  fileSize      Int      @map("file_size")
  createdBy     String?  @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")
  iv            String?  @map("iv")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("document_versions")
}

model FolderShare {
  id        String    @id @default(cuid())
  tenantId  String    @map("tenant_id")
  folderId  String    @map("folder_id")
  userId    String    @map("user_id")
  role      String    @default("VIEWER") // VIEWER, EDITOR
  password  String?   @map("password_hash")
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")

  folder Folder @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@map("folder_shares")
}

model DocumentShare {
  id         String    @id @default(cuid())
  tenantId   String    @map("tenant_id")
  documentId String    @map("document_id")
  userId     String    @map("user_id")
  role       String    @default("VIEWER") // VIEWER, EDITOR
  password   String?   @map("password_hash")
  expiresAt  DateTime? @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@map("document_shares")
}

model DocumentTemplate {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  orgId     String   @map("org_id")
  name      String
  content   String   @db.Text
  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("document_templates")
}

model Signature {
  id            String    @id @default(cuid())
  tenantId      String    @map("tenant_id")
  documentId    String    @map("document_id")
  signerEmail   String    @map("signer_email")
  status        String    @default("PENDING") // PENDING, SIGNED
  signedAt      DateTime? @map("signed_at")
  ipAddress     String?   @map("ip_address")
  signatureData String?   @map("signature_data") @db.Text

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("signatures")
}

// ════════════════════════════════════════════════
// COMMUNICATION (Phase 4)
// ════════════════════════════════════════════════

model Channel {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  orgId       String   @map("org_id")
  name        String
  description String?
  type        String   @default("PUBLIC") // PUBLIC, PRIVATE
  kind        String   @default("CHANNEL") // CHANNEL, DM, GROUP
  spaceId     String?  @map("space_id")
  topic       String?
  archived    Boolean  @default(false) @map("archived")
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  messages    Message[]
  members     ChannelMember[]
  space       ConnectSpace?   @relation(fields: [spaceId], references: [id])
  tabs        ChannelTab[]
  moderation  ChannelModeration?
  bots        ConnectBot[]
  analytics   ChannelAnalytics[]
  forwardsFrom MessageForward[] @relation("ForwardFromChannel")
  forwardsTo   MessageForward[] @relation("ForwardToChannel")
  polls        ConnectPoll[]

  @@index([tenantId])
  @@index([tenantId, spaceId])
  @@map("channels")
}

/// Search: `content` is covered by a `pg_trgm` GIN index (idx_messages_content_trgm) created
/// via raw SQL in migration 20260702120000_connect_roles_notify_search — not modeled here because
/// Prisma has no native index-ops syntax without the `postgresqlExtensions` preview feature.
/// Do not drop/recreate this index via `prisma migrate dev` schema diffing.
model Message {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenant_id")
  channelId   String    @map("channel_id")
  userId      String    @map("user_id")
  content     String    @db.Text
  kind        String    @default("USER") // USER, SYSTEM
  parentId    String?   @map("parent_id")
  pinned      Boolean   @default(false)
  attachments Json      @default("[]")
  meetingId   String?   @map("meeting_id")
  editedAt    DateTime? @map("edited_at")
  deletedAt   DateTime? @map("deleted_at")
  scheduledAt DateTime? @map("scheduled_at")
  expiresAt   DateTime? @map("expires_at")
  viewOnce    Boolean   @default(false) @map("view_once")
  pollId      String?   @map("poll_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  bookmarks MessageBookmark[]
  edits     MessageEdit[]
  forwards  MessageForward[]
  poll      ConnectPoll?          @relation(fields: [pollId], references: [id], onDelete: SetNull)

  channel   Channel           @relation(fields: [channelId], references: [id], onDelete: Cascade)
  parent    Message?          @relation("MessageThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Message[]         @relation("MessageThread")
  reactions MessageReaction[]

  @@index([tenantId])
  @@index([channelId, parentId])
  @@index([tenantId, deletedAt])
  @@index([scheduledAt])
  @@map("messages")
}

model ConnectSpace {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  orgId     String   @map("org_id")
  name      String
  emoji     String   @default("#")
  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  channels Channel[]

  @@index([tenantId])
  @@map("connect_spaces")
}

model ChannelMember {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  channelId   String   @map("channel_id")
  userId      String   @map("user_id")
  starred     Boolean  @default(false)
  muted       Boolean  @default(false)
  role        String   @default("MEMBER") // OWNER, ADMIN, MEMBER — see ChannelMemberRole in @unerp/shared
  notifyLevel String   @default("ALL") @map("notify_level") // ALL, MENTIONS, NONE
  createdAt   DateTime @default(now()) @map("created_at")

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([tenantId, userId])
  @@index([channelId, role])
  @@map("channel_members")
}

model ChannelRead {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  channelId  String   @map("channel_id")
  userId     String   @map("user_id")
  lastReadAt DateTime @default(now()) @map("last_read_at")

  @@unique([channelId, userId])
  @@index([tenantId, userId])
  @@map("channel_reads")
}

model MessageReaction {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  messageId String   @map("message_id")
  userId    String   @map("user_id")
  emoji     String
  createdAt DateTime @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@map("message_reactions")
}

model MessageBookmark {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  messageId String   @map("message_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([tenantId, userId])
  @@map("message_bookmarks")
}

model UserPresence {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenant_id")
  userId      String    @map("user_id")
  presence    String    @default("ACTIVE") // ACTIVE, AWAY, BRB, DND, OOO, INACTIVE, IN_MEETING, FOCUSING
  visibility  String    @default("EVERYONE") @map("visibility") // EVERYONE, ORG_ONLY, NOBODY (appear offline to others)
  statusText  String?   @map("status_text")
  statusEmoji String?   @map("status_emoji")
  clearAt     DateTime? @map("clear_at")  // auto-clear status after this time
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@map("user_presence")
}

/** A device registered to receive MFA push-approval notifications (Web Push). */
model PushSubscription {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  userId    String   @map("user_id")
  endpoint  String   @unique
  p256dh    String
  auth      String
  label     String?  // e.g. "Chrome on Windows" — set from the User-Agent at subscribe time
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId, userId])
  @@map("push_subscriptions")
}

/** One MFA login's push-approval round trip, polled by the login page until resolved. */
model MfaPushChallenge {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  userId    String   @map("user_id")
  token     String   @unique // hash of the MFA challenge JWT, ties this row to one login attempt
  status    String   @default("PENDING") // PENDING, APPROVED, DENIED, EXPIRED
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  @@index([tenantId, userId])
  @@map("mfa_push_challenges")
}

model ConnectMeeting {
  id        String    @id @default(cuid())
  tenantId  String    @map("tenant_id")
  channelId String?   @map("channel_id")
  code      String
  title     String
  hostId    String    @map("host_id")
  active    Boolean   @default(true)
  lobby     Boolean   @default(false) @map("lobby")
  startedAt DateTime  @default(now()) @map("started_at")
  endedAt   DateTime? @map("ended_at")

  participants MeetingParticipant[]
  chatMessages MeetingChatMessage[]
  recordings   MeetingRecording[]
  summaries    MeetingSummary[]

  @@index([tenantId])
  @@map("connect_meetings")
}

model CalendarEvent {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  title        String
  date         String // YYYY-MM-DD
  time         String // HH:MM
  durationMins Int      @default(30) @map("duration_mins")
  meetingCode  String?  @map("meeting_code")
  attendees    Json     @default("[]")
  description  String?  @db.Text
  location     String?
  color        String?
  allDay       Boolean  @default(false) @map("all_day")
  recurrence   String   @default("none") // none, daily, weekly, biweekly, monthly, yearly
  createdBy    String   @map("created_by")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@map("calendar_events")
}

model Notification {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  userId    String   @map("user_id")
  title     String
  content   String   @db.Text
  type      String   @default("SYSTEM") // SYSTEM, WORKFLOW, CHAT
  status    String   @default("UNREAD") // UNREAD, READ, ARCHIVED
  link      String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId, userId])
  @@map("notifications")
}

// ════════════════════════════════════════════════
// CONNECT PHASE 2 (Communication Deepening) — Teams-grade Collaboration
// Added 2026-07-17: threading, tabs, moderation, bots, meetings, presence scheduling, edit history
// ════════════════════════════════════════════════

/// Tabs pinned to a channel header (links, documents, integrations)
model ChannelTab {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  channelId String   @map("channel_id")
  type      String   @default("LINK") // LINK, DOCUMENT, ERP_ENTITY, CUSTOM
  label     String
  icon      String?  @default("Link")
  url       String?  @map("url")
  entityType String? @map("entity_type")
  entityId   String? @map("entity_id")
  sortOrder Int      @default(0) @map("sort_order")
  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([tenantId, channelId])
  @@map("channel_tabs")
}

/// Edit history log for messages (audit trail)
model MessageEdit {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  messageId String   @map("message_id")
  userId    String   @map("user_id")
  previousContent String @map("previous_content") @db.Text
  newContent      String @map("new_content") @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([tenantId, messageId])
  @@map("message_edits")
}

/// Forward/share record for messages
model MessageForward {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  messageId     String   @map("message_id")
  fromChannelId String   @map("from_channel_id")
  toChannelId   String   @map("to_channel_id")
  forwardedBy   String   @map("forwarded_by")
  comment       String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at")

  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  fromChannel Channel @relation("ForwardFromChannel", fields: [fromChannelId], references: [id])
  toChannel   Channel @relation("ForwardToChannel", fields: [toChannelId], references: [id])

  @@index([tenantId, toChannelId])
  @@map("message_forwards")
}

/// Channel moderation settings
model ChannelModeration {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  channelId     String   @unique @map("channel_id")
  slowModeSecs  Int      @default(0) @map("slow_mode_secs") // 0 = disabled, 30, 60, 300, 900, 3600
  whoCanPost    String   @default("EVERYONE") @map("who_can_post") // EVERYONE, ADMINS_ONLY, MODERATORS_ONLY
  onlyAdminsCanPin Boolean @default(false) @map("only_admins_can_pin")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("channel_moderation")
}

/// Meeting participant tracking
model MeetingParticipant {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  meetingId       String   @map("meeting_id")
  userId          String   @map("user_id")
  joinedAt        DateTime @default(now()) @map("joined_at")
  leftAt          DateTime? @map("left_at")
  isHandRaised    Boolean  @default(false) @map("is_hand_raised")
  isScreenSharing Boolean  @default(false) @map("is_screen_sharing")
  isMuted         Boolean  @default(true) @map("is_muted")
  isVideoOn       Boolean  @default(false) @map("is_video_on")

  meeting ConnectMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@unique([meetingId, userId])
  @@index([tenantId, meetingId])
  @@map("meeting_participants")
}

/// In-meeting chat messages
model MeetingChatMessage {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  meetingId String   @map("meeting_id")
  userId    String   @map("user_id")
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  meeting ConnectMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([tenantId, meetingId])
  @@map("meeting_chat_messages")
}

/// Meeting recording metadata
model MeetingRecording {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  meetingId     String   @map("meeting_id")
  startedAt     DateTime @default(now()) @map("started_at")
  endedAt       DateTime? @map("ended_at")
  fileUrl       String?  @map("file_url")
  fileSize      Int?     @map("file_size")
  durationSecs  Int?     @map("duration_secs")
  status        String   @default("RECORDING") // RECORDING, COMPLETED, FAILED, PROCESSING
  startedBy     String   @map("started_by")

  meeting ConnectMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([tenantId, meetingId])
  @@map("meeting_recordings")
}

/// Bot/webhook integrations for channels
model ConnectBot {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  channelId   String   @map("channel_id")
  name        String
  avatar      String?  @default("🤖")
  webhookUrl  String?  @unique @map("webhook_url")
  token       String?  @map("token")
  isActive    Boolean  @default(true) @map("is_active")
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([tenantId, channelId])
  @@map("connect_bots")
}

/// Scheduled presence/status changes
model UserStatusSchedule {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  userId       String   @map("user_id")
  presence     String   // ACTIVE, AWAY, DND, OOO, etc.
  statusText   String?  @map("status_text")
  statusEmoji  String?  @map("status_emoji")
  startTime    DateTime @map("start_time")
  endTime      DateTime @map("end_time")
  isRecurring  Boolean  @default(false) @map("is_recurring")
  recurrenceRule String? @map("recurrence_rule")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([tenantId, userId])
  @@index([tenantId, startTime, endTime])
  @@map("user_status_schedules")
}

/// Daily channel activity snapshots for analytics
model ChannelAnalytics {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  channelId    String   @map("channel_id")
  date         DateTime @map("date")
  messageCount Int      @default(0) @map("message_count")
  activeUsers  Int      @default(0) @map("active_users")
  reactions    Int      @default(0)
  threads      Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([tenantId, channelId, date])
  @@index([tenantId, channelId])
  @@map("channel_analytics")
}

// ════════════════════════════════════════════════
// CONNECT EXTENSIONS (Phase 2+ Enhancements)
// ════════════════════════════════════════════════

/// Message polls with multiple choice
model ConnectPoll {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  channelId String   @map("channel_id")
  messageId String?  @map("message_id")
  userId    String   @map("user_id")
  question  String   @db.Text
  isClosed  Boolean  @default(false) @map("is_closed")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  options  ConnectPollOption[]
  messages Message[]
  votes    ConnectPollVote[]

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([tenantId, channelId])
  @@map("connect_polls")
}

model ConnectPollOption {
  id     String @id @default(cuid())
  pollId String @map("poll_id")
  label  String
  emoji  String @default("")

  poll   ConnectPoll         @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes  ConnectPollVote[]

  @@map("connect_poll_options")
}

model ConnectPollVote {
  id       String   @id @default(cuid())
  tenantId String   @map("tenant_id")
  pollId   String   @map("poll_id")
  optionId String   @map("option_id")
  userId   String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  option ConnectPollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  poll   ConnectPoll       @relation(fields: [pollId], references: [id], onDelete: Cascade)

  @@unique([pollId, userId])
  @@index([tenantId, pollId])
  @@map("connect_poll_votes")
}

/// Custom emoji uploads for the tenant
model CustomEmoji {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  name      String   @map("name")
  fileUrl   String   @map("file_url")
  fileSize  Int      @default(0) @map("file_size")
  uploadedBy String  @map("uploaded_by")
  category  String   @default("custom")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("custom_emojis")
}

/// User reminders (scheduled notifications)
model Reminder {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  userId    String   @map("user_id")
  text      String   @db.Text
  remindAt  DateTime @map("remind_at")
  channelId String?  @map("channel_id")
  messageId String?  @map("message_id")
  isSent    Boolean  @default(false) @map("is_sent")
  snoozed   Boolean  @default(false)
  recurRule String?  @map("recur_rule")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId, userId, remindAt])
  @@index([remindAt, isSent])
  @@map("reminders")
}

/// Channel creation templates
model ChannelTemplate {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  name        String
  description String?  @db.Text
  channelType String   @default("PUBLIC") @map("channel_type")
  topic       String?
  emoji       String   @default("")
  tabs        Json     @default("[]")
  isPreset    Boolean  @default(true) @map("is_preset")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@map("channel_templates")
}

/// Meeting summaries (AI-generated)
model MeetingSummary {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  meetingId      String   @map("meeting_id")
  summary        String   @db.Text
  keyPoints      Json     @default("[]") @map("key_points")
  actionItems    Json     @default("[]") @map("action_items")
  generatedAt    DateTime @default(now()) @map("generated_at")

  meeting ConnectMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([tenantId, meetingId])
  @@map("meeting_summaries")
}

// ════════════════════════════════════════════════
// POS & RETAIL (Phase 5) — Full Market-Ready Build
// ════════════════════════════════════════════════

model POSTerminal {
  id                 String   @id @default(cuid())
  tenantId           String   @map("tenant_id")
  orgId              String   @map("org_id")
  name               String
  code               String
  warehouseId        String?  @map("warehouse_id")
  status             String   @default("ACTIVE") // ACTIVE, INACTIVE, MAINTENANCE
  receiptTemplate    String?  @map("receipt_template") @db.Text
  layoutFormat       String?  @map("layout_format") // THERMAL_80MM, THERMAL_58MM, A4_INVOICE
  diagnosticData     Json?    @map("diagnostic_data")
  currency           String   @default("USD")
  taxProfileId       String?  @map("tax_profile_id")
  priceListId        String?  @map("price_list_id")
  defaultCustomerId  String?  @map("default_customer_id")
  allowDiscount      Boolean  @default(true) @map("allow_discount")
  maxDiscountPercent Decimal  @default(100) @map("max_discount_percent") @db.Decimal(5, 2)
  enableTipping      Boolean  @default(false) @map("enable_tipping")
  posProfile         Json     @default("{}") @map("pos_profile") // JSON config blob
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  registers  POSRegister[]
  quickKeys  POSQuickKey[]
  taxProfile POSTaxProfile? @relation(fields: [taxProfileId], references: [id])
  priceList  POSPriceList?  @relation(fields: [priceListId], references: [id])
  orders     POSOrder[]

  @@unique([tenantId, orgId, code])
  @@index([tenantId])
  @@map("pos_terminals")
}

model POSRegister {
  id                String    @id @default(cuid())
  tenantId          String    @map("tenant_id")
  terminalId        String    @map("terminal_id")
  openedById        String    @map("opened_by_id")
  openedAt          DateTime  @default(now()) @map("opened_at")
  closedAt          DateTime? @map("closed_at")
  startingCash      Decimal   @map("starting_cash") @db.Decimal(15, 2)
  endingCash        Decimal?  @map("ending_cash") @db.Decimal(15, 2)
  actualCash        Decimal?  @map("actual_cash") @db.Decimal(15, 2)
  closingDifference Decimal?  @map("closing_difference") @db.Decimal(15, 2)
  totalSales        Decimal   @default(0) @map("total_sales") @db.Decimal(15, 2)
  totalReturns      Decimal   @default(0) @map("total_returns") @db.Decimal(15, 2)
  totalTransactions Int       @default(0) @map("total_transactions")
  status            String    @default("OPEN") // OPEN, CLOSED
  notes             String?
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  terminal    POSTerminal @relation(fields: [terminalId], references: [id])
  shifts      POSShift[]
  cashEntries CashEntry[]
  orders      POSOrder[]

  @@index([tenantId])
  @@map("pos_registers")
}

model POSShift {
  id           String    @id @default(cuid())
  tenantId     String    @map("tenant_id")
  registerId   String    @map("register_id")
  employeeId   String    @map("employee_id")
  startTime    DateTime  @default(now()) @map("start_time")
  endTime      DateTime? @map("end_time")
  totalSales   Decimal   @default(0) @map("total_sales") @db.Decimal(15, 2)
  totalReturns Decimal   @default(0) @map("total_returns") @db.Decimal(15, 2)
  cashIn       Decimal   @default(0) @map("cash_in") @db.Decimal(15, 2)
  cashOut      Decimal   @default(0) @map("cash_out") @db.Decimal(15, 2)
  notes        String?
  status       String    @default("OPEN") // OPEN, CLOSED

  register POSRegister @relation(fields: [registerId], references: [id], onDelete: Cascade)
  orders   POSOrder[]

  @@index([tenantId])
  @@map("pos_shifts")
}

model CashEntry {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  registerId String   @map("register_id")
  type       String   @default("IN") // IN, OUT
  amount     Decimal  @db.Decimal(15, 2)
  reason     String?
  createdBy  String?  @map("created_by")
  createdAt  DateTime @default(now()) @map("created_at")

  register POSRegister @relation(fields: [registerId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("cash_entries")
}

// ── POS Orders (Core Transaction) ──────────────────

model POSOrder {
  id                  String   @id @default(cuid())
  tenantId            String   @map("tenant_id")
  orgId               String   @map("org_id")
  orderNumber         String   @map("order_number")
  type                String   @default("SALE") // SALE, RETURN, EXCHANGE
  status              String   @default("COMPLETED") // DRAFT, COMPLETED, VOIDED, HELD, PARTIAL_RETURN
  customerId          String?  @map("customer_id")
  customerName        String?  @map("customer_name")
  terminalId          String   @map("terminal_id")
  registerId          String?  @map("register_id")
  shiftId             String?  @map("shift_id")
  cashierId           String   @map("cashier_id")
  cashierName         String?  @map("cashier_name")
  subtotal            Decimal  @default(0) @db.Decimal(15, 2)
  discountType        String?  @map("discount_type") // PERCENTAGE, FIXED
  discountValue       Decimal  @default(0) @map("discount_value") @db.Decimal(15, 2)
  discountAmount      Decimal  @default(0) @map("discount_amount") @db.Decimal(15, 2)
  taxAmount           Decimal  @default(0) @map("tax_amount") @db.Decimal(15, 2)
  roundingAmount      Decimal  @default(0) @map("rounding_amount") @db.Decimal(15, 2)
  grandTotal          Decimal  @default(0) @map("grand_total") @db.Decimal(15, 2)
  paidAmount          Decimal  @default(0) @map("paid_amount") @db.Decimal(15, 2)
  changeAmount        Decimal  @default(0) @map("change_amount") @db.Decimal(15, 2)
  tipAmount           Decimal  @default(0) @map("tip_amount") @db.Decimal(15, 2)
  loyaltyPointsEarned Int      @default(0) @map("loyalty_points_earned")
  loyaltyPointsUsed   Int      @default(0) @map("loyalty_points_used")
  couponCode          String?  @map("coupon_code")
  notes               String?
  receiptData         Json?    @map("receipt_data") // snapshot of receipt at time of sale
  originalOrderId     String?  @map("original_order_id") // for returns
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  terminal POSTerminal    @relation(fields: [terminalId], references: [id])
  register POSRegister?   @relation(fields: [registerId], references: [id])
  shift    POSShift?      @relation(fields: [shiftId], references: [id])
  items    POSOrderItem[]
  payments POSPayment[]
  returns  POSReturn[]

  @@unique([tenantId, orgId, orderNumber])
  @@index([tenantId])
  @@index([tenantId, terminalId])
  @@index([tenantId, customerId])
  @@index([tenantId, createdAt])
  @@map("pos_orders")
}

model POSOrderItem {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  orderId         String   @map("order_id")
  productId       String?  @map("product_id")
  productName     String   @map("product_name")
  sku             String   @default("")
  barcode         String?
  qty             Decimal  @db.Decimal(15, 3)
  unitPrice       Decimal  @map("unit_price") @db.Decimal(15, 2)
  discountType    String?  @map("discount_type") // PERCENTAGE, FIXED
  discountPercent Decimal  @default(0) @map("discount_percent") @db.Decimal(5, 2)
  discountAmount  Decimal  @default(0) @map("discount_amount") @db.Decimal(15, 2)
  taxRate         Decimal  @default(0) @map("tax_rate") @db.Decimal(5, 2)
  taxAmount       Decimal  @default(0) @map("tax_amount") @db.Decimal(15, 2)
  lineTotal       Decimal  @map("line_total") @db.Decimal(15, 2)
  serialNumberId  String?  @map("serial_number_id")
  batchId         String?  @map("batch_id")
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")

  order POSOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([orderId])
  @@map("pos_order_items")
}

model POSPayment {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  orderId    String   @map("order_id")
  method     String // CASH, CARD, WALLET, GIFT_CARD, STORE_CREDIT, CHECK, CUSTOM
  amount     Decimal  @db.Decimal(15, 2)
  reference  String? // transaction ID, auth code, etc.
  cardLast4  String?  @map("card_last_4")
  authCode   String?  @map("auth_code")
  giftCardId String?  @map("gift_card_id")
  status     String   @default("COMPLETED") // COMPLETED, PENDING, FAILED, REFUNDED
  createdAt  DateTime @default(now()) @map("created_at")

  order    POSOrder     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  giftCard POSGiftCard? @relation(fields: [giftCardId], references: [id])

  @@index([tenantId])
  @@index([orderId])
  @@map("pos_payments")
}

// ── Discounts & Coupons ─────────────────────────────

model POSDiscount {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenant_id")
  orgId       String    @map("org_id")
  name        String
  description String?
  type        String // PERCENTAGE, FIXED, BOGO, BUNDLE
  value       Decimal   @db.Decimal(15, 2)
  appliesTo   String    @default("ORDER") @map("applies_to") // ORDER, ITEM, CATEGORY
  categoryId  String?   @map("category_id")
  productId   String?   @map("product_id")
  minPurchase Decimal?  @map("min_purchase") @db.Decimal(15, 2)
  maxDiscount Decimal?  @map("max_discount") @db.Decimal(15, 2)
  validFrom   DateTime? @map("valid_from")
  validTo     DateTime? @map("valid_to")
  usageLimit  Int?      @map("usage_limit")
  usageCount  Int       @default(0) @map("usage_count")
  status      String    @default("ACTIVE") // ACTIVE, INACTIVE, EXPIRED
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  coupons POSCoupon[]

  @@index([tenantId])
  @@map("pos_discounts")
}

model POSCoupon {
  id         String    @id @default(cuid())
  tenantId   String    @map("tenant_id")
  code       String
  discountId String    @map("discount_id")
  maxUses    Int?      @map("max_uses")
  usedCount  Int       @default(0) @map("used_count")
  validFrom  DateTime? @map("valid_from")
  validTo    DateTime? @map("valid_to")
  status     String    @default("ACTIVE") // ACTIVE, INACTIVE, EXHAUSTED
  createdAt  DateTime  @default(now()) @map("created_at")

  discount POSDiscount @relation(fields: [discountId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("pos_coupons")
}

// ── Tax Profiles ────────────────────────────────────

model POSTaxProfile {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  orgId       String   @map("org_id")
  name        String
  rates       Json     @default("[]") // [{name, rate, appliesTo}]
  isDefault   Boolean  @default(false) @map("is_default")
  isInclusive Boolean  @default(false) @map("is_inclusive") // tax included in price
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  terminals POSTerminal[]

  @@index([tenantId])
  @@map("pos_tax_profiles")
}

// ── Quick Keys ──────────────────────────────────────

model POSQuickKey {
  id            String  @id @default(cuid())
  tenantId      String  @map("tenant_id")
  terminalId    String  @map("terminal_id")
  productId     String? @map("product_id")
  label         String
  color         String  @default("#6366f1")
  position      Int     @default(0)
  categoryGroup String? @map("category_group")

  terminal POSTerminal @relation(fields: [terminalId], references: [id], onDelete: Cascade)

  @@index([tenantId, terminalId])
  @@map("pos_quick_keys")
}

// ── Loyalty Program ─────────────────────────────────

model POSLoyaltyProgram {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  orgId           String   @map("org_id")
  name            String
  description     String?
  pointsPerUnit   Decimal  @default(1) @map("points_per_unit") @db.Decimal(10, 4) // points earned per $1
  redeemRate      Decimal  @default(100) @map("redeem_rate") @db.Decimal(10, 4) // points needed per $1
  minRedeemPoints Int      @default(100) @map("min_redeem_points")
  expiryDays      Int?     @map("expiry_days") // points expire after N days
  tiers           Json     @default("[]") // [{name,minPoints,multiplier,benefits}]
  status          String   @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  customers    POSLoyaltyMember[]
  transactions POSLoyaltyTransaction[]

  @@index([tenantId])
  @@map("pos_loyalty_programs")
}

model POSLoyaltyMember {
  id             String    @id @default(cuid())
  tenantId       String    @map("tenant_id")
  programId      String    @map("program_id")
  customerId     String?   @map("customer_id")
  name           String
  email          String?
  phone          String?
  points         Int       @default(0)
  lifetimePoints Int       @default(0) @map("lifetime_points")
  lifetimeSpent  Decimal   @default(0) @map("lifetime_spent") @db.Decimal(15, 2)
  visitCount     Int       @default(0) @map("visit_count")
  tier           String    @default("BRONZE") // BRONZE, SILVER, GOLD, PLATINUM
  lastVisit      DateTime? @map("last_visit")
  cardNumber     String?   @map("card_number")
  status         String    @default("ACTIVE") // ACTIVE, INACTIVE, BLOCKED
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  program            POSLoyaltyProgram       @relation(fields: [programId], references: [id])
  transactions       POSLoyaltyTransaction[]
  storeCreditEntries POSStoreCredit[]

  @@unique([tenantId, programId, email])
  @@index([tenantId])
  @@index([tenantId, programId])
  @@map("pos_loyalty_members")
}

model POSLoyaltyTransaction {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  programId String   @map("program_id")
  memberId  String   @map("member_id")
  orderId   String?  @map("order_id")
  type      String // EARN, REDEEM, ADJUST, EXPIRE, BONUS
  points    Int // positive = earn, negative = redeem/expire
  balance   Int // running balance after this transaction
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")

  program POSLoyaltyProgram @relation(fields: [programId], references: [id])
  member  POSLoyaltyMember  @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([memberId])
  @@map("pos_loyalty_transactions")
}

// ── Gift Cards ──────────────────────────────────────

model POSGiftCard {
  id             String    @id @default(cuid())
  tenantId       String    @map("tenant_id")
  orgId          String    @map("org_id")
  code           String
  initialBalance Decimal   @map("initial_balance") @db.Decimal(15, 2)
  currentBalance Decimal   @map("current_balance") @db.Decimal(15, 2)
  currency       String    @default("USD")
  issuedTo       String?   @map("issued_to") // customer name or email
  issuedBy       String?   @map("issued_by")
  expiresAt      DateTime? @map("expires_at")
  status         String    @default("ACTIVE") // ACTIVE, DEPLETED, EXPIRED, DEACTIVATED
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  transactions POSGiftCardTransaction[]
  payments     POSPayment[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("pos_gift_cards")
}

model POSGiftCardTransaction {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  giftCardId String   @map("gift_card_id")
  orderId    String?  @map("order_id")
  type       String // LOAD, REDEEM, REFUND, ADJUST
  amount     Decimal  @db.Decimal(15, 2)
  balance    Decimal  @db.Decimal(15, 2) // balance after transaction
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")

  giftCard POSGiftCard @relation(fields: [giftCardId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([giftCardId])
  @@map("pos_gift_card_transactions")
}

// ── Store Credit ────────────────────────────────────

model POSStoreCredit {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  memberId      String?  @map("member_id") // optional link to loyalty member
  customerId    String?  @map("customer_id")
  customerEmail String?  @map("customer_email")
  balance       Decimal  @default(0) @db.Decimal(15, 2)
  currency      String   @default("USD")
  reason        String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  member POSLoyaltyMember? @relation(fields: [memberId], references: [id])

  @@unique([tenantId, customerId])
  @@index([tenantId])
  @@map("pos_store_credits")
}

// ── Returns ─────────────────────────────────────────

model POSReturn {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  orgId           String    @map("org_id")
  returnNumber    String    @map("return_number")
  originalOrderId String    @map("original_order_id")
  type            String    @default("RETURN") // RETURN, EXCHANGE
  status          String    @default("PENDING") // PENDING, APPROVED, REFUNDED, REJECTED
  reason          String?
  refundMethod    String?   @map("refund_method") // ORIGINAL, CASH, STORE_CREDIT, GIFT_CARD
