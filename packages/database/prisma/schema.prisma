// ════════════════════════════════════════════════
// ADMIN — OPERATIONS & PLATFORM EXTENSIONS
// ════════════════════════════════════════════════

model BackgroundJob {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenant_id")
  queueName   String    @map("queue_name")
  jobType     String    @map("job_type")
  bullJobId   String?   @map("bull_job_id") // correlates this row with the real BullMQ Job.id in `queueName`; null for legacy/unlinked rows
  payload     Json      @default("{}")
  status      String    @default("PENDING")
  result      Json?
  error       String?   @db.Text
  attempts    Int       @default(0)
  maxAttempts Int       @default(3) @map("max_attempts")
  priority    Int       @default(0)
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([tenantId, queueName])
  @@index([status])
  @@index([queueName, bullJobId])
  @@map("background_jobs")
}

model ScheduledTask {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenant_id")
  name        String
  description String?
  expression  String
  handler     String
  config      Json      @default("{}")
  status      String    @default("ACTIVE")
  lastRunAt   DateTime? @map("last_run_at")
  nextRunAt   DateTime? @map("next_run_at")
  lastResult  String?   @map("last_result")
  createdBy   String?   @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("scheduled_tasks")
}

model ErrorLog {
  id         String    @id @default(cuid())
  tenantId   String?   @map("tenant_id")
  level      String    @default("ERROR")
  source     String
  message    String    @db.Text
  stack      String?   @db.Text
  metadata   Json      @default("{}")
  userId     String?   @map("user_id")
  requestId  String?   @map("request_id")
  resolved   Boolean   @default(false)
  resolvedBy String?   @map("resolved_by")
  resolvedAt DateTime? @map("resolved_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@index([level])
  @@map("error_logs")
}

model MarketplaceApp {
  id               String   @id @default(cuid())
  slug             String   @unique
  name             String
  description      String   @db.Text
  longDescription  String?  @map("long_description") @db.Text
  category         String
  icon             String?
  publisher        String
  publisherLogo    String?  @map("publisher_logo")
  publisherWebsite String?  @map("publisher_website")
  version          String
  pricing          String   @default("FREE") // FREE | PAID | FREEMIUM
  price            Decimal? @db.Decimal(10, 2)
  rating           Decimal  @default(0) @db.Decimal(3, 2)
  reviewCount      Int      @default(0) @map("review_count")
  installs         Int      @default(0)
  features         Json     @default("[]")
  screenshots      Json     @default("[]") // [{url, caption}]
  tags             Json     @default("[]") // string[]
  metadata         Json     @default("{}")
  requiresApps     Json     @default("[]") @map("requires_apps") // slug[] of prerequisite apps
  configSchema     Json     @default("{}") @map("config_schema") // JSON Schema for post-install config
  supportUrl       String?  @map("support_url")
  documentationUrl String?  @map("documentation_url")
  privacyPolicyUrl String?  @map("privacy_policy_url")
  featured         Boolean  @default(false)
  verified         Boolean  @default(false)
  status           String   @default("PUBLISHED") // PUBLISHED | DRAFT | ARCHIVED
  // ─── Bundle/vendor linkage (listing is a projection of a published AppBundle) ───
  isCore           Boolean  @default(false) @map("is_core") // in-house core module: non-uninstallable, no bundle
  vendorId         String?  @map("vendor_id")
  bundleId         String?  @map("bundle_id") // currently-published AppBundle.id powering this listing
  packageId        String?  @map("package_id") // owning AppPackage.id
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  reviews         AppReview[]
  changelogs      AppChangelog[]
  collectionItems AppCollectionItem[]
  favorites       AppFavorite[]

  @@index([category])
  @@index([featured])
  @@index([vendorId])
  @@map("marketplace_apps")
}

// ─── Third-party publishing: Vendor → AppPackage → AppBundle ───

model AppVendor {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  contactEmail  String?  @map("contact_email")
  websiteUrl    String?  @map("website_url")
  logoUrl       String?  @map("logo_url")
  description   String?  @db.Text
  verified      Boolean  @default(false)
  status        String   @default("ACTIVE") // ACTIVE | SUSPENDED
  ownerUserId   String?  @map("owner_user_id")
  ownerTenantId String?  @map("owner_tenant_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  packages AppPackage[]

  @@map("app_vendors")
}

model AppPackage {
  id               String   @id @default(cuid())
  vendorId         String   @map("vendor_id")
  slug             String   @unique
  name             String
  description      String?  @db.Text
  longDescription  String?  @map("long_description") @db.Text
  category         String
  icon             String?
  pricing          String   @default("FREE") // FREE | PAID | FREEMIUM
  price            Decimal? @db.Decimal(10, 2)
  tags             Json     @default("[]")
  screenshots      Json     @default("[]")
  status           String   @default("DRAFT") // DRAFT | IN_REVIEW | PUBLISHED | SUSPENDED
  currentVersionId String?  @map("current_version_id") // AppBundle.id of the live version
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  vendor  AppVendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  bundles AppBundle[]

  @@index([vendorId])
  @@index([status])
  @@map("app_packages")
}

model AppBundle {
  id          String    @id @default(cuid())
  packageId   String    @map("package_id")
  version     String // semver
  channel     String    @default("STABLE") // STABLE | BETA
  manifest    Json      @default("{}") // full AppManifest (schemas, pages, automations, assets, configSchema)
  blobKey     String    @map("blob_key") // key into BundleStore (the zipped bundle)
  checksum    String?
  sizeBytes   Int       @default(0) @map("size_bytes")
  changelog   String?   @db.Text
  status      String    @default("DRAFT") // DRAFT | IN_REVIEW | PUBLISHED | REJECTED | ROLLED_BACK
  reviewNotes String?   @map("review_notes") @db.Text
  reviewedBy  String?   @map("reviewed_by")
  publishedBy String?   @map("published_by")
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  package AppPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@unique([packageId, version])
  @@index([packageId])
  @@index([status])
  @@map("app_bundles")
}

model AppReview {
  id               String   @id @default(cuid())
