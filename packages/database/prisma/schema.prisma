  CUSTOM
}

enum ContainerTypeCategory {
  DRY_VAN
  REEFER
  FLAT_RACK
  OPEN_TOP
  TANK
  BULK
}

enum LoadPlanStatus {
  DRAFT
  OPTIMIZING
  READY
  IN_LOADING
  LOADED
  SHIPPED
  CANCELLED
}

enum PackingPlanStatus {
  DRAFT
  CONFIRMED
  PACKING
  COMPLETED
  CANCELLED
}

model PalletType {
