model SerialNumber {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  productId       String    @map("product_id")
  warehouseId     String?   @map("warehouse_id")
  serialNo        String    @default("") @map("serial_no")
  serialNumber    String?   @map("serial_number")
  status          String    @default("AVAILABLE") // AVAILABLE, RESERVED, SOLD, IN_REPAIR, SCRAPPED, RETURNED
  purchaseDate    DateTime? @map("purchase_date")
  warrantyExpiry  DateTime? @map("warranty_expiry")
  purchaseOrderId String?   @map("purchase_order_id")
  salesOrderId    String?   @map("sales_order_id")
  notes           String?
  customFields    Json      @default("{}") @map("custom_fields")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

