model AccountingBookRule {
  id                   String   @id @default(cuid())
  tenantId             String   @map("tenant_id")
  orgId                String   @map("org_id")
  sourceBookId         String   @map("source_book_id")
  destinationBookId    String   @map("destination_book_id")
  sourceAccountId      String?  @map("source_account_id")
  destinationAccountId String?  @map("destination_account_id")
