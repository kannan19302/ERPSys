model WithholdingTax {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  orgId     String   @map("org_id")
  name      String
  rate      Decimal  @db.Decimal(15, 4)
  threshold Decimal? @db.Decimal(15, 2)
  accountId String   @map("account_id") // Payable GL account

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  account      Account      @relation(fields: [accountId], references: [id])

  @@index([tenantId])
  @@map("withholding_taxes")
}

model TaxFiling {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenant_id")
  orgId       String    @map("org_id")
  filingType  String    @map("filing_type") // e.g., GSTR-1, VAT_RETURN
  periodStart DateTime  @map("period_start")
  periodEnd   DateTime  @map("period_end")
  status      String    @default("DRAFT")
  payload     Json?
  filedAt     DateTime? @map("filed_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("tax_filings")
}

model InvestmentPortfolio {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  orgId        String   @map("org_id")
  name         String
  assetClass   String   @map("asset_class") // e.g., BONDS, EQUITY, MUTUAL_FUNDS
  currentValue Decimal  @map("current_value") @db.Decimal(15, 2)
  yieldRate    Decimal? @map("yield_rate") @db.Decimal(5, 2)
  accountId    String   @map("account_id") // Asset GL Account
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  account      Account      @relation(fields: [accountId], references: [id])

  @@index([tenantId])
  @@map("investment_portfolios")
}

model TreasuryTransaction {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  orgId         String   @map("org_id")
  type          String // e.g., SWEEP, FOREX_TRADE, HEDGE
  amount        Decimal  @db.Decimal(15, 2)
  currency      String
  description   String?
  date          DateTime
  bankAccountId String?  @map("bank_account_id")
  status        String   @default("COMPLETED") // PENDING, COMPLETED, FAILED

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  bankAccount  BankAccount? @relation(fields: [bankAccountId], references: [id])

  @@index([tenantId])
  @@map("treasury_transactions")
}

model InterCompanyTransfer {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  fromOrgId String   @map("from_org_id")
  toOrgId   String   @map("to_org_id")
  amount    Decimal  @db.Decimal(15, 2)
  currency  String   @default("USD")
  date      DateTime
  status    String   @default("PENDING") // PENDING, APPROVED, POSTED
  createdAt DateTime @default(now()) @map("created_at")

  fromOrganization Organization @relation("FromOrganization", fields: [fromOrgId], references: [id])
  toOrganization   Organization @relation("ToOrganization", fields: [toOrgId], references: [id])

  @@index([tenantId])
  @@map("inter_company_transfers")
}

// ════════════════════════════════════════════════
// EXTENDED INVENTORY MODULE
// ════════════════════════════════════════════════

model StockLedgerEntry {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  productId     String   @map("product_id")
  warehouseId   String   @map("warehouse_id")
  quantity      Decimal  @db.Decimal(15, 3)
  valuationRate Decimal  @map("valuation_rate") @db.Decimal(15, 2)
  voucherType   String   @map("voucher_type") // STOCK_ENTRY, PURCHASE_RECEIPT, DELIVERY_NOTE, CYCLE_COUNT
  voucherId     String   @map("voucher_id")
  batchNumber   String?  @map("batch_number")
  serialNumber  String?  @map("serial_number")
  createdAt     DateTime @default(now()) @map("created_at")

  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([productId])
  @@index([warehouseId])
  @@map("stock_ledger_entries")
}

model StockEntry {
  id              String           @id @default(cuid())
  tenantId        String           @map("tenant_id")
  orgId           String           @map("org_id")
  entryNumber     String           @map("entry_number")
  purpose         String           @default("MATERIAL_TRANSFER") // MATERIAL_RECEIPT, MATERIAL_ISSUE, MATERIAL_TRANSFER
  postingDate     DateTime         @default(now()) @map("posting_date")
  status          String           @default("DRAFT") // DRAFT, SUBMITTED, CANCELLED
  remarks         String?
  fromWarehouseId String?          @map("from_warehouse_id")
  toWarehouseId   String?          @map("to_warehouse_id")
  createdBy       String?          @map("created_by")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  items           StockEntryItem[]

  @@unique([tenantId, orgId, entryNumber])
  @@index([tenantId])
  @@map("stock_entries")
}

model StockEntryItem {
  id            String     @id @default(cuid())
  tenantId      String     @map("tenant_id")
  stockEntryId  String     @map("stock_entry_id")
  productId     String     @map("product_id")
  qty           Decimal    @db.Decimal(15, 3)
  valuationRate Decimal    @map("valuation_rate") @db.Decimal(15, 2)
  amount        Decimal    @db.Decimal(15, 2)
  batchNumber   String?    @map("batch_number")
  serialNumber  String?    @map("serial_number")

  stockEntry    StockEntry @relation(fields: [stockEntryId], references: [id], onDelete: Cascade)
  product       Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([stockEntryId])
  @@map("stock_entry_items")
}

model QualityInspection {
  id               String   @id @default(cuid())
  tenantId         String   @map("tenant_id")
  orgId            String   @map("org_id")
  inspectionNumber String   @map("inspection_number")
  referenceType    String   @map("reference_type") // e.g. "Stock Entry", "Purchase Receipt"
  referenceId      String   @map("reference_id")
  productId        String   @map("product_id")
  status           String   @default("PENDING") // PENDING, PASSED, FAILED
  inspectedQty     Decimal  @map("inspected_qty") @db.Decimal(15, 3)
  passedQty        Decimal  @map("passed_qty") @db.Decimal(15, 3)
  rejectedQty      Decimal  @default(0) @map("rejected_qty") @db.Decimal(15, 3)
  inspectedBy      String   @map("inspected_by")
  inspectedDate    DateTime @default(now()) @map("inspected_date")
  checklist        Json     @default("[]") // Array of checklist item details
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([tenantId, orgId, inspectionNumber])
  @@index([tenantId])
  @@map("quality_inspections")
}
