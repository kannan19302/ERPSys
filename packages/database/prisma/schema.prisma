// ════════════════════════════════════════════════
// BLOCKCHAIN INTEGRATION
// ════════════════════════════════════════════════

/// Status of a blockchain transaction submission
enum BlockchainTxStatus {
  PENDING    /// Queued, not yet submitted to Fabric
  SUBMITTED  /// Submitted to Fabric, awaiting confirmation
  CONFIRMED  /// Confirmed in a committed block
  FAILED     /// Submission failed (Fabric error)
  RETRYING   /// Queued for retry after failure
}

/// Result of a blockchain verification check
enum VerificationResult {
  VERIFIED      /// On-chain hash matches local data
  TAMPERED      /// Hash mismatch — data was modified after anchoring
  NOT_FOUND     /// No on-chain record exists yet
  NETWORK_ERROR /// Fabric was unreachable during verification
}

/// Tracks every on-chain submission — the PostgreSQL shadow of Fabric transactions
model BlockchainTransaction {
  id            String              @id @default(cuid())
  tenantId      String              @map("tenant_id")
  /// The type of ERP entity anchored (e.g. DOCUMENT, GL_JOURNAL)
  entityType    String              @map("entity_type")
  /// The PostgreSQL ID of the entity
  entityId      String              @map("entity_id")
  /// Fabric channel name
  channelName   String              @map("channel_name")
  /// Fabric chaincode name
  chaincodeName String              @map("chaincode_name")
  /// SHA-256 hash of the data that was anchored
  dataHash      String              @map("data_hash")
  /// Current submission status
  status        BlockchainTxStatus  @default(PENDING)
  /// Fabric transaction ID (set when CONFIRMED)
  transactionId String?             @map("transaction_id")
  /// Fabric block number (set when CONFIRMED, stored as string for bigint safety)
  blockNumber   String?             @map("block_number")
  /// When the transaction was confirmed in a block
  confirmedAt   DateTime?           @map("confirmed_at")
  /// Error message on failure
  errorMessage  String?             @map("error_message")
  /// Number of retry attempts
  retryCount    Int                 @default(0) @map("retry_count")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, entityType, entityId])
  @@index([tenantId, status])
  @@index([transactionId])
  @@map("blockchain_transactions")
}

/// Tracks verification checks — when a user or system verified on-chain integrity
model BlockchainVerification {
  id          String             @id @default(cuid())
  tenantId    String             @map("tenant_id")
  entityType  String             @map("entity_type")
  entityId    String             @map("entity_id")
  /// Result of the verification check
  result      VerificationResult
  /// Hash computed from current local data
  localHash   String?            @map("local_hash")
  /// Hash retrieved from the blockchain
  onChainHash String?            @map("on_chain_hash")
  /// When this verification was performed
  verifiedAt  DateTime           @default(now()) @map("verified_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, entityType, entityId])
  @@index([tenantId, result])
  @@map("blockchain_verifications")
}

/// Durable checkpoint for blockchain event listener — persists the last-processed
/// block number per (channel, chaincode) so the listener resumes from the correct
/// position on restart instead of replaying from genesis.
model BlockchainSyncCheckpoint {
  id              String   @id @default(cuid())
  /// Fabric channel name
  channelName     String   @map("channel_name")
  /// Fabric chaincode name
  chaincodeName   String   @map("chaincode_name")
  /// Last processed block number (stored as string for bigint safety)
  lastBlockNumber String   @map("last_block_number")
  /// When this checkpoint was last updated
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([channelName, chaincodeName])
  @@map("blockchain_sync_checkpoints")
}

// ════════════════════════════════════════════════
// TRANSACTIONAL OUTBOX
// ════════════════════════════════════════════════

model OutboxEvent {
  id            String           @id @default(cuid())
  tenantId      String           @map("tenant_id")
  eventName     String           @map("event_name")
  eventVersion  Int              @map("event_version")
  aggregateType String           @map("aggregate_type")
  aggregateId   String           @map("aggregate_id")
  sequence      Int
  occurredAt    DateTime         @default(now()) @map("occurred_at")
  payload       Json
  correlationId String?          @map("correlation_id")
  causationId   String?          @map("causation_id")
  eventKey      String           @map("event_key")

  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deliveries OutboxDelivery[]

  @@unique([tenantId, eventKey])
  @@unique([tenantId, aggregateType, aggregateId, sequence])
  @@index([tenantId])
  @@index([tenantId, aggregateType, aggregateId])
  @@map("outbox_events")
}

model OutboxDelivery {
  id             String      @id @default(cuid())
  tenantId       String      @map("tenant_id")
  outboxEventId  String      @map("outbox_event_id")
  destination    String
  status         String      @default("PENDING") // PENDING | LEASED | COMPLETED | DEAD
  attempts       Int         @default(0)
  leaseOwner     String?     @map("lease_owner")
  leaseExpiresAt DateTime?   @map("lease_expires_at")
  availableAt    DateTime    @default(now()) @map("available_at")
  lastError      String?     @map("last_error")
  completedAt    DateTime?   @map("completed_at")
  failedAt       DateTime?   @map("failed_at")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  outboxEvent OutboxEvent @relation(fields: [outboxEventId], references: [id], onDelete: Cascade)

  @@unique([outboxEventId, destination])
  @@index([tenantId])
  @@index([status, availableAt])
  @@map("outbox_deliveries")
}

model OutboxConsumerReceipt {
  id            String    @id @default(cuid())
  tenantId      String    @map("tenant_id")
  consumer      String
  outboxEventId String    @map("outbox_event_id")
  processedAt   DateTime  @default(now()) @map("processed_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([consumer, outboxEventId])
  @@index([tenantId])
  @@map("outbox_consumer_receipts")
}

// ════════════════════════════════════════════════
// DOCUMENT NUMBERING SERVICE (Track G.5)
// Tenant-scoped, gapless-where-required, concurrency-safe
// ════════════════════════════════════════════════

model DocumentSequence {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  organizationId  String?   @map("organization_id")
  series          String
  description     String?   @db.Text
  prefix          String    @default("")
  suffix          String    @default("")
  padding         Int       @default(5)
  nextNumber      Int       @default(1) @map("next_number")
  resetFrequency  String?   @map("reset_frequency") // "YEARLY", "MONTHLY", "NEVER"
  resetPeriod     String?   @map("reset_period")    // e.g. "2026", "2026-07"
  format          String    @default("{prefix}{number}{suffix}")
  version         Int       @default(1)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@unique([tenantId, series, organizationId])
  @@index([tenantId])
  @@map("document_sequences")
}
