model Channel {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  orgId       String   @map("org_id")
  name        String
  description String?
  type        String   @default("PUBLIC") // PUBLIC, PRIVATE
  kind        String   @default("CHANNEL") // CHANNEL, DM, GROUP
  spaceId     String?  @map("space_id")
  topic       String?
  archived    Boolean  @default(false) @map("archived")
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  messages Message[]
  members  ChannelMember[]
  space    ConnectSpace?   @relation(fields: [spaceId], references: [id])

  @@index([tenantId])
  @@index([tenantId, spaceId])
  @@map("channels")
}

/// Search: `content` is covered by a `pg_trgm` GIN index (idx_messages_content_trgm) created
/// via raw SQL in migration 20260702120000_connect_roles_notify_search — not modeled here because
/// Prisma has no native index-ops syntax without the `postgresqlExtensions` preview feature.
/// Do not drop/recreate this index via `prisma migrate dev` schema diffing.
model Message {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenant_id")
  channelId   String    @map("channel_id")
  userId      String    @map("user_id")
  content     String    @db.Text
  kind        String    @default("USER") // USER, SYSTEM
  parentId    String?   @map("parent_id")
  pinned      Boolean   @default(false)
  attachments Json      @default("[]")
  meetingId   String?   @map("meeting_id")
  editedAt    DateTime? @map("edited_at")
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  bookmarks MessageBookmark[]

  channel   Channel           @relation(fields: [channelId], references: [id], onDelete: Cascade)
  parent    Message?          @relation("MessageThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Message[]         @relation("MessageThread")
  reactions MessageReaction[]

  @@index([tenantId])
  @@index([channelId, parentId])
  @@index([tenantId, deletedAt])
  @@map("messages")
}

model ConnectSpace {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  orgId     String   @map("org_id")
  name      String
