}

// ─── Physical Inventory / Stock Take (Cycle 25) ──────────────────────────────

enum StockTakeStatus {
  DRAFT
  IN_PROGRESS
  COUNTING
  VARIANCE_REVIEW
  APPROVED
  POSTED
  CANCELLED
}

enum CountSheetStatus {
  PENDING
  COUNTING
  RECOUNTED
  APPROVED
  REJECTED
}

enum StockTakeVarianceStatus {
  PENDING
  APPROVED
  REJECTED
}

model StockTake {
  id             String          @id @default(cuid())
  tenantId       String          @map("tenant_id")
  stockTakeNumber String         @map("stock_take_number")
  warehouseId    String          @map("warehouse_id")
  status         StockTakeStatus @default(DRAFT)
  countType      String          @default("FULL") @map("count_type") // FULL | ZONE | CATEGORY
  countDate      DateTime        @map("count_date")
  frozenAt       DateTime?       @map("frozen_at")
  completedAt    DateTime?       @map("completed_at")
  postedAt       DateTime?       @map("posted_at")
  notes          String?
  createdBy      String          @map("created_by")
  approvedBy     String?         @map("approved_by")
  approvedAt     DateTime?       @map("approved_at")
  postedBy       String?         @map("posted_by")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  sheets    CountSheet[]
  variances StockTakeVariance[]

  @@unique([tenantId, stockTakeNumber])
  @@index([tenantId])
  @@index([warehouseId])
  @@index([status])
  @@map("stock_takes")
}

model CountSheet {
  id           String          @id @default(cuid())
  tenantId     String          @map("tenant_id")
  stockTakeId  String          @map("stock_take_id")
  sheetNumber  String          @map("sheet_number")
  warehouseId  String          @map("warehouse_id")
  zone         String?
  assignedTo   String?         @map("assigned_to")
  status       CountSheetStatus @default(PENDING)
  countedAt    DateTime?       @map("counted_at")
  recountedAt  DateTime?       @map("recounted_at")
  notes        String?
  createdAt    DateTime        @default(now()) @map("created_at")

  stockTake StockTake       @relation(fields: [stockTakeId], references: [id], onDelete: Cascade)
  items     CountSheetItem[]

  @@unique([tenantId, stockTakeId, sheetNumber])
  @@index([tenantId])
  @@index([stockTakeId])
  @@map("count_sheets")
}

model CountSheetItem {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  sheetId         String   @map("sheet_id")
  productId       String   @map("product_id")
  binLocationId   String?  @map("bin_location_id")
  lotNumber       String?  @map("lot_number")
  uom             String   @default("UNIT")
  systemQty       Decimal  @map("system_qty") @db.Decimal(15, 4)
  countedQty      Decimal? @map("counted_qty") @db.Decimal(15, 4)
  recountedQty    Decimal? @map("recounted_qty") @db.Decimal(15, 4)
  varianceQty     Decimal? @map("variance_qty") @db.Decimal(15, 4)
  variancePct     Decimal? @map("variance_pct") @db.Decimal(8, 4)
  unitCost        Decimal? @map("unit_cost") @db.Decimal(15, 4)
  varianceValue   Decimal? @map("variance_value") @db.Decimal(15, 4)
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")

  sheet CountSheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([sheetId])
  @@map("count_sheet_items")
}

model StockTakeVariance {
  id              String                  @id @default(cuid())
  tenantId        String                  @map("tenant_id")
  stockTakeId     String                  @map("stock_take_id")
  productId       String                  @map("product_id")
  warehouseId     String                  @map("warehouse_id")
  binLocationId   String?                 @map("bin_location_id")
  systemQty       Decimal                 @map("system_qty") @db.Decimal(15, 4)
  countedQty      Decimal                 @map("counted_qty") @db.Decimal(15, 4)
  varianceQty     Decimal                 @map("variance_qty") @db.Decimal(15, 4)
  variancePct     Decimal                 @map("variance_pct") @db.Decimal(8, 4)
  unitCost        Decimal?                @map("unit_cost") @db.Decimal(15, 4)
  varianceValue   Decimal?                @map("variance_value") @db.Decimal(15, 4)
  status          StockTakeVarianceStatus @default(PENDING)
  approvedBy      String?                 @map("approved_by")
  approvedAt      DateTime?               @map("approved_at")
  rejectionReason String?                 @map("rejection_reason")
  postedLedgerId  String?                 @map("posted_ledger_id")
  createdAt       DateTime                @default(now()) @map("created_at")

  stockTake StockTake @relation(fields: [stockTakeId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([stockTakeId])
  @@index([status])
  @@map("stock_take_variances")
}

// ─── Cycle 26: Hazardous Materials & Dangerous Goods ────────────────────────

enum HazardClass {
  CLASS_1_EXPLOSIVES
  CLASS_2_GASES
  CLASS_3_FLAMMABLE_LIQUIDS
  CLASS_4_FLAMMABLE_SOLIDS
  CLASS_5_OXIDIZERS
  CLASS_6_TOXIC
  CLASS_7_RADIOACTIVE
  CLASS_8_CORROSIVES
  CLASS_9_MISC
}

enum PackingGroup {
  I
  II
  III
}

enum HazmatRegulation {
  ADR
  IATA
  IMDG
  DOT
  REACH
}

enum SdsStatus {
  CURRENT
  EXPIRED
  PENDING_REVIEW
  SUPERSEDED
}

enum HazmatManifestStatus {
  DRAFT
  SUBMITTED
  ACKNOWLEDGED
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum StorageCompatibilityResult {
  COMPATIBLE
  INCOMPATIBLE
  CONDITIONAL
}

model HazmatClassification {
  id              String           @id @default(cuid())
  tenantId        String           @map("tenant_id")
  productId       String           @map("product_id")
  unNumber        String           @map("un_number")
  properShippingName String        @map("proper_shipping_name")
  hazardClass     HazardClass      @map("hazard_class")
  subsidiaryHazards String[]       @map("subsidiary_hazards")
  packingGroup    PackingGroup?    @map("packing_group")
  regulation      HazmatRegulation
  flashPoint      Decimal?         @map("flash_point") @db.Decimal(8, 2)
  boilingPoint    Decimal?         @map("boiling_point") @db.Decimal(8, 2)
  maxQtyPerPackage Decimal?        @map("max_qty_per_package") @db.Decimal(15, 4)
  transportIndex  Decimal?         @map("transport_index") @db.Decimal(8, 2)
  isExempted      Boolean          @default(false) @map("is_exempted")
  exemptionRef    String?          @map("exemption_ref")
  notes           String?
  createdBy       String           @map("created_by")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  sdsRecords      SafetyDataSheet[]
  manifests       HazmatManifestLine[]

  @@unique([tenantId, productId, regulation])
  @@index([tenantId])
  @@index([unNumber])
  @@map("hazmat_classifications")
}

model SafetyDataSheet {
  id                  String     @id @default(cuid())
  tenantId            String     @map("tenant_id")
  classificationId    String     @map("classification_id")
  productId           String     @map("product_id")
  sdsNumber           String     @map("sds_number")
  revision            String
  issueDate           DateTime   @map("issue_date")
  expiryDate          DateTime?  @map("expiry_date")
  supplier            String
  language            String     @default("EN")
  status              SdsStatus  @default(CURRENT)
  storageConditions   String?    @map("storage_conditions")
  firstAidMeasures    String?    @map("first_aid_measures")
  spillProcedures     String?    @map("spill_procedures")
  disposalMethods     String?    @map("disposal_methods")
  documentUrl         String?    @map("document_url")
  acknowledgedBy      String?    @map("acknowledged_by")
  acknowledgedAt      DateTime?  @map("acknowledged_at")
  supersededById      String?    @map("superseded_by_id")
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")

  classification      HazmatClassification @relation(fields: [classificationId], references: [id], onDelete: Cascade)

  @@unique([tenantId, sdsNumber])
  @@index([tenantId])
  @@index([productId])
  @@index([status])
  @@map("safety_data_sheets")
}

model HazmatStorageRule {
