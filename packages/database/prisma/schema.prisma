  id                  String    @id @default(cuid())
  tenantId            String    @map("tenant_id")
  qualityInspectionId String?   @map("quality_inspection_id")
  workOrderId         String?   @map("work_order_id")
  productId           String    @map("product_id")
  title               String
  description         String?
  disposition         String    @default("REWORK") // REWORK, SCRAP, ACCEPT_AS_IS, RETURN_TO_VENDOR
  status              String    @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED
  loggedBy            String?   @map("logged_by")
  resolvedBy          String?   @map("resolved_by")
  resolvedAt          DateTime? @map("resolved_at")
  createdAt           DateTime  @default(now()) @map("created_at")

  workOrder WorkOrder? @relation(fields: [workOrderId], references: [id])
  product   Product    @relation(fields: [productId], references: [id])

  @@index([tenantId])
  @@map("non_conformance_reports")
}

model MachineDowntimeLog {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  workstationId   String    @map("workstation_id")
  downtimeCode    String    @map("downtime_code") // ELECTRICAL, MECHANICAL, TOOL_WEAR, NO_OPERATOR
  startTime       DateTime  @map("start_time")
  endTime         DateTime? @map("end_time")
  durationMinutes Int?      @map("duration_minutes")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")

  workstation Workstation @relation(fields: [workstationId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([workstationId])
  @@map("machine_downtime_logs")
}

model MaintenanceRequest {
  id            String    @id @default(cuid())
  tenantId      String    @map("tenant_id")
  workstationId String    @map("workstation_id")
  type          String    @default("CORRECTIVE") // PREVENTIVE, CORRECTIVE
  priority      String    @default("MEDIUM") // LOW, MEDIUM, HIGH
  title         String
  description   String?
  status        String    @default("REQUESTED") // REQUESTED, SCHEDULED, IN_PROGRESS, COMPLETED
  assignedTo    String?   @map("assigned_to")
  cost          Decimal?  @db.Decimal(15, 2)
  createdAt     DateTime  @default(now()) @map("created_at")
  completedAt   DateTime? @map("completed_at")

  workstation Workstation @relation(fields: [workstationId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([workstationId])
  @@map("maintenance_requests")
}

model SubcontractingOrder {
  id           String    @id @default(cuid())
  tenantId     String    @map("tenant_id")
  vendorId     String    @map("vendor_id")
  productId    String    @map("product_id")
  bomId        String?   @map("bom_id")
  quantity     Decimal   @db.Decimal(15, 3)
  unitCost     Decimal   @map("unit_cost") @db.Decimal(15, 2)
  totalCost    Decimal   @map("total_cost") @db.Decimal(15, 2)
  status       String    @default("SENT") // SENT, MATERIALS_SHIPPED, RECEIVED, COMPLETED
  deliveryDate DateTime? @map("delivery_date")
  createdAt    DateTime  @default(now()) @map("created_at")

  vendor    Vendor                   @relation(fields: [vendorId], references: [id])
  product   Product                  @relation(fields: [productId], references: [id])
  bom       BOM?                     @relation(fields: [bomId], references: [id])
  materials SubcontractingMaterial[]

  @@index([tenantId])
  @@map("subcontracting_orders")
}

model WorkOrderOperation {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  workOrderId     String    @map("work_order_id")
  sequence        Int
  name            String
  workstationCode String    @map("workstation_code")
  durationMinutes Int       @map("duration_minutes")
  status          String    @default("PENDING") // PENDING, RUNNING, COMPLETED
  startedAt       DateTime? @map("started_at")
  completedAt     DateTime? @map("completed_at")
  operatorId      String?   @map("operator_id")

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([workOrderId])
  @@map("work_order_operations")
}

model WorkstationShift {
  id            String @id @default(cuid())
  tenantId      String @map("tenant_id")
  workstationId String @map("workstation_id")
  name          String
  startTime     String @map("start_time") // e.g. "08:00"
  endTime       String @map("end_time") // e.g. "16:00"
  daysOfWeek    Int[]  @map("days_of_week") // e.g. [1, 2, 3, 4, 5]

  workstation Workstation @relation(fields: [workstationId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([workstationId])
  @@map("workstation_shifts")
}

model SubcontractingMaterial {
  id                    String  @id @default(cuid())
  tenantId              String  @map("tenant_id")
  subcontractingOrderId String  @map("subcontracting_order_id")
  productId             String  @map("product_id")
  requiredQty           Decimal @map("required_qty") @db.Decimal(15, 3)
  issuedQty             Decimal @default(0) @map("issued_qty") @db.Decimal(15, 3)
  consumedQty           Decimal @default(0) @map("consumed_qty") @db.Decimal(15, 3)

  subcontractingOrder SubcontractingOrder @relation(fields: [subcontractingOrderId], references: [id], onDelete: Cascade)
  product             Product             @relation(fields: [productId], references: [id])

  @@index([tenantId])
  @@index([subcontractingOrderId])
  @@map("subcontracting_materials")
}

model EquipmentTool {
  id                  String    @id @default(cuid())
  tenantId            String    @map("tenant_id")
  workstationId       String    @map("workstation_id")
  name                String
  code                String
  maxCycles           Int       @map("max_cycles")
  currentCycles       Int       @default(0) @map("current_cycles")
  lastCalibrationDate DateTime? @map("last_calibration_date")
  status              String    @default("OK") // OK, NEEDS_CALIBRATION, OUT_OF_SERVICE

  workstation Workstation @relation(fields: [workstationId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([workstationId])
  @@map("equipment_tools")
}

model EngineeringChangeOrder {
  id                String   @id @default(cuid())
  tenantId          String   @map("tenant_id")
  bomId             String   @map("bom_id")
  changeDescription String   @map("change_description")
  requestedBy       String   @map("requested_by")
  approvedBy        String?  @map("approved_by")
  status            String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt         DateTime @default(now()) @map("created_at")

  bom BOM @relation(fields: [bomId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([bomId])
  @@map("engineering_change_orders")
}

model WorkOrderComponentConsumption {
  id               String  @id @default(cuid())
  tenantId         String  @map("tenant_id")
  workOrderId      String  @map("work_order_id")
  productId        String  @map("product_id")
  lotNumber        String  @map("lot_number") // Lot of raw component consumed
  quantityConsumed Decimal @map("quantity_consumed") @db.Decimal(15, 3)

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id])

  @@index([tenantId])
  @@index([workOrderId])
  @@map("work_order_component_consumptions")
}

// ════════════════════════════════════════════════
// BUILDER STUDIO — Custom Forms, Workflows, Dashboards, Modules, Automation
// ════════════════════════════════════════════════

model BuilderForm {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  name        String
  slug        String
  description String?
  icon        String?
  status      String   @default("DRAFT") // DRAFT, PUBLISHED, ARCHIVED
  module      String   @default("Sales")
  fields      Json     @default("[]") // Array of field definitions [{name, type, label, required, options}]
  settings    Json     @default("{}") // Form settings: naming, permissions, etc.
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("builder_forms")
}

model BuilderWorkflow {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  name        String
  description String?
  docType     String?  @map("doc_type") // Which form/module this workflow applies to
  status      String   @default("DRAFT") // DRAFT, ACTIVE, PAUSED
  trigger     String   @default("SUBMIT") // SUBMIT, CREATE, UPDATE, MANUAL
  nodes       Json     @default("[]") // Workflow graph nodes [{id, type, label, approver, position}]
  edges       Json     @default("[]") // Connections between nodes [{from, to, condition}]
  settings    Json     @default("{}") // Auto-approve rules, SLA, etc.
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("builder_workflows")
}

model BuilderDashboard {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  name        String
  description String?
  icon        String?
  status      String   @default("DRAFT") // DRAFT, PUBLISHED
  widgets     Json     @default("[]") // Array of widgets [{type, title, dataSource, chartType, position, size}]
  layout      Json     @default("{}") // Grid layout config
  refreshRate Int      @default(300) @map("refresh_rate") // Auto-refresh seconds
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("builder_dashboards")
}

model BuilderModule {
  id            String  @id @default(cuid())
  tenantId      String  @map("tenant_id")
  name          String
  slug          String
  description   String?
  icon          String?
  color         String?
  status        String  @default("DRAFT") // DRAFT, ACTIVE, ARCHIVED
  scope         String  @default("ORGANIZATION") // DRAFT, ORGANIZATION, GLOBAL
  version       String  @default("1.0.0")
  entities      Json    @default("[]") // Array of entity schemas [{name, fields, relationships}]
  relationships Json    @default("[]") // Cross-entity relationships [{from, to, type}]
  permissions   Json    @default("{}") // Module-level RBAC configuration
  pages         Json    @default("[]") // [{id, name, slug, type:'form'|'list'|'dashboard', formId?, dashboardId?}]
  components    Json    @default("[]") // [{id, type:'form'|'workflow'|'dashboard'|'automation', refId, name}]
  dataModels    Json    @default("[]") // [{id, name, fields:[{name,type,required}], relationships:[]}]
  testResults   Json    @default("{}") // {lastRunAt, score, totalTests, passed, failed, errors:[], history:[]}

  // ─── App Store listing metadata ───
  category        String? // e.g. "Operations", "HR", "Finance"
  longDescription String? @map("long_description") @db.Text
  publisher       String? // display name of the publishing org/team
  screenshots     Json    @default("[]") // Array of asset URLs for the store listing
  installCount    Int     @default(0) @map("install_count")

  currentReleaseId String?   @map("current_release_id") // points at the latest PUBLISHED AppRelease
  publishedAt      DateTime? @map("published_at")
  createdBy        String?   @map("created_by")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  releases AppRelease[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([scope, status])
  @@map("builder_modules")
}

// Immutable snapshot of a BuilderModule at publish time. Installs pin to a
// release so a tenant's running app is unaffected by later edits in the studio.
model AppRelease {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  moduleId    String   @map("module_id")
  version     String // semver, e.g. "1.2.0"
  channel     String   @default("ORGANIZATION") // ORGANIZATION, GLOBAL
  changelog   String?  @db.Text
  snapshot    Json     @default("{}") // frozen {components, pages, dataModels, permissions, entities, relationships, meta}
  testScore   Int?     @map("test_score")
  status      String   @default("PUBLISHED") // PUBLISHED, ROLLED_BACK
  publishedBy String?  @map("published_by")
  publishedAt DateTime @default(now()) @map("published_at")

  module BuilderModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([moduleId, version])
  @@index([tenantId])
  @@index([channel, status])
  @@map("app_releases")
}

model AutomationRule {
  id            String    @id @default(cuid())
  tenantId      String    @map("tenant_id")
  name          String
  description   String?
  trigger       String // e.g. "record.created", "schedule.daily", "form.submitted"
  triggerConfig Json      @default("{}") @map("trigger_config") // Trigger-specific configuration
  conditions    Json      @default("[]") // Array of conditions [{field, operator, value}]
  actions       Json      @default("[]") // Array of actions [{type, config}]
  status        String    @default("DRAFT") // DRAFT, ACTIVE, PAUSED
  runCount      Int       @default(0) @map("run_count")
  lastRunAt     DateTime? @map("last_run_at")
  avgExecMs     Int?      @map("avg_exec_ms") // Average execution time in milliseconds
  settings      Json      @default("{}") // runOnce, logExecution, haltOnError
  createdBy     String?   @map("created_by")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("automation_rules")
}

model DataImportJob {
  id            String    @id @default(cuid())
  tenantId      String    @map("tenant_id")
  name          String
  targetModel   String    @map("target_model") // Which Prisma model to import into
  fileName      String    @map("file_name")
  fileSize      Int       @map("file_size") // In bytes
  totalRows     Int       @default(0) @map("total_rows")
  importedRows  Int       @default(0) @map("imported_rows")
  failedRows    Int       @default(0) @map("failed_rows")
  columnMapping Json      @default("{}") @map("column_mapping") // {csvColumn: dbColumn}
  status        String    @default("PENDING") // PENDING, VALIDATING, IMPORTING, COMPLETED, FAILED
  errorLog      Json      @default("[]") @map("error_log") // Array of row-level errors
  startedAt     DateTime? @map("started_at")
  completedAt   DateTime? @map("completed_at")
  createdBy     String?   @map("created_by")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([tenantId])
  @@map("data_import_jobs")
}

model WebPage {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  name       String
  slug       String
  status     String   @default("DRAFT") // DRAFT, PUBLISHED, ARCHIVED
  sections   Json     @default("[]") // Array of page sections [{id, type, content, settings}]
  metaTitle  String?  @map("meta_title")
  metaDesc   String?  @map("meta_desc")
  ogImage    String?  @map("og_image")
  visibility String   @default("PUBLIC") // PUBLIC, UNLISTED, PASSWORD_PROTECTED
  sortOrder  Int      @default(0) @map("sort_order")
  visits     Int      @default(0)
  createdBy  String?  @map("created_by")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("web_pages")
}

model BlogPost {
  id            String    @id @default(cuid())
  tenantId      String    @map("tenant_id")
  title         String
  slug          String
  content       String?   @db.Text
  excerpt       String?
  category      String    @default("General")
  tags          Json      @default("[]") // Array of tag strings
  author        String?
  status        String    @default("DRAFT") // DRAFT, PUBLISHED, ARCHIVED
  featuredImage String?   @map("featured_image")
  metaTitle     String?   @map("meta_title")
  metaDesc      String?   @map("meta_desc")
  readTime      String?   @map("read_time")
  views         Int       @default(0)
  publishedAt   DateTime? @map("published_at")
  createdBy     String?   @map("created_by")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("blog_posts")
}

model WebAsset {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  name       String
  url        String
  type       String   @default("IMAGE") // IMAGE, DOCUMENT, VIDEO
  sizeBytes  Int      @default(0) @map("size_bytes")
  uploadedBy String?  @map("uploaded_by")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("web_assets")
}

model WebTemplate {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  name         String
  description  String?
  thumbnail    String?
  htmlContent  String?  @map("html_content") @db.Text
  cssContent   String?  @map("css_content") @db.Text
  designTokens Json     @default("{}") @map("design_tokens")
  status       String   @default("DRAFT")
  author       String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  settings WebSettings[]

  @@index([tenantId])
  @@map("web_templates")
}

model WebMenu {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  name      String
  location  String   @default("HEADER") // HEADER, FOOTER, SIDEBAR
  items     Json // Array of { label, url, order }
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("web_menus")
}

model WebSeo {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  path        String // URL path this applies to
  title       String
  description String?
  keywords    String?
  ogImage     String?  @map("og_image")
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, path])
  @@map("web_seo")
}

model WebSettings {
  id               String   @id @default(cuid())
  tenantId         String   @unique @map("tenant_id")
  activeTemplateId String?  @map("active_template_id")
  globalCss        String?  @map("global_css") @db.Text
  themeTokens      Json     @default("{}") @map("theme_tokens")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  template WebTemplate? @relation(fields: [activeTemplateId], references: [id])

  @@map("web_settings")
}

// ════════════════════════════════════════════════
// WEB STUDIO — CMS COLLECTIONS (dynamic content modeling)
// Powers e-commerce catalogs, portfolios, team directories, testimonials, etc.
// ════════════════════════════════════════════════

model WebCollection {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  siteId      String?  @map("site_id") // owning site (multi-site); null = legacy/default
  name        String // e.g. "Products", "Projects", "Team"
  slug        String // URL-safe, used in public API + dynamic routes
  singular    String? // e.g. "Product" (for UI labels)
  description String?
  icon        String? // emoji or lucide name
  color       String?
  kind        String   @default("GENERIC") // GENERIC | PRODUCT | POST | PORTFOLIO | TEAM | TESTIMONIAL
  fields      Json     @default("[]") // [{ name, label, type, required, options, ... }]
  settings    Json     @default("{}") // titleField, slugField, imageField, sort, etc.
  status      String   @default("ACTIVE") // ACTIVE | ARCHIVED
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  items WebCollectionItem[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("web_collections")
}

model WebCollectionItem {
  id           String    @id @default(cuid())
  tenantId     String    @map("tenant_id")
  collectionId String    @map("collection_id")
  slug         String // item-level slug for /:collection/:slug routes
  data         Json      @default("{}") // the actual field values
  status       String    @default("DRAFT") // DRAFT | PUBLISHED | ARCHIVED
  featured     Boolean   @default(false)
  sortOrder    Int       @default(0) @map("sort_order")
  publishedAt  DateTime? @map("published_at")
  createdBy    String?   @map("created_by")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  collection WebCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@unique([collectionId, slug])
  @@index([tenantId, collectionId])
  @@index([tenantId, status])
  @@map("web_collection_items")
}

// Form submissions captured from public-facing website forms (contact, lead, newsletter).
model WebFormSubmission {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  siteId    String?  @map("site_id") // owning site (multi-site)
  formName  String   @map("form_name") // logical form identifier, e.g. "contact", "newsletter"
  pageSlug  String?  @map("page_slug") // which page it came from
  data      Json     @default("{}") // submitted field values
  status    String   @default("NEW") // NEW | READ | SPAM | ARCHIVED
  meta      Json     @default("{}") // ip, userAgent, referrer
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId, formName])
  @@index([tenantId, status])
  @@map("web_form_submissions")
}

// Orders captured from the public-facing storefront (e-commerce).
model WebOrder {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  siteId      String?  @map("site_id") // owning site (multi-site)
  orderNumber String   @map("order_number")
  status      String   @default("PENDING") // PENDING | PAID | FULFILLED | CANCELLED
  customer    Json     @default("{}") // { name, email, phone, address }
  items       Json     @default("[]") // [{ productSlug, name, price, qty, image }]
  subtotal    Float    @default(0)
  total       Float    @default(0)
  currency    String   @default("USD")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, orderNumber])
  @@index([tenantId, status])
  @@map("web_orders")
}

// ════════════════════════════════════════════════
// WEB STUDIO — MULTI-SITE WEBSITE BUILDER
// A tenant can build one or more sites, each served at its own custom
// domain(s) from "/". Pages/blog/docs/collections/forms/store/chatbot are
// scoped to a site.
// ════════════════════════════════════════════════

model WebSite {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  name      String
  slug      String // unique per tenant; the migrated legacy site is "default"
  status    String   @default("ACTIVE") // ACTIVE | ARCHIVED
  theme     Json     @default("{}") // colors, fonts, css tokens
  settings  Json     @default("{}") // nav, footer, favicon, analytics, etc.
  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  domains  WebDomain[]
  pages    WebSitePage[]
  chatbots WebChatbot[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("web_sites")
}

// Custom domain / subdomain mapping → site. The middleware resolves the
// request Host against this table to serve the right site at "/".
model WebDomain {
  id        String   @id @default(cuid())
  siteId    String   @map("site_id")
  host      String   @unique // e.g. "acme.com" or "acme.unerp.app"
  verified  Boolean  @default(false)
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")

  site WebSite @relation(fields: [siteId], references: [id], onDelete: Cascade)

