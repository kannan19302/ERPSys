}


// ════════════════════════════════════════════════
// INVENTORY CYCLE 29 — CATCH-WEIGHT & PRODUCT RECALL
// ════════════════════════════════════════════════

enum CatchWeightVariance {
  WITHIN_TOLERANCE
  OVER_TOLERANCE
  UNDER_TOLERANCE
}

enum RecallClass {
  CLASS_I
  CLASS_II
  CLASS_III
}

enum RecallStatus {
  DRAFT
  ISSUED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum RecallActionType {
  RETURN
  DESTROY
  REWORK
  QUARANTINE
}

/// Catch-weight configuration per product — defines tare, tolerance bands, pricing basis.
model CatchWeightConfig {
  id                  String   @id @default(cuid())
  tenantId            String   @map("tenant_id")
  productId           String   @map("product_id")
  nominalWeightKg     Decimal  @map("nominal_weight_kg") @db.Decimal(10, 4)
  tolerancePctPlus    Decimal  @default(5) @map("tolerance_pct_plus") @db.Decimal(5, 2)
  tolerancePctMinus   Decimal  @default(5) @map("tolerance_pct_minus") @db.Decimal(5, 2)
  pricingBasis        String   @default("ACTUAL_WEIGHT") @map("pricing_basis")
  tareWeightKg        Decimal  @default(0) @map("tare_weight_kg") @db.Decimal(10, 4)
  uomNominal          String   @default("UNIT") @map("uom_nominal")
  uomWeight           String   @default("KG") @map("uom_weight")
  active              Boolean  @default(true)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  weightReadings      CatchWeightReading[]

  @@unique([tenantId, productId])
  @@index([tenantId])
  @@map("catch_weight_configs")
}

/// Actual weight reading captured at receipt/pick/ship.
model CatchWeightReading {
  id              String               @id @default(cuid())
  tenantId        String               @map("tenant_id")
  configId        String               @map("config_id")
  referenceType   String               @map("reference_type")   // RECEIPT | PICK | SHIPMENT | ADJUSTMENT
  referenceId     String               @map("reference_id")
  lotNumber       String?              @map("lot_number")
  serialNumber    String?              @map("serial_number")
  nominalQty      Decimal              @map("nominal_qty") @db.Decimal(15, 4)
  actualWeightKg  Decimal              @map("actual_weight_kg") @db.Decimal(10, 4)
  varianceKg      Decimal              @map("variance_kg") @db.Decimal(10, 4)
  variancePct     Decimal              @map("variance_pct") @db.Decimal(7, 4)
  varianceStatus  CatchWeightVariance  @map("variance_status")
  scaleId         String?              @map("scale_id")
  capturedAt      DateTime             @default(now()) @map("captured_at")
  capturedBy      String               @map("captured_by")

  config          CatchWeightConfig    @relation(fields: [configId], references: [id])

  @@index([tenantId])
  @@index([configId])
  @@index([referenceType, referenceId])
  @@map("catch_weight_readings")
}

/// Tare override per container type used with catch-weight products.
model CatchWeightTare {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  containerLabel  String   @map("container_label")
  tareWeightKg    Decimal  @map("tare_weight_kg") @db.Decimal(10, 4)
  description     String?
  active          Boolean  @default(true)

  @@unique([tenantId, containerLabel])
  @@index([tenantId])
  @@map("catch_weight_tares")
}

/// Product recall notice issued by manufacturer / regulatory authority.
model ProductRecall {
  id                  String         @id @default(cuid())
  tenantId            String         @map("tenant_id")
  recallNumber        String         @map("recall_number")
  productId           String         @map("product_id")
  recallClass         RecallClass    @map("recall_class")
  status              RecallStatus   @default(DRAFT)
  title               String
  reason              String
  regulatoryRef       String?        @map("regulatory_ref")
  affectedLotNumbers  String[]       @map("affected_lot_numbers")
  affectedSerials     String[]       @map("affected_serials")
  affectedDateFrom    DateTime?      @map("affected_date_from")
  affectedDateTo      DateTime?      @map("affected_date_to")
  actionRequired      RecallActionType @map("action_required")
  issuedAt            DateTime?      @map("issued_at")
  deadlineAt          DateTime?      @map("deadline_at")
  completedAt         DateTime?      @map("completed_at")
  totalUnitsAffected  Int            @default(0) @map("total_units_affected")
  totalUnitsRecovered Int            @default(0) @map("total_units_recovered")
  notifiedAt          DateTime?      @map("notified_at")
  createdBy           String         @map("created_by")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  affectedStock       RecallAffectedStock[]
  customerNotices     RecallCustomerNotice[]
  disposalRecords     RecallDisposalRecord[]

  @@unique([tenantId, recallNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("product_recalls")
}

/// Inventory units identified as affected by a recall.
model RecallAffectedStock {
  id              String        @id @default(cuid())
  tenantId        String        @map("tenant_id")
  recallId        String        @map("recall_id")
  warehouseId     String        @map("warehouse_id")
  locationBin     String?       @map("location_bin")
  lotNumber       String?       @map("lot_number")
  serialNumber    String?       @map("serial_number")
  qtyAffected     Decimal       @map("qty_affected") @db.Decimal(15, 4)
  qtyQuarantined  Decimal       @default(0) @map("qty_quarantined") @db.Decimal(15, 4)
  qtyRecovered    Decimal       @default(0) @map("qty_recovered") @db.Decimal(15, 4)
  quarantinedAt   DateTime?     @map("quarantined_at")

  recall          ProductRecall @relation(fields: [recallId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([recallId])
  @@map("recall_affected_stocks")
}

/// Customer notification record for a recall.
model RecallCustomerNotice {
  id              String        @id @default(cuid())
  tenantId        String        @map("tenant_id")
  recallId        String        @map("recall_id")
  customerId      String        @map("customer_id")
  customerName    String        @map("customer_name")
  contactEmail    String?       @map("contact_email")
  qtyShipped      Decimal       @map("qty_shipped") @db.Decimal(15, 4)
  qtyReturned     Decimal       @default(0) @map("qty_returned") @db.Decimal(15, 4)
  noticeSentAt    DateTime?     @map("notice_sent_at")
  acknowledgedAt  DateTime?     @map("acknowledged_at")
  notes           String?

  recall          ProductRecall @relation(fields: [recallId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([recallId])
  @@map("recall_customer_notices")
}

/// Disposal / destruction / rework record for recalled units.
model RecallDisposalRecord {
  id              String        @id @default(cuid())
  tenantId        String        @map("tenant_id")
  recallId        String        @map("recall_id")
  actionType      RecallActionType @map("action_type")
  qtyProcessed    Decimal       @map("qty_processed") @db.Decimal(15, 4)
  disposalMethod  String?       @map("disposal_method")
  authorizedBy    String        @map("authorized_by")
  processedAt     DateTime      @default(now()) @map("processed_at")
  certificateRef  String?       @map("certificate_ref")
  notes           String?

  recall          ProductRecall @relation(fields: [recallId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([recallId])
  @@map("recall_disposal_records")
}


// ════════════════════════════════════════════════
// INVENTORY CYCLE 30 — PACKAGING SPECS & GS1
// ════════════════════════════════════════════════

enum PackagingLevel {
  EACH
  INNER
  CASE
  MASTER_CARTON
  PALLET
}

enum BarcodeSymbology {
  EAN13
  EAN8
  UPC_A
  UPC_E
  CODE128
  CODE39
  ITF14
  GS1_128
  DATA_MATRIX
  QR_CODE
  GS1_DATAMATRIX
}

enum LabelTemplateType {
  ITEM
  INNER
  CASE
  PALLET
  SHIPPING
  COMPLIANCE
}

/// Packaging specification per item — defines hierarchy and physical attributes at each level.
model PackagingSpec {
  id                String          @id @default(cuid())
  tenantId          String          @map("tenant_id")
  productId         String          @map("product_id")
  level             PackagingLevel
  unitsPerLevel     Int             @map("units_per_level")
  lengthMm          Decimal?        @map("length_mm") @db.Decimal(10, 2)
  widthMm           Decimal?        @map("width_mm") @db.Decimal(10, 2)
  heightMm          Decimal?        @map("height_mm") @db.Decimal(10, 2)
  grossWeightKg     Decimal?        @map("gross_weight_kg") @db.Decimal(10, 4)
  netWeightKg       Decimal?        @map("net_weight_kg") @db.Decimal(10, 4)
  cubicMetre        Decimal?        @map("cubic_metre") @db.Decimal(10, 6)
  stackable         Boolean         @default(true)
  maxStackLayers    Int?            @map("max_stack_layers")
  description       String?
  active            Boolean         @default(true)
  effectiveFrom     DateTime?       @map("effective_from")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  barcodes          ItemBarcode[]
  labelAssignments  LabelAssignment[]

  @@unique([tenantId, productId, level])
  @@index([tenantId])
  @@index([tenantId, productId])
  @@map("packaging_specs")
}

/// Barcode / GTIN / SSCC assigned to a packaging level.
model ItemBarcode {
  id              String           @id @default(cuid())
  tenantId        String           @map("tenant_id")
  packagingSpecId String           @map("packaging_spec_id")
  symbology       BarcodeSymbology
  barcodeValue    String           @map("barcode_value")
  gtin14          String?          @map("gtin_14")
  gs1CompanyPrefix String?         @map("gs1_company_prefix")
  isPrimary       Boolean          @default(false) @map("is_primary")
  active          Boolean          @default(true)
  createdAt       DateTime         @default(now()) @map("created_at")

  packagingSpec   PackagingSpec    @relation(fields: [packagingSpecId], references: [id], onDelete: Cascade)

  @@unique([tenantId, barcodeValue])
  @@index([tenantId])
  @@index([packagingSpecId])
  @@map("item_barcodes")
}

/// GS1 application identifier definition (reference table).
model Gs1ApplicationIdentifier {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  ai              String
  title           String
  dataFormat      String   @map("data_format")
  fnc1Required    Boolean  @default(false) @map("fnc1_required")
  maxLength       Int?     @map("max_length")
  description     String?

  @@unique([tenantId, ai])
  @@index([tenantId])
  @@map("gs1_application_identifiers")
}

/// Label template definition for a packaging level.
model LabelTemplate {
  id              String            @id @default(cuid())
  tenantId        String            @map("tenant_id")
  name            String
  templateType    LabelTemplateType @map("template_type")
  widthMm         Decimal           @map("width_mm") @db.Decimal(8, 2)
  heightMm        Decimal           @map("height_mm") @db.Decimal(8, 2)
  content         String
  version         Int               @default(1)
  active          Boolean           @default(true)
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  assignments     LabelAssignment[]

  @@unique([tenantId, name, version])
  @@index([tenantId])
  @@map("label_templates")
}

/// Assignment of a label template to a packaging spec (per-customer or default).
model LabelAssignment {
  id                String        @id @default(cuid())
  tenantId          String        @map("tenant_id")
  packagingSpecId   String        @map("packaging_spec_id")
  templateId        String        @map("template_id")
  customerId        String?       @map("customer_id")
  isDefault         Boolean       @default(false) @map("is_default")
  createdAt         DateTime      @default(now()) @map("created_at")

  packagingSpec     PackagingSpec @relation(fields: [packagingSpecId], references: [id], onDelete: Cascade)
  template          LabelTemplate @relation(fields: [templateId], references: [id])

  @@index([tenantId])
  @@index([packagingSpecId])
  @@map("label_assignments")
}

/// SSCC (Serial Shipping Container Code) registry.
model SsccRecord {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  sscc            String
  extensionDigit  Int      @map("extension_digit")
  gs1CompanyPrefix String  @map("gs1_company_prefix")
  serialRef       String   @map("serial_ref")
  allocatedAt     DateTime @default(now()) @map("allocated_at")
  usedAt          DateTime? @map("used_at")
  shipmentRef     String?  @map("shipment_ref")

  @@unique([tenantId, sscc])
  @@index([tenantId])
  @@map("sscc_records")
}

// ─── Inventory Cycle 31: Cold Chain & Inventory Write-Off Management ─────────

enum TemperatureUnit {
  CELSIUS
  FAHRENHEIT
}

enum ExcursionSeverity {
  MINOR
  MODERATE
  CRITICAL
}

enum ExcursionStatus {
  OPEN
  UNDER_REVIEW
  QUARANTINED
  RELEASED
  DISPOSED
}

enum WriteDownStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  WRITTEN_DOWN
}

enum WriteOffStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  COMPLETED
}

/// Cold-chain storage requirements for a product.
model ColdChainRequirement {
  id              String          @id @default(cuid())
  tenantId        String          @map("tenant_id")
  productId       String          @map("product_id")
  minTempCelsius  Decimal         @map("min_temp_celsius")
  maxTempCelsius  Decimal         @map("max_temp_celsius")
  minHumidityPct  Decimal?        @map("min_humidity_pct")
  maxHumidityPct  Decimal?        @map("max_humidity_pct")
  maxExcursionMins Int?           @map("max_excursion_mins")
  specialHandling String?         @map("special_handling")
  active          Boolean         @default(true)
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  excursions      TemperatureExcursion[]

  @@unique([tenantId, productId])
  @@index([tenantId])
  @@map("cold_chain_requirements")
}

/// Logged temperature/humidity excursion event.
model TemperatureExcursion {
  id                String            @id @default(cuid())
  tenantId          String            @map("tenant_id")
  requirementId     String            @map("requirement_id")
  warehouseId       String            @map("warehouse_id")
  batchId           String?           @map("batch_id")
  recordedTempC     Decimal           @map("recorded_temp_c")
  recordedHumidityPct Decimal?        @map("recorded_humidity_pct")
  excursionStartAt  DateTime          @map("excursion_start_at")
  excursionEndAt    DateTime?         @map("excursion_end_at")
  durationMins      Int?              @map("duration_mins")
  severity          ExcursionSeverity
  status            ExcursionStatus   @default(OPEN)
  loggedById        String            @map("logged_by_id")
  reviewedById      String?           @map("reviewed_by_id")
  dispositionNotes  String?           @map("disposition_notes")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  requirement       ColdChainRequirement @relation(fields: [requirementId], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, warehouseId])
  @@map("temperature_excursions")
}

/// Request to write down the book value of aged or damaged stock.
model StockWriteDownRequest {
  id              String          @id @default(cuid())
  tenantId        String          @map("tenant_id")
  requestNumber   String          @map("request_number")
  warehouseId     String          @map("warehouse_id")
  productId       String          @map("product_id")
  batchId         String?         @map("batch_id")
  quantity        Decimal
  originalValuePerUnit Decimal    @map("original_value_per_unit")
  proposedValuePerUnit Decimal    @map("proposed_value_per_unit")
  writeDownReason String          @map("write_down_reason")
  status          WriteDownStatus @default(DRAFT)
  requestedById   String          @map("requested_by_id")
  approvedById    String?         @map("approved_by_id")
  approvedAt      DateTime?       @map("approved_at")
  rejectionNotes  String?         @map("rejection_notes")
  appliedAt       DateTime?       @map("applied_at")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  @@unique([tenantId, requestNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("stock_write_down_requests")
}

/// Write-off record for stock that has been disposed of (destroyed, donated, scrapped).
model StockWriteOffRecord {
  id              String         @id @default(cuid())
  tenantId        String         @map("tenant_id")
  writeOffNumber  String         @map("write_off_number")
  warehouseId     String         @map("warehouse_id")
  productId       String         @map("product_id")
  batchId         String?        @map("batch_id")
  quantity        Decimal
  bookValuePerUnit Decimal       @map("book_value_per_unit")
  totalWriteOff   Decimal        @map("total_write_off")
  disposalMethod  String         @map("disposal_method")
  writeOffReason  String         @map("write_off_reason")
  status          WriteOffStatus @default(DRAFT)
  requestedById   String         @map("requested_by_id")
  approvedById    String?        @map("approved_by_id")
  approvedAt      DateTime?      @map("approved_at")
  completedAt     DateTime?      @map("completed_at")
  rejectionNotes  String?        @map("rejection_notes")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  @@unique([tenantId, writeOffNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("stock_write_off_records")
}

// ─── Inventory Cycle 32 — Velocity Classification & ABC-XYZ Analysis ──────────

enum AbcClass {
  A // top ~20% of products driving ~80% of value
  B // middle tier
  C // bottom tier — low value/volume
}

enum XyzClass {
  X // highly stable demand (low CV)
  Y // moderate variability
  Z // highly erratic / unpredictable
}

enum VelocityClassificationStatus {
  DRAFT
  ACTIVE
  SUPERSEDED
}

/// Periodic ABC-XYZ classification run for a tenant's product catalog
model VelocityClassificationRun {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  runNumber       String   @map("run_number")    // VCR-000001
  warehouseId     String?  @map("warehouse_id")  // null = all warehouses
  periodStart     DateTime @map("period_start")
  periodEnd       DateTime @map("period_end")
  status          VelocityClassificationStatus @default(DRAFT)
  totalProducts   Int      @default(0) @map("total_products")
  classACount     Int      @default(0) @map("class_a_count")
  classBCount     Int      @default(0) @map("class_b_count")
  classCCount     Int      @default(0) @map("class_c_count")
  classXCount     Int      @default(0) @map("class_x_count")
  classYCount     Int      @default(0) @map("class_y_count")
  classZCount     Int      @default(0) @map("class_z_count")
  notes           String?
  runByUserId     String   @map("run_by_user_id")
  activatedAt     DateTime? @map("activated_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  items VelocityClassificationItem[]

  @@unique([tenantId, runNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("velocity_classification_runs")
}

/// Per-product result within a classification run
model VelocityClassificationItem {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  runId           String   @map("run_id")
  productId       String   @map("product_id")
  warehouseId     String?  @map("warehouse_id")
  totalRevenue    Decimal  @default(0) @map("total_revenue") @db.Decimal(18, 4)
  totalQuantitySold Decimal @default(0) @map("total_quantity_sold") @db.Decimal(18, 4)
  revenueShare    Decimal  @default(0) @map("revenue_share") @db.Decimal(8, 6) // 0-1
  cumulativeShare Decimal  @default(0) @map("cumulative_share") @db.Decimal(8, 6)
  demandCv        Decimal? @map("demand_cv") @db.Decimal(8, 4)  // coefficient of variation
  avgMonthlyDemand Decimal? @map("avg_monthly_demand") @db.Decimal(18, 4)
  stdDevDemand    Decimal? @map("std_dev_demand") @db.Decimal(18, 4)
  abcClass        AbcClass @map("abc_class")
  xyzClass        XyzClass @map("xyz_class")
  combinedClass   String   @map("combined_class") // e.g. "AX", "BZ"
  createdAt       DateTime @default(now()) @map("created_at")

  run VelocityClassificationRun @relation(fields: [runId], references: [id])

  @@unique([runId, productId, warehouseId])
  @@index([tenantId])
  @@index([tenantId, runId])
  @@index([tenantId, productId])
  @@index([tenantId, abcClass])
  @@index([tenantId, combinedClass])
  @@map("velocity_classification_items")
}

/// Reorder and stocking policy recommendations derived from ABC-XYZ class
model VelocitySlottingPolicy {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  combinedClass   String   @map("combined_class")  // "AX", "AY", etc.
  description     String?
  reviewFrequency String   @map("review_frequency") // e.g. "DAILY", "WEEKLY", "MONTHLY"
  reorderMethod   String   @map("reorder_method")   // "CONTINUOUS", "PERIODIC", "MANUAL"
  safetyStockMultiplier Decimal @default(1) @map("safety_stock_multiplier") @db.Decimal(5, 2)
  preferredZone   String?  @map("preferred_zone")   // warehouse zone code
  active          Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, combinedClass])
  @@index([tenantId])
  @@map("velocity_slotting_policies")
}

/// Trend snapshot — monthly velocity metrics per product for sparkline / trend analysis
model ProductVelocitySnapshot {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  productId       String   @map("product_id")
  warehouseId     String?  @map("warehouse_id")
  snapshotMonth   DateTime @map("snapshot_month")   // first day of month
  quantitySold    Decimal  @default(0) @map("quantity_sold") @db.Decimal(18, 4)
  revenue         Decimal  @default(0) @map("revenue") @db.Decimal(18, 4)
  transactionCount Int     @default(0) @map("transaction_count")
  avgSellingPrice Decimal? @map("avg_selling_price") @db.Decimal(18, 4)
  abcClass        AbcClass? @map("abc_class")
  xyzClass        XyzClass? @map("xyz_class")
  createdAt       DateTime @default(now()) @map("created_at")

  @@unique([tenantId, productId, warehouseId, snapshotMonth])
  @@index([tenantId])
  @@index([tenantId, productId])
  @@index([tenantId, snapshotMonth])
  @@map("product_velocity_snapshots")
}

// ─── Inventory Cycle 33 — Customer Returns & Reverse Logistics ────────────────

enum RmaStatus {
  REQUESTED
  APPROVED
  REJECTED
  RECEIVED
  INSPECTED
  CLOSED
}

enum ReturnDisposition {
  RESTOCK          // goes back to inventory
  REFURBISH        // needs repair/rework before restock
  SCRAP            // destroy / write off
  RETURN_TO_VENDOR // send back to supplier
  QUARANTINE       // hold for QA decision
}

enum ReturnCreditStatus {
  PENDING
  ISSUED
  VOIDED
}

/// Customer Return Merchandise Authorization
model CustomerRma {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  rmaNumber       String    @map("rma_number")          // RMA-000001
  customerId      String    @map("customer_id")
  salesOrderId    String?   @map("sales_order_id")
  status          RmaStatus @default(REQUESTED)
  returnReason    String    @map("return_reason")
  customerNotes   String?   @map("customer_notes")
  requestedById   String    @map("requested_by_id")
  approvedById    String?   @map("approved_by_id")
  approvedAt      DateTime? @map("approved_at")
  rejectedById    String?   @map("rejected_by_id")
  rejectionReason String?   @map("rejection_reason")
  receivedAt      DateTime? @map("received_at")
  warehouseId     String?   @map("warehouse_id")
  expiresAt       DateTime? @map("expires_at")          // RMA validity window
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  lines  CustomerRmaLine[]
  credit ReturnCredit?

  @@unique([tenantId, rmaNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, customerId])
  @@map("customer_rmas")
}

/// Line items on a customer RMA
model CustomerRmaLine {
  id              String            @id @default(cuid())
  tenantId        String            @map("tenant_id")
  rmaId           String            @map("rma_id")
  productId       String            @map("product_id")
  lotNumber       String?           @map("lot_number")
  serialNumber    String?           @map("serial_number")
  quantityRequested Decimal         @map("quantity_requested") @db.Decimal(18, 4)
  quantityReceived  Decimal         @default(0) @map("quantity_received") @db.Decimal(18, 4)
  unitCost        Decimal?          @map("unit_cost") @db.Decimal(18, 4)
  disposition     ReturnDisposition? @map("disposition")
  inspectionNotes String?           @map("inspection_notes")
  inspectedById   String?           @map("inspected_by_id")
  inspectedAt     DateTime?         @map("inspected_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  rma CustomerRma @relation(fields: [rmaId], references: [id])

  @@index([tenantId])
  @@index([tenantId, rmaId])
  @@index([tenantId, productId])
  @@map("customer_rma_lines")
}

/// Credit memo issued to customer after return
model ReturnCredit {
  id              String             @id @default(cuid())
  tenantId        String             @map("tenant_id")
  creditNumber    String             @map("credit_number")   // CRM-000001
  rmaId           String             @unique @map("rma_id")
  customerId      String             @map("customer_id")
  creditAmount    Decimal            @map("credit_amount") @db.Decimal(18, 4)
  currency        String             @default("USD")
  status          ReturnCreditStatus @default(PENDING)
  issuedById      String?            @map("issued_by_id")
  issuedAt        DateTime?          @map("issued_at")
  voidedById      String?            @map("voided_by_id")
  voidReason      String?            @map("void_reason")
  notes           String?
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  rma CustomerRma @relation(fields: [rmaId], references: [id])

  @@unique([tenantId, creditNumber])
  @@index([tenantId])
  @@index([tenantId, customerId])
  @@index([tenantId, status])
  @@map("return_credits")
}

/// Tracks restocking of returned items back into warehouse bins
model ReturnRestock {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  rmaLineId       String   @map("rma_line_id")
  productId       String   @map("product_id")
  warehouseId     String   @map("warehouse_id")
  binLocationId   String?  @map("bin_location_id")
  quantityRestocked Decimal @map("quantity_restocked") @db.Decimal(18, 4)
  restockedById   String   @map("restocked_by_id")
  restockedAt     DateTime @default(now()) @map("restocked_at")
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([tenantId, rmaLineId])
  @@index([tenantId, productId])
  @@map("return_restocks")
}

// ─── Inventory Cycle 34 — Min-Max Replenishment Planning ─────────────────────

enum ReplenishmentMethod {
  PURCHASE_ORDER    // order from supplier
  TRANSFER          // transfer from another warehouse
  PRODUCTION        // manufacturing order
}

enum ReplenSuggestionStatus {
  OPEN
  APPROVED
  ORDERED
  RECEIVED
  CANCELLED
}

/// Per-product min/max stock level configuration per warehouse
model MinMaxLevel {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  productId       String   @map("product_id")
  warehouseId     String   @map("warehouse_id")
  minQty          Decimal  @map("min_qty") @db.Decimal(18, 4)       // reorder point
  maxQty          Decimal  @map("max_qty") @db.Decimal(18, 4)       // order-up-to level
  reorderQty      Decimal? @map("reorder_qty") @db.Decimal(18, 4)   // fixed order qty override
  method          ReplenishmentMethod @default(PURCHASE_ORDER)
  preferredVendorId String? @map("preferred_vendor_id")
  leadTimeDays    Int      @default(0) @map("lead_time_days")
  active          Boolean  @default(true)
  notes           String?
  updatedById     String   @map("updated_by_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  suggestions ReplenSuggestion[]

  @@unique([tenantId, productId, warehouseId])
  @@index([tenantId])
  @@index([tenantId, warehouseId])
  @@index([tenantId, productId])
  @@map("min_max_levels")
}

/// Auto-generated replenishment suggestion when stock falls below min
model ReplenSuggestion {
  id              String                @id @default(cuid())
  tenantId        String                @map("tenant_id")
  suggestionNumber String               @map("suggestion_number")  // RS-000001
  levelId         String                @map("level_id")
  productId       String                @map("product_id")
  warehouseId     String                @map("warehouse_id")
  currentStock    Decimal               @map("current_stock") @db.Decimal(18, 4)
  suggestedQty    Decimal               @map("suggested_qty") @db.Decimal(18, 4)
  method          ReplenishmentMethod
  vendorId        String?               @map("vendor_id")
  sourceWarehouseId String?             @map("source_warehouse_id")
  neededByDate    DateTime?             @map("needed_by_date")
  status          ReplenSuggestionStatus @default(OPEN)
  approvedById    String?               @map("approved_by_id")
  approvedAt      DateTime?             @map("approved_at")
  orderedAt       DateTime?             @map("ordered_at")
  receivedAt      DateTime?             @map("received_at")
  cancelledById   String?               @map("cancelled_by_id")
  cancellationReason String?            @map("cancellation_reason")
  notes           String?
  generatedAt     DateTime              @default(now()) @map("generated_at")
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")

  level MinMaxLevel @relation(fields: [levelId], references: [id])

  @@unique([tenantId, suggestionNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, productId])
  @@index([tenantId, warehouseId])
  @@map("replen_suggestions")
}

/// Log of replenishment run executions (scan all min/max levels and generate suggestions)
model ReplenRunLog {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  runNumber       String   @map("run_number")    // RRL-000001
  warehouseId     String?  @map("warehouse_id")  // null = all
  levelsScanned   Int      @default(0) @map("levels_scanned")
  suggestionsCreated Int   @default(0) @map("suggestions_created")
  triggeredById   String   @map("triggered_by_id")
  completedAt     DateTime? @map("completed_at")
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")

  @@unique([tenantId, runNumber])
  @@index([tenantId])
  @@map("replen_run_logs")
}

// ─── Inventory Cycle 35 — Freight Claims & Cargo Damage Reporting ─────────────

enum DamageReportStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  CLAIM_FILED
  RESOLVED
  CLOSED
}

enum DamageSeverity {
  MINOR      // cosmetic / partial damage; item still usable
  MODERATE   // partial loss; item degraded but repairable
  SEVERE     // item total loss
}

enum FreightClaimType {
  DAMAGE          // physical damage to cargo
  SHORTAGE        // quantity short-delivered
  LOSS            // cargo lost in transit
  DELAY           // time-sensitive cargo delayed
  CONCEALED       // damage discovered after delivery
}

enum FreightClaimStatus {
  DRAFT
  FILED
  ACKNOWLEDGED
  UNDER_INVESTIGATION
  SETTLEMENT_OFFERED
  ACCEPTED
  REJECTED
  CLOSED
}

/// Damage report created on receipt of a shipment
model CargoDamageReport {
  id              String             @id @default(cuid())
  tenantId        String             @map("tenant_id")
  reportNumber    String             @map("report_number")    // CDR-000001
  shipmentId      String?            @map("shipment_id")
  purchaseOrderId String?            @map("purchase_order_id")
  carrierId       String?            @map("carrier_id")
  warehouseId     String?            @map("warehouse_id")
  reportedById    String             @map("reported_by_id")
  discoveredAt    DateTime           @map("discovered_at")
  severity        DamageSeverity     @default(MINOR)
  status          DamageReportStatus @default(DRAFT)
  description     String
  affectedSkus    String?            @map("affected_skus")    // CSV of product IDs
  quantityDamaged Decimal?           @map("quantity_damaged") @db.Decimal(18, 4)
  estimatedLoss   Decimal?           @map("estimated_loss") @db.Decimal(18, 4)
  currency        String             @default("USD")
  photoUrls       String?            @map("photo_urls")       // CSV of URLs
  notes           String?
  reviewedById    String?            @map("reviewed_by_id")
  reviewedAt      DateTime?          @map("reviewed_at")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  claim FreightClaim?

  @@unique([tenantId, reportNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, carrierId])
  @@map("cargo_damage_reports")
}

/// Freight claim filed against a carrier
model FreightClaim {
  id              String             @id @default(cuid())
  tenantId        String             @map("tenant_id")
  claimNumber     String             @map("claim_number")     // FC-000001
  damageReportId  String             @unique @map("damage_report_id")
  carrierId       String             @map("carrier_id")
  claimType       FreightClaimType
  status          FreightClaimStatus @default(DRAFT)
  claimedAmount   Decimal            @map("claimed_amount") @db.Decimal(18, 4)
  currency        String             @default("USD")
  filedById       String?            @map("filed_by_id")
  filedAt         DateTime?          @map("filed_at")
  carrierRefNumber String?           @map("carrier_ref_number")
  settlementAmount Decimal?          @map("settlement_amount") @db.Decimal(18, 4)
  settlementDate  DateTime?          @map("settlement_date")
  acceptedById    String?            @map("accepted_by_id")
  rejectionReason String?            @map("rejection_reason")
  dueDate         DateTime?          @map("due_date")
  notes           String?
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  damageReport CargoDamageReport @relation(fields: [damageReportId], references: [id])

  @@unique([tenantId, claimNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, carrierId])
  @@index([tenantId, claimType])
  @@map("freight_claims")
}

/// Status updates / correspondence log for a freight claim
model FreightClaimEvent {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  claimId     String   @map("claim_id")
  eventType   String   @map("event_type")   // e.g. "CARRIER_RESPONSE", "DOCUMENT_SUBMITTED"
  description String
  recordedById String  @map("recorded_by_id")
  occurredAt  DateTime @default(now()) @map("occurred_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([tenantId, claimId])
  @@map("freight_claim_events")
}

// ── Vendor-Managed Inventory (Cycle 36) ──────────────────────────────────────

enum VmiAgreementStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  TERMINATED
}

enum VmiReplenTrigger {
  BELOW_MIN
  SCHEDULE
  MANUAL
}

enum VmiOrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  RECEIVED
  CANCELLED
}

model VmiAgreement {
  id              String              @id @default(cuid())
  tenantId        String
  agreementNumber String
  vendorId        String
  warehouseId     String
  productId       String
  status          VmiAgreementStatus  @default(DRAFT)
  replenTrigger   VmiReplenTrigger    @default(BELOW_MIN)
  minQty          Decimal             @db.Decimal(18, 4)
  maxQty          Decimal             @db.Decimal(18, 4)
  targetQty       Decimal             @db.Decimal(18, 4)
  reviewCycleDays Int                 @default(7)
  vendorLeadDays  Int                 @default(3)
  currency        String              @default("USD")
  notes           String?
  activatedAt     DateTime?
  terminatedAt    DateTime?
