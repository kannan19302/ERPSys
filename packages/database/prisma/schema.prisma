// ==========================================
// SUBSCRIPTION BILLING MODULE
// ==========================================

model Subscription {
  id                 String    @id @default(cuid())
  tenantId           String    @map("tenant_id")
  orgId              String    @map("org_id")
  name               String
  description        String?
  customerId         String?   @map("customer_id")
  productId          String?   @map("product_id")
  currency           String    @default("USD")
  unitAmount         Decimal   @map("unit_amount") @db.Decimal(15, 2)
  quantity           Int       @default(1)
  billingPeriod      String    @default("MONTHLY") @map("billing_period") // MONTHLY, QUARTERLY, SEMI_ANNUAL, ANNUAL
  billingCycles      Int?      @map("billing_cycles") // null = infinite
  status             String    @default("ACTIVE") // ACTIVE, PAUSED, CANCELED, EXPIRED, TRIALING
  startDate          DateTime  @map("start_date")
  currentPeriodStart DateTime  @map("current_period_start")
  currentPeriodEnd   DateTime  @map("current_period_end")
  trialEndDate       DateTime? @map("trial_end_date")
  cancelAtPeriodEnd  Boolean   @default(false) @map("cancel_at_period_end")
  canceledAt         DateTime? @map("canceled_at")
  pausedAt           DateTime? @map("paused_at")
  metadata           Json      @default("{}")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  lines    SubscriptionLine[]
  invoices SubscriptionInvoice[]
  usage    SubscriptionUsage[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, customerId])
  @@map("subscriptions")
}

model SubscriptionLine {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  subscriptionId String   @map("subscription_id")
  productId      String?  @map("product_id")
  description    String
  unitAmount     Decimal  @map("unit_amount") @db.Decimal(15, 2)
  quantity       Int      @default(1)
  taxRate        Decimal  @default(0) @map("tax_rate") @db.Decimal(5, 2)
  totalAmount    Decimal  @map("total_amount") @db.Decimal(15, 2)
  createdAt      DateTime @default(now()) @map("created_at")

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([subscriptionId])
  @@map("subscription_lines")
}

model SubscriptionInvoice {
  id             String    @id @default(cuid())
  tenantId       String    @map("tenant_id")
  subscriptionId String    @map("subscription_id")
  invoiceId      String    @map("invoice_id")
  periodStart    DateTime  @map("period_start")
  periodEnd      DateTime  @map("period_end")
  sequenceNumber Int       @map("sequence_number")
  status         String    @default("PENDING") // PENDING, PAID, FAILED
  amount         Decimal   @db.Decimal(15, 2)
  createdAt      DateTime  @default(now()) @map("created_at")
  paidAt         DateTime? @map("paid_at")

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  invoice      Invoice      @relation(fields: [invoiceId], references: [id])

  @@index([tenantId])
  @@index([subscriptionId])
  @@index([tenantId, status])
  @@map("subscription_invoices")
}

model SubscriptionUsage {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  subscriptionId String   @map("subscription_id")
  usageDate      DateTime @map("usage_date")
  metricName     String   @map("metric_name") // e.g. "api_calls", "storage_gb", "seats"
  quantity       Int
  unitAmount     Decimal  @map("unit_amount") @db.Decimal(15, 2)
  totalAmount    Decimal  @map("total_amount") @db.Decimal(15, 2)
  invoiceId      String?  @map("invoice_id")
  createdAt      DateTime @default(now()) @map("created_at")

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([subscriptionId])
  @@index([tenantId, subscriptionId, metricName])
  @@map("subscription_usage")
}

model ConsolidationRun {
