  completedAt     DateTime?      @map("completed_at")
  notes           String?
  createdAt       DateTime       @default(now()) @map("created_at")

  appointment YardAppointment? @relation(fields: [appointmentId], references: [id])

  @@index([tenantId])
  @@index([warehouseId])
  @@index([status])
