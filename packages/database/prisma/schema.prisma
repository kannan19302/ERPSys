// ─────────────────────────────────────────────────
// Prisma Schema — Universal ERP System
// ─────────────────────────────────────────────────
// This is the single source of truth for the database schema.
// All entities follow the patterns defined in .ai/DATA_MODEL.md
// ─────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ════════════════════════════════════════════════
// MULTI-TENANCY & AUTH
// ════════════════════════════════════════════════

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      String   @default("free")
  status    String   @default("ACTIVE")
  settings  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  demoDataLoaded Boolean   @default(false) @map("demo_data_loaded")
  demoLoadedAt   DateTime? @map("demo_loaded_at")

  users           User[]
  organizations   Organization[]
  subscription    TenantSubscription?
  installedApps   InstalledApp[]
  demoDataRecords DemoDataRecord[]
  accessPackages  AccessPackage[]
  ssoConfigs      SsoConfig[]
  userSessions    UserSession[]
  userGroups      UserGroup[]
  ipRestrictions  IpRestriction[]
  fixedAssets            FixedAsset[]
  fixedAssetCategories   FixedAssetCategory[]
  assetDepreciations     AssetDepreciation[]
  assetTransferLogs      AssetTransferLog[]
  assetMaintenanceLogs   AssetMaintenanceLog[]

  @@map("tenants")
}

model User {
  id           String    @id @default(cuid())
  tenantId     String    @map("tenant_id")
  email        String
  passwordHash String?   @map("password_hash")
  firstName    String    @map("first_name")
  lastName     String    @map("last_name")
  avatar       String?
  status       String    @default("ACTIVE")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")
  preferences  Json      @default("{}")

  mfaEnabled   Boolean   @default(false) @map("mfa_enabled")
  mfaSecret    String?   @map("mfa_secret")

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roles            UserRole[]
  userSessions     UserSession[]
  groupMemberships UserGroupMember[]
  passkeys         Passkey[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
  @@map("users")
}

model Passkey {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  credentialID String   @unique @map("credential_id")
  publicKey    String   @map("public_key")
  counter      Int
  transports   String?
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("passkeys")
}

model Role {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  name        String
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  permissions Json     @default("[]")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users          UserRole[]
  accessPackages RoleAccessPackage[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("roles")
}

model UserRole {
  userId     String   @map("user_id")
  roleId     String   @map("role_id")
  assignedAt DateTime @default(now()) @map("assigned_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

// ════════════════════════════════════════════════
// ORGANIZATION STRUCTURE
// ════════════════════════════════════════════════

model Organization {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  name            String
  legalName       String?  @map("legal_name")
  taxId           String?  @map("tax_id")
  email           String?
  phone           String?
  website         String?
  logo            String?
  address         Json?
  currency        String   @default("USD")
  timezone        String   @default("UTC")
  fiscalYearStart Int      @default(1) @map("fiscal_year_start")
  settings        Json     @default("{}")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant                    Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  departments               Department[]
  customers                 Customer[]
  vendors                   Vendor[]
  products                  Product[]
  warehouses                Warehouse[]
  creditNotes               CreditNote[]
  debitNotes                DebitNote[]
  dunningLevels             DunningLevel[]
  dunningRuns               DunningRun[]
  paymentSchedules          PaymentSchedule[]
  paymentRuns               PaymentRun[]
  budgets                   Budget[]
  forecastScenarios         ForecastScenario[]
  taxRules                  TaxRule[]
  withholdingTaxes          WithholdingTax[]
  taxFilings                TaxFiling[]
  outgoingTransfers         InterCompanyTransfer[]     @relation("FromOrganization")
  incomingTransfers         InterCompanyTransfer[]     @relation("ToOrganization")
  investmentPortfolios      InvestmentPortfolio[]
  treasuryTransactions      TreasuryTransaction[]
  rfqs                      RFQ[]
  supplierQuotations        SupplierQuotation[]
  campaigns                 Campaign[]
  salesReturns              SalesReturn[]
  purchaseReturns           PurchaseReturn[]
  purchaseRequisitions      PurchaseRequisition[]
  blanketPurchaseAgreements BlanketPurchaseAgreement[]
  cases                     Case[]
  salesChannels             SalesChannel[]
  accountingBooks           AccountingBook[]

  @@index([tenantId])
  @@map("organizations")
}

model Department {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  orgId     String   @map("org_id")
  name      String
  code      String
  parentId  String?  @map("parent_id")
  managerId String?  @map("manager_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization         Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  parent               Department?           @relation("DeptHierarchy", fields: [parentId], references: [id])
  children             Department[]          @relation("DeptHierarchy")
  employees            Employee[]
  journalEntries       JournalEntry[]
  positions            Position[]
  purchaseRequisitions PurchaseRequisition[]

  @@unique([tenantId, orgId, code])
  @@index([tenantId])
  @@map("departments")
}

// ════════════════════════════════════════════════
// HR MODULE
// ════════════════════════════════════════════════

model Employee {
  id             String    @id @default(cuid())
  tenantId       String    @map("tenant_id")
  orgId          String    @map("org_id")
  userId         String?   @map("user_id")
  departmentId   String?   @map("department_id")
  employeeCode   String    @map("employee_code")
  firstName      String    @map("first_name")
  lastName       String    @map("last_name")
  email          String
  phone          String?
  designation    String?
  dateOfBirth    DateTime? @map("date_of_birth")
  dateOfJoining  DateTime  @map("date_of_joining")
  dateOfLeaving  DateTime? @map("date_of_leaving")
  employmentType String    @default("FULL_TIME") @map("employment_type")
  status         String    @default("ACTIVE")
  address        Json?
  bankDetails    Json?     @map("bank_details")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  department          Department?          @relation(fields: [departmentId], references: [id])
  practitioners       Practitioner[]
  trainingEnrollments TrainingEnrollment[]
  fixedAssets         FixedAsset[]

  @@unique([tenantId, orgId, employeeCode])
  @@index([tenantId])
  @@map("employees")
}

// ════════════════════════════════════════════════
// CRM MODULE
// ════════════════════════════════════════════════

model Customer {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  orgId           String    @map("org_id")
  type            String    @default("COMPANY")
  name            String
  email           String?
  phone           String?
  taxId           String?   @map("tax_id")
  billingAddress  Json?     @map("billing_address")
  shippingAddress Json?     @map("shipping_address")
  creditLimit     Decimal?  @map("credit_limit") @db.Decimal(15, 2)
  paymentTerms    Int       @default(30) @map("payment_terms")
  status          String    @default("ACTIVE")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  organization  Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  invoices      Invoice[]
  quotations    Quotation[]
  salesOrders   SalesOrder[]
  creditNotes   CreditNote[]
  contacts      Contact[] // Added for inverse relation
  opportunities Opportunity[] // Added for inverse relation
  activities    Activity[] // Added for inverse relation
  salesReturns  SalesReturn[]
  projects      Project[]
  cases         Case[]

  @@index([tenantId])
  @@index([tenantId, orgId])
  @@map("customers")
}

model Vendor {
  id           String    @id @default(cuid())
  tenantId     String    @map("tenant_id")
  orgId        String    @map("org_id")
  type         String    @default("COMPANY")
  name         String
  email        String?
  phone        String?
  taxId        String?   @map("tax_id")
  address      Json?
  paymentTerms Int       @default(30) @map("payment_terms")
  status       String    @default("ACTIVE")
  notes        String?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  organization              Organization               @relation(fields: [orgId], references: [id], onDelete: Cascade)
  purchaseOrders            PurchaseOrder[]
  debitNotes                DebitNote[]
  paymentSchedules          PaymentSchedule[]
  supplierQuotations        SupplierQuotation[]
  purchaseReturns           PurchaseReturn[]
  subcontractingOrders      SubcontractingOrder[]
  blanketPurchaseAgreements BlanketPurchaseAgreement[]
  portalUsers               VendorPortalUser[]
  auctionBids               RFQAuctionBid[]

  @@index([tenantId])
  @@map("vendors")
}

model Contact {
  id         String    @id @default(cuid())
  tenantId   String    @map("tenant_id")
  orgId      String    @map("org_id")
  customerId String?   @map("customer_id")
  salutation String?
  firstName  String    @map("first_name")
  lastName   String    @map("last_name")
  email      String?
  phone      String?
  mobile     String?
  title      String?
  department String?
  isPrimary  Boolean   @default(false) @map("is_primary")
  isActive   Boolean   @default(true) @map("is_active")
  score      Int       @default(0)
  notes      String?
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  customer   Customer?        @relation(fields: [customerId], references: [id])
  activities Activity[]
  tags       ContactTagLink[]
  cases      Case[]

  @@unique([tenantId, orgId, email])
  @@index([tenantId])
  @@index([customerId])
  @@map("contacts")
}

model LeadSource {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  leads Lead[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("lead_sources")
}

model Lead {
  id                     String    @id @default(cuid())
  tenantId               String    @map("tenant_id")
  orgId                  String    @map("org_id")
  salutation             String?
  firstName              String    @map("first_name")
  lastName               String    @map("last_name")
  company                String?
  title                  String?
  email                  String?
  phone                  String?
  mobile                 String?
  website                String?
  sourceId               String?   @map("source_id")
  status                 String    @default("NEW") // NEW, CONTACTED, QUALIFIED, DISQUALIFIED, CONVERTED
  industry               String?
  employeeCount          Int?      @map("employee_count")
  annualRevenue          Decimal?  @map("annual_revenue") @db.Decimal(15, 2)
  score                  Int       @default(0)
  notes                  String?
  assignedToId           String?   @map("assigned_to_id")
  convertedCustomerId    String?   @map("converted_customer_id")
  convertedOpportunityId String?   @map("converted_opportunity_id")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")
  deletedAt              DateTime? @map("deleted_at")

  campaignId String? @map("campaign_id")

  source        LeadSource?   @relation(fields: [sourceId], references: [id])
  campaign      Campaign?     @relation(fields: [campaignId], references: [id])
  activities    Activity[]
  opportunities Opportunity[] @relation("LeadOpportunity")

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([campaignId])
  @@index([assignedToId])
  @@map("leads")
}

model SalesPipeline {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  name      String
  stages    Json     @default("[]") // Array of {label, probability, order}
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  opportunities  Opportunity[]
  stageConfigs   PipelineStage[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("sales_pipelines")
}

model Opportunity {
  id                String    @id @default(cuid())
  tenantId          String    @map("tenant_id")
  orgId             String    @map("org_id")
  name              String
  customerId        String?   @map("customer_id")
  leadId            String?   @map("lead_id")
  pipelineId        String?   @map("pipeline_id")
  stage             String    @default("PROSPECTING") // Prospecting, Qualification, Proposal, Negotiation, Closed Won, Closed Lost
  amount            Decimal?  @db.Decimal(15, 2)
  probability       Int       @default(0) // 0-100
  expectedCloseDate DateTime? @map("expected_close_date")
  actualCloseDate   DateTime? @map("actual_close_date")
  competitor        String?
  lossReason        String?   @map("loss_reason")
  notes             String?
  assignedToId      String?   @map("assigned_to_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  currency       String    @default("USD")
  weightedAmount Decimal?  @map("weighted_amount") @db.Decimal(15, 2)
  stageEnteredAt DateTime? @map("stage_entered_at")

  customer   Customer?             @relation(fields: [customerId], references: [id])
  lead       Lead?                 @relation("LeadOpportunity", fields: [leadId], references: [id])
  pipeline   SalesPipeline?        @relation(fields: [pipelineId], references: [id])
  activities Activity[]
  lineItems  OpportunityLineItem[]

  @@index([tenantId])
  @@index([tenantId, stage])
  @@index([tenantId, pipelineId])
  @@index([customerId])
  @@map("opportunities")
}

model Activity {
  id            String    @id @default(cuid())
  tenantId      String    @map("tenant_id")
  orgId         String    @map("org_id")
  type          String // CALL, EMAIL, MEETING, NOTE, TASK, QUOTE_SENT, ORDER_PLACED
  subject       String
  description   String?
  leadId        String?   @map("lead_id")
  opportunityId String?   @map("opportunity_id")
  customerId    String?   @map("customer_id")
  contactId     String?   @map("contact_id")
  dueDate       DateTime? @map("due_date")
  completedAt   DateTime? @map("completed_at")
  assignedToId  String?   @map("assigned_to_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  lead        Lead?        @relation(fields: [leadId], references: [id])
  opportunity Opportunity? @relation(fields: [opportunityId], references: [id])
  customer    Customer?    @relation(fields: [customerId], references: [id])
  contact     Contact?     @relation(fields: [contactId], references: [id])

  @@index([tenantId])
  @@index([leadId])
  @@index([opportunityId])
  @@index([customerId])
  @@map("activities")
}

model EmailTemplate {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  name      String
  category  String   @default("GENERAL") // GENERAL, QUOTATION, INVOICE, FOLLOWUP
  subject   String
  body      String
  variables Json     @default("[]") // Available variable names
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("email_templates")
}

// ════════════════════════════════════════════════
// INVENTORY MODULE
// ════════════════════════════════════════════════

model Product {
  id                String    @id @default(cuid())
  tenantId          String    @map("tenant_id")
  orgId             String    @map("org_id")
  categoryId        String?   @map("category_id")
  sku               String
  barcode           String?
  name              String
  description       String?
  type              String    @default("GOODS") // GOODS, SERVICE, CONSUMABLE, RAW_MATERIAL, FINISHED_GOOD, SEMI_FINISHED, ASSET
  category          String?
  brand             String?
  manufacturer      String?
  unit              String    @default("EACH")
  costPrice         Decimal   @map("cost_price") @db.Decimal(15, 2)
  sellPrice         Decimal   @map("sell_price") @db.Decimal(15, 2)
  taxCategory       String?   @map("tax_category")
  isActive          Boolean   @default(true) @map("is_active")
  hasSerialTracking Boolean   @default(false) @map("has_serial_tracking")
  hasBatchTracking  Boolean   @default(false) @map("has_batch_tracking")
  costingMethod     String    @default("AVERAGE") @map("costing_method")
  minOrderQty       Decimal?  @map("min_order_qty") @db.Decimal(15, 3)
  maxOrderQty       Decimal?  @map("max_order_qty") @db.Decimal(15, 3)
  leadTimeDays      Int       @default(0) @map("lead_time_days")
  weight            Decimal?  @db.Decimal(10, 3)
  weightUnit        String    @default("KG") @map("weight_unit")
  dimensions        Json?     @default("{}")
  images            Json      @default("[]")
  attributes        Json      @default("{}")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  organization                  Organization                    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  productCategory               ProductCategory?                @relation("ProductCategory", fields: [categoryId], references: [id])
  inventoryItems                InventoryItem[]
  invoiceLines                  InvoiceLineItem[]
  purchaseOrderItems            PurchaseOrderItem[]
  salesOrderItems               SalesOrderItem[]
  serialNumbers                 SerialNumber[]
  batches                       Batch[]
  stockLedgerEntries            StockLedgerEntry[]
  stockEntryItems               StockEntryItem[]
  qualityInspections            QualityInspection[]
  cycleCountItems               CycleCountItem[]
  rfqItems                      RFQItem[]
  supplierQuotationItems        SupplierQuotationItem[]
  salesReturnItems              SalesReturnItem[]
  purchaseReturnItems           PurchaseReturnItem[]
  mrpPlannedItems               MRPPlannedItem[]
  subcontractingOrders          SubcontractingOrder[]
  ncrRecords                    NonConformanceReport[]
  opportunityLineItems          OpportunityLineItem[]
  priceBookEntries              PriceBookEntry[]
  variants                      ProductVariant[]
  inventoryItemBins             InventoryItemBin[]
  reorderRules                  ReorderRule[]
  stockAlerts                   StockAlert[]
  inventoryValuations           InventoryValuation[]
  productKit                    ProductKit?
  productKitItems               ProductKitItem[]
  subcontractingMaterials       SubcontractingMaterial[]
  componentConsumptions         WorkOrderComponentConsumption[]
  purchaseRequisitionItems      PurchaseRequisitionItem[]
  blanketPurchaseAgreementItems BlanketPurchaseAgreementItem[]
  channelInventory              ChannelInventory[]
  storefrontListings            ProductListing[]

  @@unique([tenantId, orgId, sku])
  @@index([tenantId])
  @@index([tenantId, categoryId])
  @@map("products")
}

model Warehouse {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  orgId     String   @map("org_id")
  name      String
  code      String
  address   Json?
  type      String   @default("MAIN") // MAIN, TRANSIT, VIRTUAL, RETAIL, CONSIGNMENT
  managerId String?  @map("manager_id")
  capacity  Decimal? @db.Decimal(15, 3)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization       Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  inventoryItems     InventoryItem[]
  stockLedgerEntries StockLedgerEntry[]
  binLocations       BinLocation[]
  fixedAssets        FixedAsset[]

  @@unique([tenantId, orgId, code])
  @@index([tenantId])
  @@map("warehouses")
}

model InventoryItem {
  id            String    @id @default(cuid())
  tenantId      String    @map("tenant_id")
  productId     String    @map("product_id")
  warehouseId   String    @map("warehouse_id")
  quantity      Decimal   @default(0) @db.Decimal(15, 3)
  reservedQty   Decimal   @default(0) @map("reserved_qty") @db.Decimal(15, 3)
  committedQty  Decimal   @default(0) @map("committed_qty") @db.Decimal(15, 3)
  inTransitQty  Decimal   @default(0) @map("in_transit_qty") @db.Decimal(15, 3)
  reorderPoint  Decimal?  @map("reorder_point") @db.Decimal(15, 3)
  reorderQty    Decimal?  @map("reorder_qty") @db.Decimal(15, 3)
  valuationRate Decimal?  @map("valuation_rate") @db.Decimal(15, 4)
  lastCountDate DateTime? @map("last_count_date")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([tenantId, productId, warehouseId])
  @@index([tenantId])
  @@map("inventory_items")
}

// ════════════════════════════════════════════════
// FINANCE MODULE
// ════════════════════════════════════════════════

model Invoice {
  id             String    @id @default(cuid())
  tenantId       String    @map("tenant_id")
  orgId          String    @map("org_id")
  customerId     String    @map("customer_id")
  invoiceNumber  String    @map("invoice_number")
  status         String    @default("DRAFT")
  issueDate      DateTime  @default(now()) @map("issue_date")
  dueDate        DateTime  @map("due_date")
  subtotal       Decimal   @default(0) @db.Decimal(15, 2)
  taxAmount      Decimal   @default(0) @map("tax_amount") @db.Decimal(15, 2)
  discountAmount Decimal   @default(0) @map("discount_amount") @db.Decimal(15, 2)
  totalAmount    Decimal   @default(0) @map("total_amount") @db.Decimal(15, 2)
  paidAmount     Decimal   @default(0) @map("paid_amount") @db.Decimal(15, 2)
  currency       String    @default("USD")
  exchangeRate   Decimal   @default(1) @map("exchange_rate") @db.Decimal(15, 6)
  notes          String?
  internalNotes  String?   @map("internal_notes")
  paidAt         DateTime? @map("paid_at")
  sentAt         DateTime? @map("sent_at")
  createdBy      String?   @map("created_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  customer    Customer          @relation(fields: [customerId], references: [id])
  lineItems   InvoiceLineItem[]
  payments    Payment[]
  creditNotes CreditNote[]

  @@unique([tenantId, orgId, invoiceNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, customerId])
  @@map("invoices")
}

model InvoiceLineItem {
  id          String  @id @default(cuid())
  tenantId    String  @map("tenant_id")
