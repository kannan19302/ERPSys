// ─────────────────────────────────────────────────
// Prisma Schema — Universal ERP System
// ─────────────────────────────────────────────────
// This is the single source of truth for the database schema.
// All entities follow the patterns defined in .ai/DATA_MODEL.md
// ─────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ════════════════════════════════════════════════
// MULTI-TENANCY & AUTH
// ════════════════════════════════════════════════

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      String   @default("free")
  status    String   @default("ACTIVE")
  settings  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  demoDataLoaded Boolean   @default(false) @map("demo_data_loaded")
  demoLoadedAt   DateTime? @map("demo_loaded_at")

  users                User[]
  organizations        Organization[]
  subscription         TenantSubscription?
  installedApps        InstalledApp[]
  demoDataRecords      DemoDataRecord[]
  accessPackages       AccessPackage[]
  ssoConfigs           SsoConfig[]
  userSessions         UserSession[]
  userGroups           UserGroup[]
  ipRestrictions       IpRestriction[]
  fixedAssets          FixedAsset[]
  fixedAssetCategories FixedAssetCategory[]
  assetDepreciations   AssetDepreciation[]
  assetTransferLogs    AssetTransferLog[]
  assetMaintenanceLogs AssetMaintenanceLog[]
  savedViews              SavedView[]
  blockchainTransactions  BlockchainTransaction[]
  blockchainVerifications BlockchainVerification[]
  outboxEvents            OutboxEvent[]
  outboxDeliveries        OutboxDelivery[]
  outboxConsumerReceipts  OutboxConsumerReceipt[]
  lifecycleEvents         TenantLifecycleEvent[]

  @@map("tenants")
}

model TenantLifecycleEvent {
  id            String   @id @default(cuid())
  tenantId      String
  eventType     String   // EXPORT, SUSPEND, UNSUSPEND, OFFBOARD, CANCEL_OFFBOARD, PURGE
  status        String   // PENDING, COMPLETED, FAILED
  initiatedBy   String?  // User ID or "system"
  retentionDays Int?     @default(90)
  payload       Json?    @db.JsonB
  errorMessage  String?  @db.Text
  completedAt   DateTime?
  createdAt     DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("tenant_lifecycle_events")
}

model User {
  id           String    @id @default(cuid())
  tenantId     String    @map("tenant_id")
  email        String
  passwordHash String?   @map("password_hash")
  firstName    String    @map("first_name")
  lastName     String    @map("last_name")
  avatar       String?
  status       String    @default("ACTIVE")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")
  preferences  Json      @default("{}")

  emailVerifiedAt DateTime? @map("email_verified_at")

  mfaEnabled       Boolean @default(false) @map("mfa_enabled")
  mfaSecret        String? @map("mfa_secret")
  mfaPending       Boolean @default(false) @map("mfa_pending")
  mfaRecoveryCodes Json    @default("[]") @map("mfa_recovery_codes")

  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until")
  passwordChangedAt   DateTime? @map("password_changed_at")

  tenant             Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roles              UserRole[]
  userSessions       UserSession[]
  groupMemberships   UserGroupMember[]
  passkeys           Passkey[]
  savedViews         SavedView[]
  passwordResetTokens PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
  @@map("users")
}

model SavedView {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  userId       String   @map("user_id")
  resourceName String   @map("resource_name")
  name         String
  state        Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, resourceName, name])
  @@index([tenantId])
  @@index([userId])
  @@map("saved_views")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tenantId  String    @map("tenant_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tenantId  String    @map("tenant_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

model Passkey {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  credentialID String   @unique @map("credential_id")
  publicKey    String   @map("public_key")
  counter      Int
  transports   String?
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("passkeys")
}

model Role {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  name        String
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  permissions Json     @default("[]")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users          UserRole[]
  accessPackages RoleAccessPackage[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("roles")
}

model UserRole {
  userId     String   @map("user_id")
  roleId     String   @map("role_id")
  assignedAt DateTime @default(now()) @map("assigned_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

// ════════════════════════════════════════════════
// ORGANIZATION STRUCTURE
// ════════════════════════════════════════════════

model Organization {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  name            String
  legalName       String?  @map("legal_name")
  taxId           String?  @map("tax_id")
  email           String?
  phone           String?
  website         String?
  logo            String?
  address         Json?
  currency        String   @default("USD")
  timezone        String   @default("UTC")
  fiscalYearStart Int      @default(1) @map("fiscal_year_start")
  settings        Json     @default("{}")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant                    Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  departments               Department[]
  customers                 Customer[]
  vendors                   Vendor[]
  products                  Product[]
  warehouses                Warehouse[]
  creditNotes               CreditNote[]
  debitNotes                DebitNote[]
  dunningLevels             DunningLevel[]
  dunningRuns               DunningRun[]
  dunningLogs               InvoiceDunningLog[]
  paymentSchedules          PaymentSchedule[]
  paymentRuns               PaymentRun[]
  budgets                   Budget[]
  forecastScenarios         ForecastScenario[]
  taxRules                  TaxRule[]
  withholdingTaxes          WithholdingTax[]
  taxFilings                TaxFiling[]
  outgoingTransfers         InterCompanyTransfer[]     @relation("FromOrganization")
  incomingTransfers         InterCompanyTransfer[]     @relation("ToOrganization")
  investmentPortfolios      InvestmentPortfolio[]
  treasuryTransactions      TreasuryTransaction[]
  rfqs                      RFQ[]
  supplierQuotations        SupplierQuotation[]
  campaigns                 Campaign[]
  salesReturns              SalesReturn[]
  purchaseReturns           PurchaseReturn[]
  vendorRmaRequests         VendorRmaRequest[]
  purchaseRequisitions      PurchaseRequisition[]
  blanketPurchaseAgreements BlanketPurchaseAgreement[]
  cases                     Case[]
  salesChannels             SalesChannel[]
  accountingBooks           AccountingBook[]
  contracts                 Contract[]
  financeLeases             FinanceLease[]
  demandForecastRuns        DemandForecastRun[]

  @@index([tenantId])
  @@map("organizations")
}

model Department {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  orgId     String   @map("org_id")
  name      String
  code      String
  parentId  String?  @map("parent_id")
  managerId String?  @map("manager_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization         Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  parent               Department?           @relation("DeptHierarchy", fields: [parentId], references: [id])
  children             Department[]          @relation("DeptHierarchy")
  employees            Employee[]
  journalEntries       JournalEntry[]
  positions            Position[]
  purchaseRequisitions PurchaseRequisition[]

  @@unique([tenantId, orgId, code])
  @@index([tenantId])
  @@map("departments")
}

// ════════════════════════════════════════════════
// HR MODULE
// ════════════════════════════════════════════════

model Employee {
  id             String    @id @default(cuid())
  tenantId       String    @map("tenant_id")
  orgId          String    @map("org_id")
  userId         String?   @map("user_id")
  departmentId   String?   @map("department_id")
  employeeCode   String    @map("employee_code")
  firstName      String    @map("first_name")
  lastName       String    @map("last_name")
  email          String
  phone          String?
  designation    String?
  dateOfBirth    DateTime? @map("date_of_birth")
  dateOfJoining  DateTime  @map("date_of_joining")
  dateOfLeaving  DateTime? @map("date_of_leaving")
  employmentType String    @default("FULL_TIME") @map("employment_type")
  status         String    @default("ACTIVE")
  address        Json?
  bankDetails    Json?     @map("bank_details")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  department          Department?          @relation(fields: [departmentId], references: [id])
  trainingEnrollments TrainingEnrollment[]
  fixedAssets         FixedAsset[]

  @@unique([tenantId, orgId, employeeCode])
  @@index([tenantId])
  @@map("employees")
}

// ════════════════════════════════════════════════
// CRM MODULE
// ════════════════════════════════════════════════

model Customer {
  id               String    @id @default(cuid())
  tenantId         String    @map("tenant_id")
  orgId            String    @map("org_id")
  type             String    @default("COMPANY")
  name             String
  email            String?
  phone            String?
  taxId            String?   @map("tax_id")
  billingAddress   Json?     @map("billing_address")
  shippingAddress  Json?     @map("shipping_address")
  creditLimit      Decimal?  @map("credit_limit") @db.Decimal(15, 2)
  paymentTerms     Int       @default(30) @map("payment_terms")
  status           String    @default("ACTIVE")
  notes            String?
  customerType     String    @default("RECURRING") @map("customer_type")
  creditHold       Boolean   @default(false) @map("credit_hold")
  creditHoldReason String?   @map("credit_hold_reason")
  riskRating       String    @default("LOW") @map("risk_rating")
  parentCustomerId String?   @map("parent_customer_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  organization  Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  parentCustomer   Customer?         @relation("CustomerHierarchy", fields: [parentCustomerId], references: [id])
  childCustomers   Customer[]        @relation("CustomerHierarchy")
  invoices      Invoice[]
  quotations    Quotation[]
  salesOrders   SalesOrder[]
  creditNotes   CreditNote[]
  contacts      Contact[] // Added for inverse relation
  opportunities Opportunity[] // Added for inverse relation
  activities    Activity[] // Added for inverse relation
  salesReturns  SalesReturn[]
  projects      Project[]
  cases         Case[]
  tags          CustomerTagLink[]
  contracts     Contract[]
  accountPlans  AccountPlan[]
  healthLogs    CustomerHealthLog[]
  portalUsers   CustomerPortalUser[]

  @@index([tenantId])
  @@index([tenantId, orgId])
  @@index([parentCustomerId])
  @@map("customers")
}

model Vendor {
  id                    String    @id @default(cuid())
  tenantId              String    @map("tenant_id")
  orgId                 String    @map("org_id")
  type                  String    @default("COMPANY")
  name                  String
  email                 String?
  phone                 String?
  taxId                 String?   @map("tax_id")
  address               Json?
  paymentTerms          Int       @default(30) @map("payment_terms")
  status                String    @default("ACTIVE")
  notes                 String?
  onboardingStatus      String    @default("PENDING") @map("onboarding_status")
  checklistTaxVerified  Boolean   @default(false) @map("checklist_tax_verified")
  checklistBankVerified Boolean   @default(false) @map("checklist_bank_verified")
  checklistNdaSigned    Boolean   @default(false) @map("checklist_nda_signed")
  averageLeadTimeDays   Float     @default(0.0) @map("average_lead_time_days")
  qualityScore          Float     @default(100.0) @map("quality_score")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  deletedAt             DateTime? @map("deleted_at")

  organization              Organization               @relation(fields: [orgId], references: [id], onDelete: Cascade)
  purchaseOrders            PurchaseOrder[]
  debitNotes                DebitNote[]
  paymentSchedules          PaymentSchedule[]
  supplierQuotations        SupplierQuotation[]
  purchaseReturns           PurchaseReturn[]
  vendorRmaRequests         VendorRmaRequest[]
  subcontractingOrders      SubcontractingOrder[]
  blanketPurchaseAgreements BlanketPurchaseAgreement[]
  supplierScorecards        SupplierScorecard[]
  supplierNcrs              SupplierNcr[]
  supplierCarRequests       SupplierCarRequest[]
  portalUsers               VendorPortalUser[]
  auctionBids               RFQAuctionBid[]
  contracts                 Contract[]
  vendor1099Profile         Vendor1099Profile?
  form1099s                 Form1099[]

  @@index([tenantId])
  @@map("vendors")
}

model Contact {
  id                     String    @id @default(cuid())
  tenantId               String    @map("tenant_id")
  orgId                  String    @map("org_id")
  customerId             String?   @map("customer_id")
  salutation             String?
  firstName              String    @map("first_name")
  lastName               String    @map("last_name")
  email                  String?
  phone                  String?
  mobile                 String?
  title                  String?
  department             String?
  isPrimary              Boolean   @default(false) @map("is_primary")
  isActive               Boolean   @default(true) @map("is_active")
  score                  Int       @default(0)
  notes                  String?
  secondaryEmail         String?   @map("secondary_email")
  preferredContactMethod String?   @map("preferred_contact_method")
  engagementScore        Int       @default(0) @map("engagement_score")
  socialProfiles         Json?     @map("social_profiles")
  lifecycleStatus        String    @default("ACTIVE") @map("lifecycle_status")
  buyingRole             String    @default("INFLUENCER") @map("buying_role")
  lastContactedAt        DateTime? @map("last_contacted_at")
  interactionVelocity    Int       @default(0) @map("interaction_velocity")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")
  deletedAt              DateTime? @map("deleted_at")

  customer         Customer?            @relation(fields: [customerId], references: [id])
  activities       Activity[]
  tags             ContactTagLink[]
  cases            Case[]
  opportunityRoles ContactRole[]
  portalUsers      CustomerPortalUser[]

  @@unique([tenantId, orgId, email])
  @@index([tenantId])
  @@index([customerId])
  @@map("contacts")
}

model LeadSource {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  leads Lead[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("lead_sources")
}

model Lead {
  id                     String    @id @default(cuid())
  tenantId               String    @map("tenant_id")
  orgId                  String    @map("org_id")
  salutation             String?
  firstName              String    @map("first_name")
  lastName               String    @map("last_name")
  company                String?
  title                  String?
  email                  String?
  phone                  String?
  mobile                 String?
  website                String?
  sourceId               String?   @map("source_id")
  status                 String    @default("NEW") // NEW, CONTACTED, QUALIFIED, DISQUALIFIED, CONVERTED
  industry               String?
  employeeCount          Int?      @map("employee_count")
  annualRevenue          Decimal?  @map("annual_revenue") @db.Decimal(15, 2)
  country                String?
  region                 String?
  score                  Int       @default(0)
  notes                  String?
  assignedToId           String?   @map("assigned_to_id")
  convertedCustomerId    String?   @map("converted_customer_id")
  convertedOpportunityId String?   @map("converted_opportunity_id")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")
  deletedAt              DateTime? @map("deleted_at")

  campaignId String? @map("campaign_id")

  source        LeadSource?   @relation(fields: [sourceId], references: [id])
  campaign      Campaign?     @relation(fields: [campaignId], references: [id])
  activities    Activity[]
  opportunities Opportunity[] @relation("LeadOpportunity")

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([campaignId])
  @@index([assignedToId])
  @@map("leads")
}

model SalesPipeline {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  name      String
  stages    Json     @default("[]") // Array of {label, probability, order}
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  opportunities Opportunity[]
  stageConfigs  PipelineStage[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("sales_pipelines")
}

model Opportunity {
  id                String    @id @default(cuid())
  tenantId          String    @map("tenant_id")
  orgId             String    @map("org_id")
  name              String
  customerId        String?   @map("customer_id")
  leadId            String?   @map("lead_id")
  pipelineId        String?   @map("pipeline_id")
  stage             String    @default("PROSPECTING") // Prospecting, Qualification, Proposal, Negotiation, Closed Won, Closed Lost
  amount            Decimal?  @db.Decimal(15, 2)
  probability       Int       @default(0) // 0-100
  expectedCloseDate DateTime? @map("expected_close_date")
  actualCloseDate   DateTime? @map("actual_close_date")
  competitor        String?
  lossReason        String?   @map("loss_reason")
  notes             String?
  assignedToId      String?   @map("assigned_to_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  currency       String    @default("USD")
  weightedAmount Decimal?  @map("weighted_amount") @db.Decimal(15, 2)
  stageEnteredAt DateTime? @map("stage_entered_at")

  customer     Customer?             @relation(fields: [customerId], references: [id])
  lead         Lead?                 @relation("LeadOpportunity", fields: [leadId], references: [id])
  pipeline     SalesPipeline?        @relation(fields: [pipelineId], references: [id])
  activities   Activity[]
  lineItems    OpportunityLineItem[]
  tags         DealTag[]
  teamMembers  DealTeamMember[]
  contactRoles ContactRole[]
  riskAlerts   PipelineRiskAlert[]
  dealRoom     DealRoom?

  @@index([tenantId])
  @@index([tenantId, stage])
  @@index([tenantId, pipelineId])
  @@index([customerId])
  @@map("opportunities")
}

model ForecastSnapshot {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  orgId          String   @map("org_id")
  name           String
  periodStart    DateTime @map("period_start")
  periodEnd      DateTime @map("period_end")
  quotaAmount    Decimal  @map("quota_amount") @db.Decimal(15, 2)
  pipelineAmount Decimal  @map("pipeline_amount") @db.Decimal(15, 2)
  wonAmount      Decimal  @map("won_amount") @db.Decimal(15, 2)
  forecastAmount Decimal  @map("forecast_amount") @db.Decimal(15, 2) // override amount
  status         String   @default("DRAFT") // DRAFT, FROZEN
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("forecast_snapshots")
}

model Quota {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  orgId     String   @map("org_id")
  userId    String   @map("user_id")
  period    String // Q1 2026, FY2026, etc.
  amount    Decimal  @db.Decimal(15, 2)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, userId, period])
  @@index([tenantId])
  @@map("quotas")
}

model DealTag {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  opportunityId String   @map("opportunity_id")
  tag           String
  createdAt     DateTime @default(now()) @map("created_at")

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@unique([tenantId, opportunityId, tag])
  @@index([tenantId])
  @@map("deal_tags")
}

model DealTeamMember {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  opportunityId String   @map("opportunity_id")
  userId        String   @map("user_id")
  role          String // AE, SC, CSM, Exec Sponsor
  accessLevel   String   @default("READ") // READ, WRITE
  createdAt     DateTime @default(now()) @map("created_at")

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@unique([tenantId, opportunityId, userId])
  @@index([tenantId])
  @@map("deal_team_members")
}

/// Pipeline Inspection / stage-change risk alerts (Einstein Pipeline Inspection /
/// HubSpot Breeze-style). Persisted risk records surfaced tenant-wide on a
/// dashboard, distinct from the existing on-demand `getRottingDeals`/
/// `getDealRiskIndicators` analysis in `crm-forecasting.service.ts` — those
/// compute risk when asked about ONE deal; this recomputes + PERSISTS an
/// alert row per at-risk deal across the WHOLE pipeline so alerts can be
/// listed, acknowledged/snoozed, and (via the `pipeline.deal.at_risk` event)
/// drive notifications.
model PipelineRiskAlert {
  id             String    @id @default(cuid())
  tenantId       String    @map("tenant_id")
  orgId          String    @map("org_id")
  opportunityId  String    @map("opportunity_id")
  alertType      String    @map("alert_type") // STAGE_STALL, CLOSE_DATE_SLIPPED, LOW_CONFIDENCE, NO_ACTIVITY
  riskLevel      String    @default("MEDIUM") @map("risk_level") // LOW, MEDIUM, HIGH, CRITICAL
  daysInStage    Int?      @map("days_in_stage")
  message        String
  status         String    @default("OPEN") // OPEN, ACKNOWLEDGED, SNOOZED, RESOLVED
  snoozedUntil   DateTime? @map("snoozed_until")
  acknowledgedBy String?   @map("acknowledged_by")
  acknowledgedAt DateTime? @map("acknowledged_at")
  resolvedAt     DateTime? @map("resolved_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@unique([tenantId, opportunityId, alertType])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([opportunityId])
  @@map("pipeline_risk_alerts")
}

/// Customer-portal online invoice payment collection (Up Next item 37).
/// Records a payment attempt initiated by a portal customer via the mock
/// gateway seam (mirrors `PaymentGatewayAdapter` in ecommerce/payments —
/// re-implemented here, not cross-imported, since CRM cannot depend on the
/// ecommerce module). On `succeeded`, a real `Payment` row is created against
/// the invoice, same as staff-recorded payments.
model PortalPaymentIntent {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  invoiceId       String    @map("invoice_id")
  customerId      String    @map("customer_id")
  portalUserId    String    @map("portal_user_id")
  amount          Decimal   @db.Decimal(15, 2)
  currency        String    @default("USD")
  provider        String    @default("mock_gateway")
  gatewayIntentId String    @map("gateway_intent_id")
  status          String    @default("REQUIRES_CONFIRMATION") // REQUIRES_CONFIRMATION, SUCCEEDED, FAILED
  paymentId       String?   @map("payment_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  confirmedAt     DateTime? @map("confirmed_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([invoiceId])
  @@index([tenantId, customerId])
  @@map("portal_payment_intents")
}

