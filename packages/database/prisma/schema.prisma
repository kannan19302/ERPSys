  orgId              String   @map("org_id")
  assetCode          String   @map("asset_code")
  name               String
  description        String?
  categoryId         String?  @map("category_id")
  purchaseDate       DateTime @map("purchase_date")
  purchaseValue      Decimal  @map("purchase_value") @db.Decimal(15, 2)
  salvageValue       Decimal  @map("salvage_value") @db.Decimal(15, 2)
  usefulLifeYears    Int      @map("useful_life_years")
  depreciationMethod String   @map("depreciation_method") // SLM, WDV
  depreciationRate   Decimal? @map("depreciation_rate") @db.Decimal(5, 2)
  currentValue       Decimal  @map("current_value") @db.Decimal(15, 2)
  accountId          String   @map("account_id")
  accumDepAccountId  String   @map("accum_dep_account_id")
  locationId         String?  @map("location_id")
  custodianId        String?  @map("custodian_id")
  status             String   @default("ACTIVE") // ACTIVE, DISPOSED, UNDER_MAINTENANCE
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  createdBy          String   @default("system") @map("created_by")
  updatedBy          String   @default("system") @map("updated_by")

  category           FixedAssetCategory? @relation(fields: [categoryId], references: [id])
  location           Warehouse?          @relation(fields: [locationId], references: [id])
  custodian          Employee?           @relation(fields: [custodianId], references: [id])
