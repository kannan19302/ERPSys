{
  "name": "@unerp/database",
  "version": "0.0.1",
  "private": true,
  "description": "Prisma ORM schema, client, and migrations",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "lint": "eslint src/",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@prisma/client": "^6.2.0"
  },
  "devDependencies": {
    "@unerp/config": "workspace:*",
    "@types/node": "^22.0.0",
    "prisma": "^6.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "rimraf": "^6.0.0"
  }
}
