{
  "name": "@unerp/ui",
  "version": "0.0.1",
  "private": true,
  "description": "UniERP Design System — backward-compat facade over @unerp/ui-* packages",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./styles": "./src/styles/globals.css",
    "./tokens": "./src/tokens/design-tokens.css"
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@unerp/ui-charts": "workspace:*",
    "@unerp/ui-components": "workspace:*",
    "@unerp/ui-dashboard": "workspace:*",
    "@unerp/ui-data-grid": "workspace:*",
    "@unerp/ui-hooks": "workspace:*",
    "@unerp/ui-icons": "workspace:*",
    "@unerp/ui-layout": "workspace:*",
    "@unerp/ui-notifications": "workspace:*",
    "@unerp/ui-theme": "workspace:*",
    "@unerp/ui-tokens": "workspace:*",
    "@unerp/ui-utils": "workspace:*",
    "lucide-react": "^1.25.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@unerp/config": "workspace:*",
    "rimraf": "^6.0.0",
    "typescript": "^5.7.0"
  }
}
