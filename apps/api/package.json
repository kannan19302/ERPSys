{
  "name": "@unerp/api",
  "version": "0.0.1",
  "private": true,
  "description": "UniERP Backend API — NestJS",
  "scripts": {
    "dev": "nest start --watch --transpile-only",
    "build": "nest build",
    "start": "node dist/main",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "powershell -ExecutionPolicy Bypass -File ./run-tests-sequential.ps1",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/event-emitter": "^3.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.1.27",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/throttler": "^6.0.0",
    "@nestjs/websockets": "^11.1.27",
    "@opentelemetry/auto-instrumentations-node": "^0.77.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@prisma/client": "^6.2.0",
    "@sentry/nestjs": "^10.61.0",
    "@sentry/node": "^10.61.0",
    "@types/multer": "^1.4.11",
    "@unerp/auth": "workspace:*",
    "@unerp/database": "workspace:*",
    "@unerp/shared": "workspace:*",
    "bullmq": "^5.79.1",
    "cookie-parser": "^1.4.7",
    "exceljs": "^4.4.0",
    "helmet": "^8.0.0",
    "pdfkit": "^0.19.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "socket.io": "^4.8.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/pdfkit": "^0.17.6",
    "@types/pino-http": "^6.1.0",
    "@unerp/config": "workspace:*",
    "@vitest/coverage-v8": "^2.1.9",
    "rimraf": "^6.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
