{
  "name": "@unerp/web",
  "version": "0.0.1",
  "private": true,
  "description": "UniERP Web Frontend — Next.js 15",
  "scripts": {
    "dev": "node ../../scripts/ensure-web-deps.mjs && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint \"app/**/*.{ts,tsx}\" \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:journeys": "playwright test --project=journeys",
    "test:e2e:all": "playwright test --project=all-e2e",
    "clean": "rimraf .next"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tanstack/react-query": "^5.101.1",
    "@types/papaparse": "^5.5.2",
    "@unerp/auth": "workspace:*",
    "@unerp/database": "workspace:*",
    "@unerp/framework": "workspace:*",
    "@unerp/shared": "workspace:*",
    "@unerp/ui": "workspace:*",
    "@xyflow/react": "^12.11.0",
    "lucide-react": "^1.25.0",
    "next": "^15.1.0",
    "papaparse": "^5.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-grid-layout": "^2.2.3",
    "react-zoom-pan-pinch": "^4.0.3",
    "recharts": "^3.9.0",
    "socket.io-client": "^4.8.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@unerp/config": "workspace:*",
    "rimraf": "^6.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
