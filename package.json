{
  "name": "unerp",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@unerp/web",
    "dev:api": "turbo run dev --filter=@unerp/api",
    "docker:up": "docker compose -f docker-compose.dev.yml up -d --build",
    "docker:down": "docker compose -f docker-compose.dev.yml down",
    "docker:logs": "docker compose -f docker-compose.dev.yml logs -f dev",
    "docker:shell": "docker exec -it unerp-dev sh",
    "docker:reset": "docker compose -f docker-compose.dev.yml down -v && docker compose -f docker-compose.dev.yml up -d --build",
    "lint": "turbo run lint",
    "architecture:check": "pnpm --filter @unerp/api architecture:check",
    "foundation:check": "node scripts/check-foundation-readiness.mjs",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:coverage": "turbo run test:coverage",
    "test:e2e": "turbo run test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "db:generate": "pnpm --filter @unerp/database db:generate",
    "db:migrate": "pnpm --filter @unerp/database db:migrate",
    "db:deploy": "pnpm --filter @unerp/database db:deploy",
    "db:push": "node scripts/forbid-db-push.mjs",
    "db:seed": "pnpm --filter @unerp/database db:seed",
    "migration:discipline": "node scripts/check-migration-discipline.mjs && node scripts/check-schema-lints.mjs",
    "migration:reconciliation:report": "node scripts/report-migration-reconciliation.mjs",
    "db:studio": "pnpm --filter @unerp/database db:studio",
    "clean": "turbo run clean && rimraf node_modules",
    "prepare": "husky",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "publish-packages": "pnpm turbo build && changeset publish",
    "schema:lint": "node scripts/check-schema-lints.mjs",
    "test:load": "k6 run",
    "test:load:smoke": "k6 run load-tests/scenarios/smoke-test.js",
    "test:load:login": "k6 run load-tests/scenarios/login.js",
    "test:load:list": "k6 run load-tests/scenarios/list-paginate.js",
    "test:load:post": "k6 run load-tests/scenarios/document-post.js",
    "test:load:stress": "k6 run load-tests/scenarios/stress-test.js",
    "test:load:tenant": "k6 run load-tests/scenarios/tenant-isolation.js",
    "test:audit": "pnpm audit --audit-level=high",
    "test:load:all": "k6 run load-tests/scenarios/smoke-test.js && k6 run load-tests/scenarios/login.js && k6 run load-tests/scenarios/list-paginate.js && k6 run load-tests/scenarios/document-post.js && k6 run load-tests/scenarios/tenant-isolation.js"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@next/eslint-plugin-next": "^15.1.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@unerp/config": "workspace:*",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.4.0",
    "rimraf": "^6.0.0",
    "tsup": "^8.5.1",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  }
}
